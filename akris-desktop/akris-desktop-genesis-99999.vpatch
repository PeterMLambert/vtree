--- akris-desktop/akris_desktop/console_renderers/knob.py false
+++ akris-desktop-genesis/akris_desktop/console_renderers/knob.py 589306c4b4c775a92139ffd6052277324ab59a5ac9e1e38022baf098c213072d7398cfb99a65ea110a860dc396c649f8d4e270ba65190ffbc46ba1797faab411
@@ -0,0 +1,16 @@
+import tkinter as tk
+
+
+class Knob:
+    def __init__(self, output):
+        self.output = output
+
+    def render(self, response):
+        knobs = response.get("body")
+        for key, value in knobs.items():
+            self.render_knob("{}:\t{}".format(key, value))
+
+    def render_knob(self, knob):
+        self.output.configure(state="normal")
+        self.output.insert(tk.END, "{}\n".format(knob))
+        self.output.configure(state="disabled")
