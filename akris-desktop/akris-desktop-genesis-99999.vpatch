+    app.update()
+    app.console.entry.event_generate('<Return>')
+    app.update()
+    assert(app.api_client.send_command.called_with({
+        'command': 'knob',
+        'args': []
+    }))
+    app.mainloop()
+
+def test_knob_get(app):
+    app.console.entry.focus_force()
+    app.console.entry.insert(0, 'knob max_bounces')
+    app.update()
+    app.console.entry.event_generate('<Return>')
+    app.update()
+    assert(app.api_client.send_command.called_with({
+        'command': 'knob',
