+    client.message_queue = Queue()
+    timestamp = int(time.time())
+    messages = [
+        {
+            'command': 'console_response',
+            'type': 'at',
+            'body': [
+                {
+                    'handle': 'atahualpa',
+                    'address': '122.122.0.1:8081',
+                    'active_at': '2023-05-21 07:13:26.541438',
+                    'active_at_unixtime': 1684678406
