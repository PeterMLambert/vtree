--- a/ffa/libffa/fz_arith.adb a6774ea126b6431e912686b5269349926976a8685a61817e99fe468b61056842a0881b0569d5ec0de27b904b456bd13350fc4f939286a5633c08a7888dd23c4b
+++ b/ffa/libffa/fz_arith.adb be7752ac12ad772033c57e4e844a62a2451b9e398a6b5f3ca4cd8873b0adaf6ccebe8093c3d4f4d9a4a40cde4fc48282e5e04579d9f284d0170a32b4ddb06777
@@ -161,6 +161,26 @@
    end FZ_Sub;
    
    
+   -- Difference := X - W; Underflow := Borrow
+   procedure FZ_Sub_W(X          : in  FZ;
+                      W          : in  Word;
+                      Difference : out FZ;
+                      Underflow  : out WBool) is
+      Borrow : Word := W;
+   begin
+      for i in 0 .. Word_Index(X'Length - 1) loop
+         declare
+            A : constant Word := X(X'First + i);
+            S : constant Word := A - Borrow;
+         begin
+            Difference(Difference'First + i) := S;
+            Borrow := W_Borrow(A, 0, S);
+         end;
+      end loop;
+      Underflow := Borrow;
+   end FZ_Sub_W;
+   
+   
    -- Destructive: If Cond is 1, NotN := ~N; otherwise NotN := N.
    procedure FZ_Not_Cond_D(N    : in out FZ;
                            Cond : in     WBool)is
