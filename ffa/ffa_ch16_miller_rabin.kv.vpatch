@@ -513,6 +513,29 @@
                FFA_FZ_Clear(Stack(SP));
                FFA_FZ_Set_Head(Stack(SP), Word(FFA_K_Version));
                
+               -- Constant-Time Miller-Rabin Test on N using the given Witness.
+               -- Witness will be used as-is if it conforms to the valid range,
+               -- i.e. 2 <= Witness <= N - 2; else will be transformed into a
+               -- valid Witness via modular arithmetic.
+               -- Outputs ONE if N WAS FOUND composite; ZERO if NOT FOUND.
+               -- Handles degenerate cases of N that M-R per se cannot eat:
+               -- N=0, N=1: ALWAYS 'FOUND COMPOS.'; 2, 3 - ALWAYS 'NOT FOUND'.
+               -- If N is Even and not equal to 2, N is ALWAYS 'FOUND COMPOS.'
+               -- For ALL other N, the output is equal to that of the M-R test.
+               -- At most 1/4 of all possible Witnesses will be 'liars' for
+               -- a particular composite N , i.e. fail to attest to its
+               -- compositivity.
+            when 'P' =>
+               Want(2);
+               declare
+                  MR_Result : WBool := 
+                    FFA_FZ_MR_Composite_On_Witness(N       => Stack(SP - 1),
+                                                   Witness => Stack(SP));
+               begin
+                  FFA_WBool_To_FZ(MR_Result, Stack(SP - 1));
+               end;
+               Drop;
+               
                --------------
                -- Prefixes --
                --------------
@@ -534,7 +557,7 @@
                ---------------------------------------------------------
             when '!' | '@' | '$' | ':' | ';' | ',' |
                  'H' | 'I' | 'J' | 'K' | 'N' |
-                 'P' | 'T' | 'X' | 'Y' =>
+                 'T' | 'X' | 'Y' =>
                
                E("This Operator is not defined yet: " & C);
                ---------------------------------------------------------
