+++ b/ffa/libffa/fz_measr.ads f4b728be332da4162214657e54df4a241b02dfe4781ac47e34df24138661c9c0e0d7835e3cf34377a3e152051a17a6c7adf0d24c793a80f93f47c117f471b3b1
@@ -17,7 +17,6 @@
 ------------------------------------------------------------------------------
