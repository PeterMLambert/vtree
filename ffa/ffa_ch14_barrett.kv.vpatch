@@ -24,7 +24,7 @@
    
    pragma Pure;
    
-   -- Modular Multiply: Product := X*Y mod Modulus
+   -- (Conventional) Modular Multiply: Product := X*Y mod Modulus
    procedure FZ_Mod_Mul(X        : in  FZ;
                         Y        : in  FZ;
                         Modulus  : in  FZ;
@@ -33,14 +33,14 @@
