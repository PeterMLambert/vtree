+++ b/ffa/ffacalc/os.adb 05940de6b9b69ff1479bee3ef9bf100edb3cff903a3ec4a014d6b238643c576f1136fd5c0a48ed43c3c5234e576f317ccb2db45f21d0e2465320fb5cd1f2bd47
@@ -69,7 +69,18 @@
       To_Stderr(Character'Val(16#A#));
       
       -- Exit
-      Quit(Sadness_Code);
-   end;
+      Quit(Sad_Code);
+   end Eggog;
+   
+   -- Warn operator re: potentially-dangerous condition.
+   procedure Achtung(M : String) is
+   begin
+      for i in 1 .. M'Length loop
+         To_Stderr(M(I));
+      end loop;
+      
+      -- Emit LF
+      To_Stderr(Character'Val(16#A#));
+   end Achtung;
    
 end OS;
