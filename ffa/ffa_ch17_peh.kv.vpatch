 end Version;
diff -uNr a/ffa/libffa/fz_prime.adb b/ffa/libffa/fz_prime.adb
--- a/ffa/libffa/fz_prime.adb 78d4c49ffca81897f9e4832f272a46df2dd8258bcd4502fff7c716e4d8b7e67f5c96aea13e193d44374ffadc7bf3487ae14c512257875d95c3414fd37c69f03a
+++ b/ffa/libffa/fz_prime.adb 690acdd6451fc4e1c2263ca60e7240357c5438334c009521a1e32f12bbfb02370b9e68f6b66c00470a5bf440ca80827f82e090a5f72d447877542e6d9c09c7b8
@@ -194,7 +194,7 @@
       -- Generate Barrettoid(X) to use in all of the modulo-X operations:
       FZ_Make_Barrettoid(Modulus => X, Result => XBar);
       
-      -- Find R >= 1, and odd K, where X − 1 = 2^R * K :
+      -- Find R >= 1, and odd K, where X - 1 = 2^R * K :
       
       -- ... first, find R, the largest power of two which divides X - 1 :
       R := FZ_Count_Bottom_Zeros(X_Minus_One);
