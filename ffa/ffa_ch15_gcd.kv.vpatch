                  'P' | 'T' | 'X' | 'Y' =>
                
                E("This Operator is not defined yet: " & C);
@@ -602,19 +615,27 @@
                   when 'R' =>
                      E("Right-Rotate not yet defined!");
                      
+                  -- 'Right-Multiply', give only lower half of the product XY
+                  when '*' =>
+                     Want(2);
+                     FFA_FZ_Low_Multiply(X  => Stack(SP - 1),
+                                         Y  => Stack(SP),
+                                         XY => Stack(SP - 1));
+                     Drop;
+                     
                   -- ... Unknown:
                   when others =>
                      E("Undefined Op: R" & O);
                      
                end case;
             ---------------------------------------------------------
-            -- Modular...   
+            -- Modular...
             when 'M' =>
                
                -- Which M-op?
                case O is
                   
-                  -- ... Multiplication :
+                  -- ... Multiplication (Conventional) :
                   when '*' =>
                      Want(3);
                      MustNotZero(Stack(SP));
@@ -625,7 +646,16 @@
                      Drop;
                      Drop;
                      
-                  -- ... Exponentiation :
+                  -- ... Squaring (Conventional) :
+                  when 'S' =>
+                     Want(2);
+                     MustNotZero(Stack(SP));
+                     FFA_FZ_Modular_Square(X       => Stack(SP - 1),
+                                           Modulus => Stack(SP),
+                                           Product => Stack(SP - 1));
+                     Drop;
+                     
+                  -- ... Exponentiation (Barrettronic) :
                   when 'X' =>
                      Want(3);
                      MustNotZero(Stack(SP));
