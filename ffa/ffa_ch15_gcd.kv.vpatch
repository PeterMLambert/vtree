@@ -393,6 +393,27 @@
                                XY_Lo => Stack(SP - 1),
                                XY_Hi => Stack(SP));
                
+               -- Square, give bottom and top halves
+            when 'S' =>
+               Want(1);
+               Push;
+               FFA_FZ_Square(X     => Stack(SP - 1),
+                             XX_Lo => Stack(SP - 1),
+                             XX_Hi => Stack(SP));
+               
+               -- Greatest Common Divisor (GCD)
+            when 'G' =>
+               Want(2);
+               
+               -- Note that GCD(0,0) is not factually zero, or unique.
+               -- But it is permissible to define it as zero.
+               -- (See Ch. 15 discussion.)
+               
+               FFA_FZ_Greatest_Common_Divisor(X      => Stack(SP - 1),
+                                              Y      => Stack(SP),
+                                              Result => Stack(SP - 1));
+               Drop;
+               
                -----------------
                -- Bitwise Ops --
                -----------------
