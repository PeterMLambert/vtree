      X'Length mod 2 = 0;
    -- CAUTION: Inlining prohibited for Low_Mul !
    
+   -- Low-Only Multiplier. Preserves the inputs.
+   procedure FZ_Low_Multiply_Buffered(X     : in  FZ;
+                                      Y     : in  FZ;
+                                      XY    : out FZ)
+     with Pre => X'Length = Y'Length and
+     XY'Length = X'Length and
+     X'Length mod 2 = 0;
+   
 end FZ_LoMul;
