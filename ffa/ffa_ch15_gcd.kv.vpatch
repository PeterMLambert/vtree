@@ -176,4 +176,21 @@
       
    end FZ_Low_Multiply_Unbuffered;
    
+   
+   -- Low-Only Multiplier. Preserves the inputs.
+   procedure FZ_Low_Multiply_Buffered(X     : in  FZ;
+                                      Y     : in  FZ;
+                                      XY    : out FZ) is
+      
+      -- Product buffer.
+      P : FZ(1 .. X'Length);
+      
+   begin
+      
+      FZ_Low_Multiply_Unbuffered(X, Y, P);
+      
+      XY := P;
+      
+   end FZ_Low_Multiply_Buffered;
+   
 end FZ_LoMul;
