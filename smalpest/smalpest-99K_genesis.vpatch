diff -uNr a/makefile b/makefile
--- a/makefile false
+++ b/makefile 77469f9c4c5bc3c62adb0fd854e0bf604a0079b012949e47f33d93fa4843c477349a4717d9aca0bb66d5523238e98c8d6c46cb2a7847b4a3d84b5b47b717f1f1
@@ -0,0 +1,71 @@
+.POSIX:
+.SUFFIXES:
+
+OUT        := smalpest
+CFLAGS     := -std=c99 -O3 -DNDEBUG -fdata-sections -ffunction-sections -Wno-parentheses
+LDFLAGS    := -Wl,--gc-sections
+LDLIBS     := 
+OBJ        := \
+	src/addr.o \
+	src/addrcast.o \
+	src/banner.o \
+	src/black.o \
+	src/chain.o \
+	src/console.o \
+	src/data.o \
+	src/dedup.o \
+	src/getdata.o \
+	src/hash.o \
+	src/hearsay.o \
+	src/hmac.o \
+	src/ht.o \
+	src/idx.o \
+	src/ignore.o \
+	src/io.o \
+	src/irc.o \
+	src/ircd.o \
+	src/irclog.o \
+	src/key.o \
+	src/killfile.o \
+	src/knob.o \
+	src/log.o \
+	src/main.o \
+	src/memset.o \
+	src/mess.o \
+	src/message.o \
+	src/msg.o \
+	src/net.o \
+	src/otherpplgode/base64.o \
+	src/otherpplgode/hmac.o \
+	src/otherpplgode/serpent.o \
+	src/otherpplgode/sha.o \
+	src/packetlog.o \
+	src/peer.o \
+	src/peerio.o \
+	src/pending.o \
+	src/pest.o \
+	src/recv.o \
+	src/rekey.o \
+	src/rng.o \
+	src/send.o \
+	src/serial.o \
+	src/serpent.o \
+	src/sha.o \
+	src/state.o \
+	src/string.o \
+	src/time.o \
+	src/util.o \
+	src/wipe.o \
+
+all: $(OUT)
+
+$(OUT): $(OBJ)
+	$(CC) $(LDFLAGS) $(OBJ) -o $@ $(LDLIBS)
+
+.SUFFIXES: .c .o
+.c.o:
+	$(CC) $(CFLAGS) -c $< -o $@
+
+clean:
+	rm -f $(OUT)
+	rm -f src/*.o
diff -uNr a/src/addr.c b/src/addr.c
--- a/src/addr.c false
+++ b/src/addr.c 1886cd929b38e42f502f1a71f09da844891b2db451f2bda34fe62b6f99a84bd55b9b069d5e57243efc72bf7de5153514effcf676da439f738467f33e4d5d8677
@@ -0,0 +1,51 @@
+#include "addr.h"
+#include "net.h"
+#include "def.h"
+#include "util.h"
+#include "string.h"
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+extern bool         addr_null     (addr_t const *addr);
+extern bool         addr_equal    (addr_t const *a,addr_t const *b);
+
+bool addr_valid(addr_t *addr){
+  return port_valid(addr->port);
+}
+
+bool addr_from_at(addr_t *addr,char const *at){
+  char  ata[AT_BUF];
+  char *atb;
+  char *sep;
+  int   i;
+
+  strzcpy(ata,at,sizeof(ata));
+
+  sep   = strchr(ata,':');
+  if(!sep) return 0;
+  *sep  = 0;
+  atb   = sep+1;
+
+  //TODO: non retard this
+  if(!str_valid(ata,1,IPV4_LEN,IPV4_CHARSET)) return 0;
+  if(!str_valid(atb,1,PORT_LEN,PORT_CHARSET)) return 0;
+
+  if(!*ata) return 0;
+  if(!*atb) return 0;
+
+  if(!ip_u32(&addr->ip,ata)) return 0;
+  i = strtoll(atb,0,10);
+  if(!port_valid(i)) return 0;
+  addr->port = i;
+  assert(addr_valid(addr)); 
+
+  return 1;
+}
+
+void at_from_addr(char *at,size_t at_size,addr_t const *addr){
+  char ip[IPV4_BUF]; 
+  ip_str(ip,sizeof(ip),addr->ip);
+  snprintf(at,at_size,"%s:%u",ip,addr->port);
+}
+
diff -uNr a/src/addr.h b/src/addr.h
--- a/src/addr.h false
+++ b/src/addr.h 63f053f335bf8851fa97c98493e7dac4e5728476e738e0aa216e5e4e1befdfc0517cd1b93d82ab48d663d24ca6f8799b40bf092910616e731c88df1c3ce05d91
@@ -0,0 +1,26 @@
+#ifndef ADDR_H
+#define ADDR_H
+
+#include "type.h"
+#include <stdint.h>
+#include <stdbool.h>
+#include <stddef.h>
+
+bool                addr_valid    (addr_t *addr);
+inline bool         addr_null     (addr_t const *addr);
+inline bool         addr_equal    (addr_t const *a,addr_t const *b);
+
+bool                addr_from_at  (addr_t *addr,char const *at);
+void                at_from_addr  (char *at,size_t at_size,addr_t const *addr);
+
+inline bool addr_null(addr_t const *addr){
+  return addr->ip == 0;
+}
+
+inline bool addr_equal(addr_t const *a,addr_t const *b){
+  return a->ip   == b->ip &&
+         a->port == b->port;
+}
+
+#endif
+
diff -uNr a/src/addrcast.c b/src/addrcast.c
--- a/src/addrcast.c false
+++ b/src/addrcast.c 8fb6d26702f38b6dc89fed7076155c76ac1172959889fd1bb2d3d815d8c4520f90377c7b079fcb4a20b9172698ac5bb67f87d8190f62d07eebb018d6bdb0f722
@@ -0,0 +1,136 @@
+#include "pest.h"
+#include "addr.h"
+#include "peer.h"
+#include "packet.h"
+#include "crypto.h"
+#include "serial.h"
+#include "log.h"
+#include "time.h"
+#include "util.h"
+#include "state.h"
+#include <assert.h>
+
+static void ac_black_ciph(uint8_t        *ab,
+                          uint8_t const  *ar,
+                          uint8_t const  *key_serp){
+
+  serpent_cbc_ciph(key_serp,ab+AC_RED_OFF,ar,AC_RED_SIZE);
+}
+
+static void ac_black_deciph(uint8_t        *ar,
+                            uint8_t const  *ab,
+                            uint8_t const  *key_serp){
+
+  serpent_cbc_deciph(key_serp,ar,ab+AC_RED_OFF,AC_RED_SIZE);
+}
+
+static void ac_black_sign(uint8_t        *ab,
+                          uint8_t const  *key){
+
+  hmac384(key,KEY_SIGN_SIZE,ab+AC_SIGN_OFF,ab+AC_RED_OFF,AC_RED_SIZE);
+}
+
+static bool ac_black_verify(uint8_t const  *ab,
+                            uint8_t const  *key){
+
+  uint8_t sign[AC_SIGN_SIZE];
+  hmac384(key,KEY_SIGN_SIZE,sign,ab+AC_RED_OFF,AC_RED_SIZE);
+  return memcmp(sign,ab+AC_SIGN_OFF,AC_SIGN_SIZE) == 0;
+}
+
+static bool ac_send(uint8_t const *ar,peer_t *p){
+  uint8_t   ab[AC_BLACK_SIZE];
+  pkey_t   *pk;
+  uint64_t  stamp;
+
+  pk = peer_key_recent(p);
+  assert(pk);
+
+  //TODO: 276bytes dont / into 16byte
+  ac_black_ciph(ab,ar,pk->ciph_serp);
+  ac_black_sign(ab,pk->key.sub.sign);
+
+  stamp = mono_sec();
+
+  assert(sizeof(ab) == TEXT_SIZE);
+  return send_text(CMD_ADDRESSCAST,stamp,ab,sizeof(ab),0);
+  BUF_ZERO(ab);
+}
+
+static void ac_red_write(uint8_t *ar,addr_t const *addr){
+  uint32_t cmd = 0;
+
+  write_u32(ar+AC_CMD_OFF,  &cmd);
+  write_u16(ar+AC_PORT_OFF, &addr->port);
+  write_u32(ar+AC_IP_OFF,   &addr->ip);
+
+  memset(ar+AC_PAD_OFF,0x00,AC_PAD_SIZE);
+}
+
+static void ac_red_read(uint8_t const *ar,addr_t *addr){
+  read_u16(ar+AC_PORT_OFF, &addr->port);
+  read_u32(ar+AC_IP_OFF,   &addr->ip);
+}
+
+void addrcast_broadcast(addr_t const *addr){
+  uint8_t ar[AC_RED_SIZE];
+
+  //ignur until 276 thing fixed
+  return;
+
+  ac_red_write(ar,addr);
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p = peer+x;
+    if(!peer_cansend(p,0)) continue;
+    ac_send(ar,p);
+  }
+
+  BUF_ZERO(ar);
+}
+
+static bool find_key(uint8_t const *ab,peer_t **p_out,pkey_t **pk_out){
+  uint16_t peer_idx[peer_cnt];
+
+  if(!index_shuffle(peer_idx,peer_cnt)){
+    irclog_err("could not shuffle index, "
+               "address cast cannot be processed");
+    return 0;
+  }
+
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p = peer+peer_idx[x];
+    for(size_t y = 0;y < p->key_cnt;y++){
+      pkey_t *pk = p->key+y;
+      if(!ac_black_verify(ab,pk->key.sub.sign)) continue;
+      *p_out  = p;
+      *pk_out = pk;
+      return 1;
+    }
+  }
+  return 0;
+}
+
+bool addrcast_handle(uint8_t const *ab){
+  uint8_t   ar[AC_RED_SIZE];
+  peer_t   *p;
+  pkey_t   *pk;
+  addr_t    addr;
+
+  //ignur until 276 thing fixed
+  return 1;
+
+  if(!find_key(ab,&p,&pk)){
+    return 1;
+  }
+
+  //TODO: 276bytes dont / into 16byte
+  ac_black_deciph(ar,ab,pk->ciph_serp);
+  ac_red_read(ar,&addr);
+
+  if(!addr_equal(&p->addr,&addr)){
+    peer_addr_set(p,&addr,0);
+  }
+
+  return 1;
+}
+
diff -uNr a/src/banner.c b/src/banner.c
--- a/src/banner.c false
+++ b/src/banner.c ae87376d0c4a1bbcdeb2f3095845e3b76faf5cbf1360544b27443c42d0c083ddcc9c358b1d274ee5864e243b92183409f937eb6c3c77f197c29a0835a344eb9d
@@ -0,0 +1,37 @@
+#include "pest.h"
+#include "packet.h"
+#include "peer.h"
+#include "log.h"
+#include "time.h"
+#include "util.h"
+#include "state.h"
+#include <string.h>
+#include <assert.h>
+
+void banner_handle(peer_t *p,uint8_t const *text){
+  char banner[BANNER_BUF];
+
+  //TODO: vat do vith this
+  cpy_text(banner,sizeof(banner),text);
+  if(strcmp(banner,p->banner) != 0){
+    peer_banner_set(p,banner);
+  }
+}
+
+void banner_broadcast(uint64_t time){
+  uint64_t        stamp;
+  uint8_t const  *text;
+  size_t          text_len;
+
+  if(time < banner_last+baint) return;
+
+  if(banner_last != 0){
+    stamp     = mono_sec();
+    text      = (uint8_t const *)banner;
+    text_len  = strlen(banner);
+    send_text(CMD_BANNER,stamp,text,text_len,0);
+  }
+
+  banner_last = time;
+}
+
diff -uNr a/src/black.c b/src/black.c
--- a/src/black.c false
+++ b/src/black.c 1c265e1e316d5c6ec3ae36a835284f043b0adbe621e73c0a6f795f6c6c88828fcfb4dddb8d29116873e63db0e176a203f0c056cfdfd40e32c6c4b33343ac627f
@@ -0,0 +1,23 @@
+#include "packet.h"
+#include "pest.h"
+#include "crypto.h"
+#include <string.h>
+
+void black_ciph(uint8_t *b,uint8_t const *r,uint8_t const *key_serp){
+  serpent_cbc_ciph(key_serp,b+RED_OFF,r,RED_SIZE);
+}
+
+void black_deciph(uint8_t *r,uint8_t const *b,uint8_t const *key_serp){
+  serpent_cbc_deciph(key_serp,r,b+RED_OFF,RED_SIZE);
+}
+
+void black_sign(uint8_t *b,uint8_t const *key){
+  hmac384(key,KEY_SIGN_SIZE,b+SIGN_OFF,b+RED_OFF,RED_SIZE);
+}
+
+bool black_verify(uint8_t const *b,uint8_t const *key){
+  uint8_t sign[SIGN_SIZE];
+  hmac384(key,KEY_SIGN_SIZE,sign,b+RED_OFF,RED_SIZE);
+  return memcmp(sign,b+SIGN_OFF,SIGN_SIZE) == 0;
+}
+
diff -uNr a/src/chain.c b/src/chain.c
--- a/src/chain.c false
+++ b/src/chain.c d8ac0a8af55fce7f0ff03873aa6b0c97501573fc77ae0181fa686e053f6e1fb8942ada184a83257e1460b43371a252c986ca96c33be474a1889e78dbc8c3b4f1
@@ -0,0 +1,411 @@
+#include "chain.h"
+#include "crypto.h"
+#include "log.h"
+#include "io.h"
+#include "serial.h"
+#include "util.h"
+#include "string.h"
+#include "config.h"
+#include <stdio.h>
+#include <assert.h>
+
+//TODO: this and idx table shud be generalized
+
+#define CHA_LOAD                        CHAIN_CHA_LOAD
+#define CHA_LOAD_MUL                 1000
+#define CHA_POW2                        CHAIN_CHA_POW2
+#define CHA_MAX                         (1<<CHA_POW2)
+#define CHA_THRESHOLD                   (CHA_MAX*CHA_LOAD/CHA_LOAD_MUL)
+#define CHA_FILE_SIZE                   (CHA_MAX*CHA_SIZE)
+#define CHA_FILE                        "cha"
+#define CHA_TMP_FILE                    "tmp"
+#define CHA_FILE_ZEROS                  CHAIN_CHA_ZEROS
+
+//--- cha file ----------------------------------------------------------------
+#define CHA_ECNT_SIZE                   sizeof(uint64_t)
+
+#define CHA_ECNT_OFF                    ( 0                                   )
+#define CHA_TABLE_OFF                   ( CHA_ECNT_OFF    + CHA_ECNT_SIZE     )
+
+//--- cha entry ---------------------------------------------------------------
+#define CHA_HASH_SIZE                   sizeof(hash_t)
+#define CHA_PREV_SIZE                   sizeof(hash_t)  
+
+#define CHA_HASH_OFF                    ( 0                                   )
+#define CHA_PREV_OFF                    ( CHA_HASH_OFF    + CHA_HASH_SIZE     )
+
+#define CHA_SIZE                        ( CHA_PREV_OFF    + CHA_PREV_SIZE     )
+
+static void cha_path(char *buf,size_t buf_size,chain_t const *c,size_t i){
+  snprintf(buf,buf_size,"%s/"CHA_FILE"%0"STR(CHA_FILE_ZEROS)"zu",c->path,i);
+}
+
+static void cha_corrupt(char const *path,bool write){
+  irclog_err("chain file corrupt: '%s'",path);
+  if(write) disk_unsync();
+}
+
+static FILE *cha_open(char const *path,char const *mode,bool write){
+  FILE *f = file_open(path,mode);
+  if(!f){
+    if(write) disk_unsync();
+  }
+  return f;
+}
+
+static bool cha_close(FILE *f,char const *path,bool write){
+  if(!file_close(f)){
+    if(write) disk_unsync();
+    return 0;
+  }
+  if(write){
+    disk_written(path);
+  }else{
+    disk_read(path);
+  }
+  return 1;
+}
+
+static bool cha_seek_entry(FILE *f,size_t index,bool write){
+  if(!file_seek(f,CHA_TABLE_OFF+index*CHA_SIZE,SEEK_SET)){
+    file_close(f);
+    if(write) disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool cha_read_ecnt(FILE *f,uint64_t *ecnt,bool write){
+  if(!file_read(f,ecnt,CHA_ECNT_SIZE)){
+    file_close(f);
+    if(write) disk_unsync();
+    return 0;
+  }
+  *ecnt = host64le(*ecnt);
+  return 1;
+}
+
+static bool cha_write_ecnt(FILE *f,uint64_t ecnt){
+  ecnt = host64le(ecnt);
+  if(!file_write(f,&ecnt,CHA_ECNT_SIZE)){
+    file_close(f);
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool cha_read_hash(FILE *f,hash_t hash,bool write){
+  if(hash){
+    if(!file_read(f,hash,CHA_HASH_SIZE)){
+      file_close(f);
+      if(write) disk_unsync();
+      return 0;
+    }
+  }else{
+    if(!file_seek(f,CHA_HASH_SIZE,SEEK_CUR)){
+      file_close(f);
+      if(write) disk_unsync();
+      return 0;
+    }
+  }
+  return 1;
+}
+
+static bool cha_write_hash(FILE *f,hash_t const hash){
+  if(!file_write(f,hash,CHA_HASH_SIZE)){
+    file_close(f);
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool cha_init(chain_t *c,size_t file_idx){
+  char      path[PATH_BUF];
+  FILE     *f;
+  hash_t    hash;
+
+  assert(CHA_THRESHOLD <= CHA_MAX);
+
+  cha_path(path,sizeof(path),c,file_idx);
+  f = cha_open(path,"wb+",1);
+  if(!f) return 0;
+
+  if(!cha_write_ecnt(f,0)) return 0;
+
+  hash_zero(hash);
+  for(size_t x = 0;x < CHA_MAX;x++){
+    if(!cha_write_hash(f,hash)) return 0;
+    if(!cha_write_hash(f,hash)) return 0;
+  }
+
+  if(!cha_close(f,path,1)) return 0;
+  return 1;
+}
+
+static size_t cha_hash_low32(hash_t const hash){
+  uint32_t lo32;
+  memcpy(&lo32,hash+HASH_SIZE-sizeof(lo32),sizeof(lo32));
+  return host32le(lo32);
+}
+
+static bool cha_ins(chain_t *c,hash_t const hash,hash_t const prev){
+  char      path[PATH_BUF];
+  FILE     *f;
+  uint64_t  ecnt;
+  size_t    i_start;
+  size_t    i_end;
+
+  if(c->cha_cnt == 0 || c->cha_ecnt+1 > CHA_THRESHOLD){
+    if(!cha_init(c,c->cha_cnt)) return 0;
+    c->cha_cnt++;
+    c->cha_ecnt = 0;
+  }
+
+  cha_path(path,sizeof(path),c,c->cha_cnt-1);
+  f = cha_open(path,"rb+",1);
+  if(!f) return 0;
+
+  //TODO: chek filesize
+
+  ecnt = c->cha_ecnt+1;
+  if(!cha_write_ecnt(f,ecnt)) return 0;
+
+  i_start  = cha_hash_low32(hash)  & CHA_MAX-1;
+  i_end    = i_start-1             & CHA_MAX-1;
+  for(size_t i = i_start;i != i_end;i = i+1 & CHA_MAX-1){
+    hash_t i_hash;
+
+    if(!cha_seek_entry  (f,i,1))        return 0;
+    if(!cha_read_hash   (f,i_hash,1))   return 0;
+
+    if(!hash_null(i_hash)) continue;
+
+    if(!cha_seek_entry  (f,i,1))        return 0;
+    if(!cha_write_hash  (f,hash))       return 0;
+    if(!cha_write_hash  (f,prev))       return 0;
+    if(!cha_close       (f,path,1))     return 0;
+
+    c->cha_ecnt = ecnt;
+    return 1;
+  }
+
+  cha_corrupt(path,1);
+  return 0;
+}
+
+static bool cha_cnt(chain_t *c,size_t *cha_cnt_out){
+  size_t cha_cnt = 0;
+  while(1){
+    char path[PATH_BUF];
+    cha_path(path,sizeof(path),c,cha_cnt);
+    if(!file_exists(path)) break;
+    cha_cnt++;
+  }
+  *cha_cnt_out = cha_cnt;
+  return 1;
+}
+
+static bool cha_ecnt(chain_t *c,size_t *ecnt_out){
+  char      path[PATH_BUF];
+  FILE     *f;
+  uint64_t  ecnt;
+
+  cha_path(path,sizeof(path),c,c->cha_cnt-1);
+  if(c->cha_cnt == 0 || !file_exists(path)){
+    *ecnt_out = 0;
+    return 1;
+  }
+
+  f = cha_open(path,"rb+",0);
+  if(!f) return 0;
+
+  if(!cha_read_ecnt(f,&ecnt,0)) return 0;
+
+  if(ecnt > CHA_MAX){
+    cha_corrupt(path,0);
+    file_close(f);
+    return 0;
+  }
+
+  cha_close(f,path,0);
+  *ecnt_out = ecnt;
+  return 1;
+}
+
+void chain_init(chain_t *c){
+  assert(CHA_THRESHOLD <= CHA_MAX);
+  assert(CHA_HASH_SIZE == CHA_PREV_SIZE);
+
+  *c->path    = 0;
+  c->cha_cnt  = 0;
+  c->cha_ecnt = 0;
+}
+
+void chain_path(chain_t *c,char const *path){
+  strzcpy(c->path,path,sizeof(c->path));
+}
+
+bool chain_load(chain_t *c){
+  if(!mkdir_p(c->path)) return 0;
+
+  if(!cha_cnt (c,&c->cha_cnt )) return 0;
+  if(!cha_ecnt(c,&c->cha_ecnt)) return 0;
+
+#ifdef LOG_CHAIN
+  log_out("chain loaded: '%s'",c->path);
+#endif
+
+  return 1;
+}
+
+bool chain_push(chain_t *c,hash_t const hash,hash_t const prev){
+  if(!cha_ins(c,hash,prev)) return 0;
+
+#ifdef LOG_CHAIN
+  char hash_hex[HASH_HEX_BUF];
+  hash_str_log(hash_hex,sizeof(hash_hex),hash);
+  log_out("%s pushed to chain: '%s'",hash_hex,c->path);
+#endif
+
+  return 1;
+}
+
+static unsigned cha_file_lookup(chain_t      *c,
+                                size_t        file_idx,
+                                hash_t const  hash,
+                                hash_t        prev){
+  char      path[PATH_BUF];
+  FILE     *f;
+  size_t    i_start;
+  size_t    i_end;
+
+  cha_path(path,sizeof(path),c,file_idx);
+  f = cha_open(path,"r",0);
+  if(!f) return LOOKUP_IO;
+
+  i_start  = cha_hash_low32(hash)  & CHA_MAX-1;
+  i_end    = i_start-1             & CHA_MAX-1;
+  for(size_t i = i_start;i != i_end;i = i+1 & CHA_MAX-1){
+    hash_t    i_hash;
+
+    if(!cha_seek_entry  (f,i,0))        return LOOKUP_IO;
+    if(!cha_read_hash   (f,i_hash,0))   return LOOKUP_IO;
+
+    if(hash_null(i_hash))               break;
+    if(!hash_equal(i_hash,hash))        continue;
+
+    if(!cha_read_hash   (f,prev,0))     return LOOKUP_IO;
+
+    cha_close(f,path,0);
+    return LOOKUP_FOUND;
+  }
+
+  cha_close(f,path,0);
+  return LOOKUP_NOTFOUND;
+}
+
+unsigned chain_lookup(chain_t *c,hash_t const hash,hash_t prev){
+  int ret = LOOKUP_NOTFOUND;
+
+  if(hash_null(hash)) return LOOKUP_NOTFOUND;
+
+  for(size_t x = c->cha_cnt-1;x < (size_t)-1;x--){
+    switch(cha_file_lookup(c,x,hash,prev)){
+    case LOOKUP_FOUND:
+      ret = LOOKUP_FOUND;
+      goto ret;
+
+    case LOOKUP_NOTFOUND:
+      break;
+
+    case LOOKUP_IO:
+      irclog_err("failed to look up hash in chain: '%s'",c->path);
+      return LOOKUP_IO;
+    }
+  }
+
+ret:
+#ifdef LOG_CHAIN
+  ;char hash_hex[HASH_HEX_BUF];
+  hash_str_log(hash_hex,sizeof(hash_hex),hash);
+  log_out("%s %sfound in chain: '%s'",
+          hash_hex,ret == LOOKUP_FOUND ? "" : "not ",c->path);
+#endif
+  return ret;
+}
+
+bool chain_resolve(chain_t *c,hash_t const head,hash_t tail){
+  bool      ret;
+  chain_t   t;
+  hash_t    hash;
+  hash_t    prev;
+  char     *path;
+  char     *path_e;
+
+  ret = 1;
+
+  chain_init(&t);
+  path    = t.path;
+  path_e  = t.path+sizeof(t.path);
+  path    = strpcpy(path,c->path,         path_e);
+  path    = strpcpy(path,"/"CHA_TMP_FILE, path_e);
+
+  if(!mkdir_p(t.path)){
+    ret = 0;
+    goto ret;
+  }
+
+  hash_copy(hash,head);
+
+  while(1){
+    switch(chain_lookup(c,hash,prev)){
+    case LOOKUP_FOUND:
+      if(!chain_push(&t,hash,prev)){
+        ret = 0;
+        goto ret;
+      }
+      hash_copy(hash,prev);
+      break;
+
+    case LOOKUP_NOTFOUND:
+      goto break_while;
+
+    case LOOKUP_IO:
+      ret = 0;
+      goto ret;
+    }
+  }
+break_while:
+
+  for(size_t x = 0;x < c->cha_cnt;x++){
+    char path_del[PATH_BUF];
+    cha_path(path_del,sizeof(path_del),c,x);
+    if(!file_delete(path_del)){
+      ret = 0;
+      goto ret;
+    }
+  }
+
+  for(size_t x = 0;x < t.cha_cnt;x++){
+    char path_src[PATH_BUF];
+    char path_dst[PATH_BUF];
+    cha_path(path_src,sizeof(path_src),&t,x);
+    cha_path(path_dst,sizeof(path_dst),c,x);
+    if(!file_rename(path_src,path_dst)){
+      ret = 0;
+      goto ret;
+    }
+  }
+
+  c->cha_cnt  = t.cha_cnt;
+  c->cha_ecnt = t.cha_ecnt;
+
+  hash_copy(tail,hash);
+
+ret:
+  rm_rf(t.path);
+  return ret;
+}
+
