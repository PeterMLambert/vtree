+//TMP
+#define HEX_DELIM                       4
+#define HEX_GROUPS                      4
+void print_hex(uint8_t const *buf,size_t len){
+  size_t columns  = HEX_DELIM*HEX_GROUPS;
+  size_t y        = 0;
+  size_t z        = 0;
+  size_t w        = columns*3+columns/HEX_DELIM+6;
+
+  for(size_t x = 0;x < len;x++){
+    uint8_t c = buf[x];
+    fprintf(stderr,"%02X ",c);
+    z += 3;
+
+    if(x%HEX_DELIM == HEX_DELIM-1){
+      fputc(' ',stderr);
+      fputc(' ',stderr);
+      z += 2;
+    }
+
+    if(x%columns == columns-1 || x == len-1){
+      for(size_t u = z;u < w;u++){
+        fputc(' ',stderr);
+      }
+
+      for(;y <= x;y++){
+        unsigned char c   = buf[y];
+        bool          sym = c < 0x20 || c > 0x7E;
+        if(sym) fputc('.',stderr);
+        else    fputc(c,stderr);
+      }
+
+      fputc('\n',stderr);
+      z = 0;
+      y = x+1;
+    }
+  }
+  fflush(stderr);
+}
+
+bool port_valid(int64_t port){
+  return port >= PORT_MIN && port <= PORT_MAX;
+}
+
+bool check_port(int64_t port,char const *proto){
+  if(!port_valid(port)){
+    irclog_err("invalid %s port: %d (valid range: %d-%d)",
+               proto,port,PORT_MIN,PORT_MAX);
+    return 0;
+  }
+  return 1;
+}
+
+bool check_irc_user(char const *user){
+  if(!str_valid(user,1,IRC_USER_LEN,HANDLE_CHARSET)){
+    log_err("invalid IRC username: '%s'",user);
+    return 0;
+  }
+  return 1;
+}
+
+bool handle_valid(char const *handle){
+  return str_valid(handle,1,HANDLE_LEN,HANDLE_CHARSET);
+}
+
+void fmt_peerhost(char *buf,size_t buf_size,char const *handle){
+  snprintf(buf,buf_size,"%s!%s@"IRC_PEERHOST,handle,handle);
+}
+
+void fmt_handle_ext(char         *buf,
+                    size_t        buf_size,
+                    char const   *speaker,
+                    handle_t     *parens,
+                    size_t        parens_cnt){
+
+  char *b = buf;
+  char *e = buf+buf_size;
+
+  b = strpzcpy(b,speaker,e,SPEAKER_SIZE);
+  b = strpcpy(b,"[",e);
+  for(size_t x = 0;x < parens_cnt;x++){
+    b = strpcpy(b,parens[x],e);
+    b = strpcpy(b,x+1 < parens_cnt ? "|" : "]",e);
+  }
+}
+
+void cpy_speaker(char *buf,size_t buf_size,uint8_t const *m){
+  strzzcpy(buf,(char const *)(m+SPEAKER_OFF),buf_size,SPEAKER_SIZE);
+}
+
+void cpy_text(char *buf,size_t buf_size,uint8_t const *m){
+  strzzcpy(buf,(char const *)(m+TEXT_OFF),buf_size,TEXT_SIZE);
+}
+
+bool index_shuffle(uint16_t *i,size_t n){
+  uint16_t rngolade[n];
+
+  assert(n <= 65536);
+  if(!rng_read(rngolade,sizeof(*rngolade)*n)) return 0;
+
+  for(size_t x = 0;x < n;x++){
+    i[x] = x;
+  }
+
+  for(size_t x = 0;x < n;x++){
+    uint16_t y;
+    uint16_t t;
+
+    y     = rngolade[x]%n;
+    t     = i[x];
+    i[x]  = i[y];
+    i[y]  = t;
+  }
+
+  return 1;
+}
+
