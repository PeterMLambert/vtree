diff -uNr a/src/getdata.c b/src/getdata.c
--- a/src/getdata.c false
+++ b/src/getdata.c 6f4eff43a5686a1625ab6534eccc57552e177ba3584698baf0351d9389b84c2adfa7ed36c8cc42cc40c033fac2666cedf899e0d2a360c0cff6febdd93cbcf047
@@ -0,0 +1,142 @@
+#include "pest.h"
+#include "peer.h"
+#include "packet.h"
+#include "chain.h"
+#include "crypto.h"
+#include "log.h"
+#include "time.h"
+#include "util.h"
+#include "config.h"
+#include "state.h"
+
+static void getdata_attempt(getdata_t *g,peer_t *chan){
+  send_text(CMD_GETDATA,mono_sec(),g->hash,HASH_SIZE,chan);
+  g->ntime = mono_nsec();
+  g->attempt++;
+}
+
+static void del(getdata_t *g){
+  ARR_DEL(gd,gd_cnt,g);
+  gd_cnt--;
+  memset_ffs(gd+gd_cnt,0x00,sizeof(*gd));
+}
+
+bool getdata_push(peer_t *p,peer_t *chan,hash_t const hash){
+  getdata_t *g;
+
+  assert(p || !chan);
+  getdata_del(hash,0);
+
+  if(gd_cnt >= GETDATA_MAX){
+    irclog_err("getdata buffer full");
+    return 0;
+  }
+
+  g           = &gd[gd_cnt++];
+  g->peer_id  = p    ? p->id    : PEER_ID_INVALID;
+  g->chan_id  = chan ? chan->id : PEER_ID_INVALID;
+  g->attempt  = 0;
+  hash_copy(g->hash,hash);
+
+  getdata_attempt(g,chan);
+
+  return 1;
+}
+
+bool getdata_push_cond(peer_t *p,peer_t *chan,hash_t const hash){
+  if(hearsay_lookup(hash)) return 0;
+  if(pending_lookup(hash)) return 0;
+  if(getdata_lookup(hash)) return 0;
+  return getdata_push(p,chan,hash);
+}
+
+static getdata_t *gd_lookup(hash_t const hash){
+  for(size_t x = 0;x < gd_cnt;x++){
+    getdata_t *g = gd+x;
+    if(hash_equal(hash,g->hash)) return g;
+  }
+  return 0;
+}
+
+bool getdata_lookup(hash_t const hash){
+  return gd_lookup(hash);
+}
+
+bool getdata_del(hash_t const hash,peer_t **peer){
+  getdata_t *g;
+
+  g = gd_lookup(hash);
+  if(!g) return 0;
+  if(peer){
+    *peer = peer_lookup_id(g->peer_id);
+  }
+  del(g);
+
+  return 1;
+}
+
+void getdata_del_peer(peer_t *p){
+  for(size_t x = 0;x < gd_cnt;x++){
+    getdata_t *g = gd+x;
+    if(g->peer_id != p->id) continue;
+    del(g);
+    x--;
+  }
+}
+
+void getdata_process(uint64_t ntime){
+  for(size_t x = 0;x < gd_cnt;x++){
+    getdata_t *g = gd+x;
+
+    if(ntime < g->ntime+(gdtime*NSEC_MSEC)){
+      continue;
+    }
+
+    if(g->attempt < (size_t)gdatt){
+      peer_t *chan = peer_lookup_id(g->chan_id);
+      getdata_attempt(g,chan);
+    }else{
+      del(g);
+      x--;
+    }
+  }
+}
+
+//TODO: make les stupid
+void getdata_retry(uint64_t time){
+  if(time < gd_retry_last+gdint) return;
+  gd_retry_last = time;
+
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p = peer+x;
+    //index 0 is considered "validest" of tails
+    for(size_t y = 1;y < p->btail.cnt;y++){
+      uint8_t const *h = p->btail.hash[y];
+      if(hash_null(h)) continue;
+      getdata_push_cond(p,0,h);
+    }
+    for(size_t y = 1;y < p->dtail.cnt;y++){
+      uint8_t const *h = p->dtail.hash[y];
+      if(hash_null(h)) continue;
+      getdata_push_cond(p,p,h);
+    }
+  }
+}
+
+void getdata_handle(peer_t *p,hash_t hash){
+  uint8_t   r[RED_SIZE];
+  uint8_t  *m = r+MESSAGE_OFF;
+
+  //TODO: only process if cpu avail
+
+  if(mess_lookup(&mess,hash,m) == LOOKUP_FOUND){
+    send_message(CMD_BROADCAST,r,hash,p,0);
+    return;
+  }
+
+  if(mess_lookup(&p->mess,hash,m) == LOOKUP_FOUND){
+    send_message(CMD_DIRECT,r,hash,p,0);
+    return;
+  }
+}
+
diff -uNr a/src/hash.c b/src/hash.c
--- a/src/hash.c false
+++ b/src/hash.c 634d73851517012ef66ee69d2ef2407e525698a4d71d09c3e9c90dd73fb7c24dada2a566d4c297ac8eb4c7c183fb22cfd1e025b7aabb3fd479ce731a567e7868
@@ -0,0 +1,35 @@
+#include "crypto.h"
+#include "util.h"
+#include <stdio.h>
+
+#define HASH_LOG_SIZE         LOG_HASH_BYTES
+
+extern void         hash_data     (hash_t h,void const *data,size_t size);
+extern void         hash_zero     (hash_t h);
+extern void         hash_copy     (hash_t dst,hash_t const src);
+extern bool         hash_equal    (hash_t const a,hash_t const b);
+extern bool         hash_null     (hash_t const h);
+
+static void fmt_hex_rev(char           *buf,
+                        size_t          buf_size,
+                        uint8_t const  *data,
+                        size_t          data_size){
+
+  for(size_t x = data_size-1;x < (size_t)-1;x--){
+    size_t n;
+    n         = snprintf(buf,buf_size,"%02X",data[x]);
+    buf      += n;
+    buf_size -= n;
+    if(buf_size == 0) return;
+  }
+}
+
+void hash_str(char *buf,size_t buf_size,hash_t const hash){
+  fmt_hex_rev(buf,buf_size,hash,HASH_SIZE);
+}
+
+void hash_str_log(char *buf,size_t buf_size,hash_t const hash){
+  assert(HASH_LOG_SIZE <= HASH_SIZE);
+  fmt_hex_rev(buf,buf_size,hash,HASH_LOG_SIZE);
+}
+
diff -uNr a/src/hearsay.c b/src/hearsay.c
--- a/src/hearsay.c false
+++ b/src/hearsay.c 1dcb41cfe46232131fce0ce8febf5133391b4adffce845551fe3b805b2b152438f8de7a9b112e189101aeda2271bbf40e1c508560c745906c64cf8c06ffdd014
@@ -0,0 +1,153 @@
+#include "pest.h"
+#include "peer.h"
+#include "packet.h"
+#include "crypto.h"
+#include "time.h"
+#include "log.h"
+#include "util.h"
+#include "string.h"
+#include "state.h"
+#include <stddef.h>
+#include <stdlib.h>
+#include <string.h>
+#include <stdio.h>
+#include <assert.h>
+
+void *hearsay_lookup(hash_t const hash){
+  for(size_t x = 0;x < hs_cnt;x++){
+    hearsay_t *h = hs+x;
+    if(hash_equal(h->hash,hash)) return h;
+  }
+  return 0;
+}
+
+void hearsay_peer(void *_h,peer_t *p,uint8_t bounces){
+  hearsay_t *h = _h;
+  if(!hearsay_peered(h,p)){
+    if(h->peer_cnt < PEER_MAX){
+      h->peer[h->peer_cnt] = p->id;
+    }
+    h->peer_cnt++;
+  }
+
+  if(bounces < h->bounces){
+    h->bounces = bounces;
+  }
+}
+
+bool hearsay_peered(void *_h,peer_t *p){
+  hearsay_t *h = _h;
+  for(size_t x = 0;x < h->peer_cnt;x++){
+    if(h->peer[x] == p->id) return 1;
+  }
+  return 0;
+}
+
+void *hearsay_push(hash_t const    hash,
+                        uint8_t const  *red,
+                        peer_t         *speaker,
+                        peer_t         *p,
+                        uint8_t         bounces){
+  hearsay_t *h;
+
+  if(hs_cnt >= HEARSAY_MAX){
+    irclog_err("hearsay buffer full");
+    return 0;
+  }
+
+  h = &hs[hs_cnt++];
+  hash_copy(h->hash,hash);
+  memcpy(h->red,red,sizeof(h->red));
+  h->peer[0]  = p->id;
+  h->peer_cnt = 1;
+  h->speaker  = speaker ? speaker->id : PEER_ID_INVALID;
+  h->ntime    = mono_nsec();
+  h->bounces  = bounces;
+
+  return h;
+}
+
+void hearsay_del(void *_h){
+  hearsay_t *h = _h;
+  ARR_DEL(hs,hs_cnt,h);
+  hs_cnt--;
+  memset_ffs(hs+hs_cnt,0x00,sizeof(*hs));
+}
+
+void hearsay_del_peer(peer_t *p){
+  for(size_t x = 0;x < hs_cnt;x++){
+    hearsay_t *h = hs+x;
+
+    if(h->speaker == p->id){
+      h->speaker = PEER_ID_INVALID;
+    }
+
+    for(size_t y = 0;y < h->peer_cnt;y++){
+      peerid_t *q = h->peer+y;
+      if(*q != p->id) continue;
+
+      ARR_DEL(h->peer,h->peer_cnt,q);
+      h->peer_cnt--;
+      y--;
+
+      if(h->peer_cnt == 0){
+        hearsay_del(h);
+        x--;
+        break;
+      }
+    }
+  }
+}
+
+static void fmt_hearsay(char       *buf,
+                        size_t      buf_size,
+                        char const *speaker,
+                        hearsay_t  *h){
+
+  if(h->peer_cnt <= HEARSAY_PARENS_MAX){
+    handle_t parens[HEARSAY_PARENS_MAX];
+    for(size_t x = 0;x < h->peer_cnt;x++){
+      peer_t *p = peer_lookup_id(h->peer[x]);
+      assert(p);
+      strzcpy(parens[x],p->handle[0],sizeof(parens[x]));
+    }
+    fmt_handle_ext(buf,buf_size,speaker,parens,h->peer_cnt);
+  }else{
+    char num[HANDLE_BUF];
+    snprintf(num,sizeof(num),"%zu",h->peer_cnt);
+    fmt_handle_ext(buf,buf_size,speaker,&num,1);
+  }
+}
+
+static void hearsay_message(hearsay_t *h){
+  char        speaker[HANDLE_EXT_BUF];
+  uint8_t    *m;
+  char const *m_speaker;
+  peer_t     *p;
+
+  m         = h->red+MESSAGE_OFF;
+  m_speaker = (char const *)(m+SPEAKER_OFF);
+
+  fmt_hearsay(speaker,sizeof(speaker),m_speaker,h);
+  if(p = peer_lookup_id(h->speaker)){
+    //in-wot hearsay
+    message_handle(m,h->hash,speaker,p,0,0,1,1);
+  }else{
+    //simple hearsay
+    message_handle_simp(m,h->hash,speaker,0);
+  }
+  red_rebroadcast(h->red,h->hash,h->bounces);
+}
+
+void hearsay_process(uint64_t ntime){
+  for(size_t x = 0;x < hs_cnt;x++){
+    hearsay_t *h = hs+x;
+    if(ntime < h->ntime+(hstime*NSEC_MSEC)){
+      continue;
+    }
+    hearsay_message(h);
+    hearsay_del(h);
+    x--;
+  }
+}
+
diff -uNr a/src/hmac.c b/src/hmac.c
--- a/src/hmac.c false
+++ b/src/hmac.c ae4aaf9b4f8f0cb090f97b09437beda1f8920fdb2fd9b41482145962f4bb1364c3674ee7f3d1d40a38600554fc6dc17533f0bcdc8aba3f5ae6c92d3c8eb47b81
@@ -0,0 +1,17 @@
+#include "crypto.h"
+#include "otherpplgode/hmac.h"
+#include <string.h>
+
+void hmac384(uint8_t const *key,
+             size_t         key_size,
+             uint8_t       *mac,
+             uint8_t const *msg,
+             size_t         msg_size){
+
+  hmac_sha384_ctx ctx;
+  hmac_sha384_init(&ctx,key,key_size);
+  hmac_sha384_update(&ctx,msg,msg_size);
+  hmac_sha384_final(&ctx,mac,HMAC384_SIZE);
+  VAR_ZERO(ctx);
+}
+
diff -uNr a/src/ht.c b/src/ht.c
--- a/src/ht.c false
+++ b/src/ht.c c06466da05d832e6924802547162c73052e4e6e3e5f4d8bc14cd8691dafc227df5fca093c1bdab933d5776979ef469950cbfe29d469f43410ed53c0bfb9a261d
@@ -0,0 +1,119 @@
+#include "chain.h"
+#include "crypto.h"
+#include "log.h"
+#include "io.h"
+#include "util.h"
+#include "string.h"
+
+void ht_init(ht_t *ht){
+  *ht->path = 0;
+  ht->cnt   = 1;
+  ht->last  = -1;
+  hash_zero(ht->hash[0]);
+}
+
+void ht_path(ht_t *ht,char const *path){
+  strzcpy(ht->path,path,sizeof(ht->path));
+}
+
+bool ht_store(ht_t *ht){
+  if(!hash_store(ht->path,(hash_t const *)ht->hash,ht->cnt)){
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+bool ht_load(ht_t *ht){
+  ht->last = -1;
+  if(file_exists(ht->path)){
+    return hash_load(ht->path,ht->hash,&ht->cnt,HEADTAIL_MAX);
+  }else{
+    ht->cnt = 1;
+    hash_zero(ht->hash[0]);
+    return hash_store(ht->path,(hash_t const *)ht->hash,ht->cnt);
+  }
+}
+
+hash_t *ht_lookup(ht_t *ht,hash_t const hash){
+  for(size_t x = 0;x < ht->cnt;x++){
+    hash_t *h = ht->hash+x;
+    if(hash_equal(*h,hash)) return h;
+  }
+  return 0;
+}
+
+hash_t *ht_last(ht_t *ht){
+  if(ht->last == (size_t)-1) return 0;
+  return &ht->hash[ht->last];
+}
+
+bool ht_full(ht_t *ht){
+  return ht->cnt >= HEADTAIL_MAX;
+}
+
+hash_t *ht_add(ht_t *ht,hash_t const hash){
+  hash_t *h;
+
+  if(ht->cnt >= HEADTAIL_MAX){
+    irclog_err("max heads/tails reached: %zu",HEADTAIL_MAX); 
+    return 0;
+  }
+
+  h         = &ht->hash[ht->cnt];
+  ht->last  = ht->cnt;
+  ht->cnt++;
+  hash_copy(*h,hash);
+  ht_store(ht);
+  return h;
+}
+
+void ht_del(ht_t *ht,hash_t *h){
+  size_t idx;
+
+  idx = ARR_INDEXOF(ht->hash,h);
+  ARR_DEL(ht->hash,ht->cnt,h);
+  ht->cnt--;
+  assert(ht->cnt > 0);
+
+  if(ht->last == idx){
+    //dum but alternativ is store stamps for each shit 76kb of mem
+    ht->last = -1;
+  }else if(ht->last > idx){
+    ht->last--;
+  }
+
+  ht_store(ht);
+}
+
+void ht_set(ht_t *ht,hash_t *h,hash_t const hash){
+  ht->last = ARR_INDEXOF(ht->hash,h);
+  hash_copy(*h,hash);
+  ht_store(ht);
+}
+
+void ht_clear(ht_t *ht,hash_t const hash){
+  ht->cnt   = 1;
+  ht->last  = 0;
+  hash_copy(ht->hash[0],hash);
+  ht_store(ht);
+}
+
+bool ht_null(ht_t *h,ht_t *t){
+  return h->cnt == 1 &&
+         t->cnt == 1 &&
+         hash_null(h->hash[0]) &&
+         hash_null(t->hash[0]);
+}
+
+size_t ht_forks(ht_t *h,ht_t *t){
+  assert(h->cnt >= t->cnt);
+  return h->cnt-t->cnt;
+}
+
+size_t ht_breaks(ht_t *h,ht_t *t){
+  (void)h;
+  assert(t->cnt >= 1);
+  return t->cnt-1;
+}
+
diff -uNr a/src/idx.c b/src/idx.c
--- a/src/idx.c false
+++ b/src/idx.c ac81b2f48960624fd11a54ab1b47b49007773e942b7defbecdf9bf4422982628de1ff96fcfabb9603ac8841798177cfcea25389f545151debebdf7c6df827175
@@ -0,0 +1,294 @@
+#include "chain.h"
+#include "crypto.h"
+#include "io.h"
+#include "serial.h"
+#include "log.h"
+#include "util.h"
+
+#define IDX_LOAD                        MESS_IDX_LOAD
+#define IDX_LOAD_MUL                 1000
+#define IDX_POW2                        MESS_IDX_POW2
+#define IDX_MAX                         (1<<IDX_POW2)
+#define IDX_THRESHOLD                   (IDX_MAX*IDX_LOAD/IDX_LOAD_MUL)
+#define IDX_FILE_SIZE                   (IDX_MAX*IDX_SIZE)
+#define IDX_FILE                        "idx"
+#define IDX_FILE_ZEROS                  MESS_IDX_ZEROS
+#define IDX_INDEX_EMPTY                 ((uint64_t)-1)
+
+//--- idx file ----------------------------------------------------------------
+#define IDX_ECNT_SIZE                   sizeof(uint64_t)
+
+#define IDX_ECNT_OFF                    ( 0                                   )
+#define IDX_TABLE_OFF                   ( IDX_ECNT_OFF    + IDX_ECNT_SIZE     )
+
+//--- idx entry ---------------------------------------------------------------
+#define IDX_INDEX_SIZE                  sizeof(uint64_t)  
+#define IDX_HASH_SIZE                   sizeof(hash_t)
+
+#define IDX_INDEX_OFF                   ( 0                                   )
+#define IDX_HASH_OFF                    ( IDX_INDEX_OFF   + IDX_INDEX_SIZE    )
+
+#define IDX_SIZE                        ( IDX_HASH_OFF    + IDX_HASH_SIZE     )
+
+static void idx_path(char *buf,size_t buf_size,mess_t const *c,size_t i){
+  snprintf(buf,buf_size,"%s/"IDX_FILE"%0"STR(IDX_FILE_ZEROS)"zu",c->path,i);
+}
+
+static void idx_corrupt(char const *path,bool write){
+  irclog_err("mess index file corrupt: '%s'",path);
+  if(write) disk_unsync();
+}
+
+static FILE *idx_open(char const *path,char const *mode,bool write){
+  FILE *f = file_open(path,mode);
+  if(!f){
+    if(write) disk_unsync();
+  }
+  return f;
+}
+
+static bool idx_close(FILE *f,char const *path,bool write){
+  if(!file_close(f)){
+    if(write) disk_unsync();
+    return 0;
+  }
+  if(write){
+    disk_written(path);
+  }else{
+    disk_read(path);
+  }
+  return 1;
+}
+
+static bool idx_seek_entry(FILE *f,size_t index,bool write){
+  if(!file_seek(f,IDX_TABLE_OFF+index*IDX_SIZE,SEEK_SET)){
+    file_close(f);
+    if(write) disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool idx_read_ecnt(FILE *f,uint64_t *ecnt,bool write){
+  if(!file_read(f,ecnt,IDX_ECNT_SIZE)){
+    file_close(f);
+    if(write) disk_unsync();
+    return 0;
+  }
+  *ecnt = host64le(*ecnt);
+  return 1;
+}
+
+static bool idx_write_ecnt(FILE *f,uint64_t ecnt){
+  ecnt = host64le(ecnt);
+  if(!file_write(f,&ecnt,IDX_ECNT_SIZE)){
+    file_close(f);
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool idx_read_index(FILE *f,uint64_t *index,bool write){
+  if(!file_read(f,index,IDX_INDEX_SIZE)){
+    file_close(f);
+    if(write) disk_unsync();
+    return 0;
+  }
+  *index = host64le(*index);
+  return 1;
+}
+
+static bool idx_write_index(FILE *f,uint64_t index){
+  index = host64le(index);
+  if(!file_write(f,&index,IDX_INDEX_SIZE)){
+    file_close(f);
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool idx_read_hash(FILE *f,hash_t hash,bool write){
+  if(!file_read(f,hash,IDX_HASH_SIZE)){
+    file_close(f);
+    if(write) disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool idx_write_hash(FILE *f,hash_t const hash){
+  if(!file_write(f,hash,IDX_HASH_SIZE)){
+    file_close(f);
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool idx_init(mess_t *c,size_t file_idx){
+  char      path[PATH_BUF];
+  FILE     *f;
+  hash_t    hash;
+
+  assert(IDX_THRESHOLD <= IDX_MAX);
+
+  idx_path(path,sizeof(path),c,file_idx);
+  f = idx_open(path,"wb+",1);
+  if(!f) return 0;
+
+  if(!idx_write_ecnt(f,0)) return 0;
+
+  hash_zero(hash);
+  for(size_t x = 0;x < IDX_MAX;x++){
+    if(!idx_write_index (f,IDX_INDEX_EMPTY)) return 0;
+    if(!idx_write_hash  (f,hash           )) return 0;
+  }
+
+  if(!idx_close(f,path,1)) return 0;
+  return 1;
+}
+
+static size_t idx_hash_low32(hash_t const hash){
+  uint32_t lo32;
+  memcpy(&lo32,hash+HASH_SIZE-sizeof(lo32),sizeof(lo32));
+  return host32le(lo32);
+}
+
+bool idx_ins(mess_t *c,hash_t const hash,uint64_t index){
+  char      path[PATH_BUF];
+  FILE     *f;
+  uint64_t  ecnt;
+  size_t    i_start;
+  size_t    i_end;
+
+  if(c->idx_cnt == 0 || c->idx_ecnt+1 > IDX_THRESHOLD){
+    if(!idx_init(c,c->idx_cnt)) return 0;
+    c->idx_cnt++;
+    c->idx_ecnt = 0;
+  }
+
+  idx_path(path,sizeof(path),c,c->idx_cnt-1);
+  f = idx_open(path,"rb+",1);
+  if(!f) return 0;
+
+  //TODO: chek filesize
+
+  ecnt = c->idx_ecnt+1;
+  if(!idx_write_ecnt(f,ecnt)) return 0;
+
+  i_start  = idx_hash_low32(hash)  & IDX_MAX-1;
+  i_end    = i_start-1             & IDX_MAX-1;
+  for(size_t i = i_start;i != i_end;i = i+1 & IDX_MAX-1){
+    uint64_t i_index;
+
+    if(!idx_seek_entry  (f,i,1))        return 0;
+    if(!idx_read_index  (f,&i_index,1)) return 0;
+
+    if(i_index != IDX_INDEX_EMPTY) continue;
+
+    if(!idx_seek_entry  (f,i,1))        return 0;
+    if(!idx_write_index (f,index))      return 0;
+    if(!idx_write_hash  (f,hash))       return 0;
+    if(!idx_close       (f,path,1))     return 0;
+
+    c->idx_ecnt = ecnt;
+    return 1;
+  }
+
+  idx_corrupt(path,1);
+  return 0;
+}
+
+bool idx_cnt(mess_t *c,size_t *idx_cnt_out){
+  size_t idx_cnt = 0;
+  while(1){
+    char path[PATH_BUF];
+    idx_path(path,sizeof(path),c,idx_cnt);
+    if(!file_exists(path)) break;
+    idx_cnt++;
+  }
+  *idx_cnt_out = idx_cnt;
+  return 1;
+}
+
+bool idx_ecnt(mess_t *c,size_t *ecnt_out){
+  char      path[PATH_BUF];
+  FILE     *f;
+  uint64_t  ecnt;
+
+  idx_path(path,sizeof(path),c,c->idx_cnt-1);
+  if(c->idx_cnt == 0 || !file_exists(path)){
+    *ecnt_out = 0;
+    return 1;
+  }
+
+  f = idx_open(path,"rb+",0);
+  if(!f) return 0;
+
+  if(!idx_read_ecnt(f,&ecnt,0)) return 0;
+
+  if(ecnt > IDX_MAX){
+    idx_corrupt(path,0);
+    file_close(f);
+    return 0;
+  }
+
+  idx_close(f,path,0);
+  *ecnt_out = ecnt;
+  return 1;
+}
+
+static unsigned idx_file_lookup(mess_t       *c,
+                                size_t        file_idx,
+                                hash_t const  hash,
+                                uint64_t     *index){
+  char      path[PATH_BUF];
+  FILE     *f;
+  size_t    i_start;
+  size_t    i_end;
+
+  idx_path(path,sizeof(path),c,file_idx);
+  f = idx_open(path,"r",0);
+  if(!f) return LOOKUP_IO;
+
+  i_start  = idx_hash_low32(hash)  & IDX_MAX-1;
+  i_end    = i_start-1             & IDX_MAX-1;
+  for(size_t i = i_start;i != i_end;i = i+1 & IDX_MAX-1){
+    uint64_t  i_index;
+    hash_t    i_hash;
+
+    if(!idx_seek_entry  (f,i,0))        return LOOKUP_IO;
+    if(!idx_read_index  (f,&i_index,0)) return LOOKUP_IO;
+    if(i_index == IDX_INDEX_EMPTY) break;
+
+    if(!idx_read_hash   (f,i_hash,0))   return LOOKUP_IO;
+    if(!hash_equal(i_hash,hash)) continue;
+
+    idx_close(f,path,0);
+    *index = i_index;
+    return LOOKUP_FOUND;
+  }
+
+  idx_close(f,path,0);
+  return LOOKUP_NOTFOUND;
+}
+
+unsigned idx_lookup(mess_t *c,hash_t const hash,uint64_t *index){
+  for(size_t x = c->idx_cnt-1;x < (size_t)-1;x--){
+    switch(idx_file_lookup(c,x,hash,index)){
+    case LOOKUP_FOUND:
+      return LOOKUP_FOUND;
+
+    case LOOKUP_NOTFOUND:
+      break;
+
+    case LOOKUP_IO:
+      irclog_err("failed to look up index in chain: '%s'",c->path);
+      return LOOKUP_IO;
+    }
+  }
+  return LOOKUP_NOTFOUND;
+}
+
diff -uNr a/src/ignore.c b/src/ignore.c
--- a/src/ignore.c false
+++ b/src/ignore.c c8e9ecb54d9133b64f7a2dd5ace6d36961863ef7db8356668f9be22c0d8e3971bb81861df01030e825bb147f6dbd739398f716efd3fdc97bd9d0ba9e79417641
@@ -0,0 +1,30 @@
+#include "pest.h"
+#include "packet.h"
+#include "crypto.h"
+#include "time.h"
+#include "config.h"
+#include "state.h"
+#include <assert.h>
+
+bool ignore_send(peer_t *chan,pkey_t *pk){
+  uint8_t   r[RED_SIZE];
+  uint8_t  *m = r+MESSAGE_OFF;
+  hash_t    hash;
+
+  if(!rng_read(m,MESSAGE_SIZE)) return 0;
+  hash_data(hash,m,MESSAGE_SIZE);
+  return send_message(CMD_IGNORE,r,hash,chan,pk);
+}
+
+void ignore_broadcast(uint64_t ntime){
+  uint64_t next;
+
+  if(ntime < ignore_next) return;
+  if(ignore_next > 0){
+    ignore_send(0,0);
+  }
+  if(!rng_read(&next,sizeof(next))) return;
+  next         %= igint*NSEC_MSEC*2;
+  ignore_next   = ntime+next;
+}
+
diff -uNr a/src/io.c b/src/io.c
--- a/src/io.c false
+++ b/src/io.c e679727077b82fe8ead7b7b37700f69d742d89cafc48fd9a50ff7ee222240bf3160c8ec2e893e0311451d5449d48254dd47548102dbac0e4dc9f9746e3622eb0
@@ -0,0 +1,415 @@
+#define _XOPEN_SOURCE 600
+#include "io.h"
+#include "addr.h"
+#include "crypto.h"
+#include "log.h"
+#include "util.h"
+#include "string.h"
+#include "def.h"
+#include "config.h"
+#include <ftw.h>
+#include <unistd.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <stdarg.h>
+#include <string.h>
+#include <errno.h>
+
+//TODO: chek errno osv
+bool file_exists(char const *path){
+  return access(path,F_OK) == 0;
+}
+
+bool file_touch(char const *path){
+  FILE *f = file_open(path,"ab");
+  if(!f) return 0;
+  if(!file_close(f)) return 0;
+  disk_written(path);
+  return 1;
+}
+
+bool file_delete(char const *path){
+  if(remove(path) == 0){
+#ifdef LOG_IOSPAM
+    log_out("file deleted: '%s'",path);
+#endif
+    return 1;
+  }else{
+    log_errno("remove");
+    irclog_err("failed to delete file: '%s'",path);
+    return 0;
+  }
+}
+
+bool file_rename(char const *from,char const *to){
+  if(rename(from,to) == 0){
+#ifdef LOG_IOSPAM
+    log_out("file renamed: '%s' -> '%s'",from,to);
+#endif
+    return 1;
+  }else{
+    log_errno("rename");
+    irclog_err("failed to rename file: '%s' -> '%s'",from,to);
+    return 0;
+  }
+}
+
+bool file_stat(char const *path,struct stat *sb){
+  if(stat(path,sb) == 0){
+#ifdef LOG_IOSPAM
+    log_out("file stated: '%s'",path);
+#endif
+    return 1;
+  }else{
+    log_errno("stat");
+    irclog_err("failed to stat file: '%s'",path);
+    return 0;
+  }
+}
+
+FILE *file_open(char const *path,char const *mode){
+  FILE *f = fopen(path,mode);
+  if(!f){
+    log_errno("fopen");
+    irclog_err("failed to open file: '%s'",path);
+  }
+  return f;
+}
+
+bool file_close(FILE *f){
+  int r = fclose(f);
+  if(r != 0){
+    log_errno("fclose");
+    irclog_err("failed to close file handle");
+    return 0;
+  }
+  return 1;
+}
+
+bool file_seek(FILE *f,size_t off,int origin){
+  if(fseek(f,off,origin) != 0){
+    log_errno("fseek");
+    irclog_err("failed to seek in file");
+    return 0;
+  }
+  return 1;
+}
+
+bool file_read(FILE *f,void *data,size_t size){
+  size_t r = fread(data,1,size,f);
+  if(r != size){
+    if(ferror(f)){
+      log_errno("fread");
+      irclog_err("failed to read from file");
+      return 0;
+    }else{
+      irclog_err("unexpected eof reached");
+      return 0;
+    }
+  }
+  return 1;
+}
+
+bool file_write(FILE *f,void const *data,size_t size){
+  size_t r = fwrite(data,1,size,f);
+  if(r != size){
+    log_errno("fwrite");
+    irclog_err("failed to write to file");
+    return 0;
+  }
+  return 1;
+}
+
+bool file_gets(FILE *f,void *buf,size_t buf_size){
+  char *r = fgets(buf,buf_size,f);
+  if(!r && ferror(f)){
+    log_errno("fgets");
+    irclog_err("failed to read from file");
+  }
+  return r;
+}
+
+bool file_printf(FILE *f,char const *fmt,...){
+  va_list args;
+  int     r;
+
+  va_start(args,fmt);
+  r = vfprintf(f,fmt,args);
+  va_end(args);
+  if(r < 0){
+    log_errno("fprintf");
+    irclog_err("failed to write to file");
+    return 0;
+  }
+  return 1;
+}
+
+bool mkdir_p(char const *path){
+  char  buf[PATH_BUF];
+  char *p = buf;
+  char  t;
+
+  strzcpy(buf,path,sizeof(buf));
+  do{
+    p   = strchr0(p,'/');
+    t   = *p;
+    *p  = 0;
+    if(mkdir(buf,DATA_MODE) == 0){
+#ifdef LOG_IOSPAM
+      log_out("directory created: '%s'",buf);
+#endif
+    }else if(errno != EEXIST){
+      log_errno("mkdir");
+      irclog_err("failed to create directory: '%s'",path);
+      return 0;
+    }
+    *p  = t;
+    p   = strnotchr0(++p,'/');
+  }while(t);
+  return 1;
+}
+
+static int ftw_rm_rf(char const         *path,
+                     struct stat const  *sb,
+                     int                 flag,
+                     struct FTW         *ftw){
+
+  (void)sb;
+  (void)flag;
+  (void)ftw;
+  return file_delete(path) ? 0 : -1;
+}
+
+bool rm_rf(char const *path){
+  if(nftw(path,ftw_rm_rf,64,FTW_DEPTH | FTW_PHYS) == 0){
+    return 1;
+  }else{
+    log_errno("nftw");
+    irclog_err("failed to recursively delete directory: '%s'",path);
+    return 0;
+  }
+}
+
+bool str_store(char const *path,char const *str){
+  FILE   *f;
+  size_t  str_len;
+
+  f = file_open(path,"wb");
+  if(!f) return 0;
+
+  str_len = strlen(str);
+  if(!file_write(f,str,str_len)){
+    file_close(f);
+    return 0;
+  }
+
+  if(!file_write(f,"\n",1)){
+    file_close(f);
+    return 0;
+  }
+
+  if(!file_close(f)) return 0;
+  disk_written(path);
+  return 1;
+}
+
+bool str_load(char const *path,char *buf,size_t buf_size){
+  FILE         *f;
+  size_t        size;
+  struct stat   sb;
+
+  if(!file_stat(path,&sb)) return 0;
+  size = (size_t)sb.st_size;
+
+  if(size+1 > buf_size){
+    irclog_err("file size + terminator exceeds "
+               "buffer size: '%s' (%zu > %zu)",
+               path,size+1,buf_size);
+    return 0;
+  }
+
+  f = file_open(path,"rb");
+  if(!f) return 0;
+
+  if(!file_read(f,buf,size)){
+    file_close(f);
+    return 0;
+  }
+
+  ((uint8_t *)buf)[size] = 0;
+  str_stripnl(buf);
+
+  file_close(f);
+  disk_read(path);
+  return 1;
+}
+
+bool int_store(char const *path,int64_t i){
+  char buf[INT64_BUF];
+  snprintf(buf,sizeof(buf),"%ld",i);
+  return str_store(path,buf);
+}
+
+bool int_load(char const *path,int64_t *i){
+  char buf[INT64_LEN+WHITE_LEN+1+1]; //int\n\0
+  if(!str_load(path,buf,sizeof(buf))) return 0;
+  *i = strtoll(buf,0,10);
+  return 1;
+}
+
+bool bool_store(char const *path,bool b){
+  return str_store(path,b ? "1" : "0");
+}
+
+bool bool_load(char const *path,bool *b){
+  char    buf[INT64_LEN+WHITE_LEN+1+1]; //int\n\0
+  int64_t i;
+  if(!str_load(path,buf,sizeof(buf))) return 0;
+  i   = strtoll(buf,0,10);
+  *b  = i != 0;
+  return 1;
+}
+
+bool hash_store(char const *path,hash_t const *h,size_t cnt){
+  FILE *f;
+
+  f = file_open(path,"wb");
+  if(!f) return 0;
+
+  for(size_t x = 0;x < cnt;x++){
+    char hash_b64[BASE64_ENC_SIZE(sizeof(hash_t),1)];
+    base64_enc(h[x],sizeof(hash_t),hash_b64,sizeof(hash_b64));
+
+    if(!file_printf(f,"%s\n",hash_b64)){
+      file_close(f);
+      return 0;
+    }
+  }
+
+  if(!file_close(f)) return 0;
+  disk_written(path);
+  return 1;
+}
+
+static bool hash_from_b64(hash_t hash,char const *b64_hash){
+  size_t n;
+
+  if(!str_valid(b64_hash,HASH_B64_LEN,HASH_B64_LEN,BASE64_CHARSET)){
+    return 0;
+  }
+
+  n = base64_dec(b64_hash,hash,HASH_SIZE,0);
+  assert(n == HASH_SIZE); (void)n;
+  return 1;
+}
+
+bool hash_load(char const *path,hash_t *h,size_t *cnt,size_t max){
+  FILE   *f;
+  char    buf[HASH_B64_LEN+WHITE_LEN+1+1]; //base64(hash)\n\0
+  char   *b;
+  size_t  n;
+
+  f = file_open(path,"rb");
+  if(!f) return 0;
+
+  n = 0;
+  while(file_gets(f,buf,sizeof(buf))){
+    b = str_trim(buf);
+    if(!*b) continue;
+
+    if(n >= max){
+      log_err("file '%s' max entries reached (%zu)",path,max);
+      file_close(f);
+      return 0;
+    }
+
+    if(!hash_from_b64(h[n],b)){
+      log_err("file '%s' contains invalid hash: '%s'",path,b);
+      file_close(f);
+      return 0;
+    }
+
+    n++;
+  }
+
+  if(ferror(f)){
+    file_close(f);
+    return 0;
+  }
+
+  file_close(f);
+  disk_read(path);
+  *cnt = n;
+  return 1;
+}
+
+bool pass_store(char const *path,uint8_t const *pass){
+  char pass_b64[B64_PASS_BUF];
+  base64_enc(pass,PASS_SIZE,pass_b64,sizeof(pass_b64));
+  return str_store(path,pass_b64);
+}
+
+bool pass_load(char const *path,uint8_t *pass){
+  char    buf[B64_PASS_LEN+WHITE_LEN+1+1]; //base64(pass_hash)\n\0
+  char   *b;
+  size_t  n;
+
+  if(!str_load(path,buf,sizeof(buf))){
+    return 0;
+  }
+
+  b = str_trim(buf);
+
+  if(!str_valid(b,B64_PASS_LEN,B64_PASS_LEN,BASE64_CHARSET)){
+    log_err("file '%s' contains invalid password hash: '%s'",path,b);
+    return 0;
+  }
+
+  n = base64_dec(b,pass,PASS_SIZE,0);
+  assert(n == PASS_SIZE); (void)n;
+
+  return 1;
+}
+
+bool addr_store(char const *path,addr_t const *addr){
+  char at[AT_BUF];
+  at_from_addr(at,sizeof(at),addr);
+  return str_store(path,at);
+}
+
+bool addr_load(char const *path,addr_t *addr){
+  char  buf[AT_LEN+WHITE_LEN+1+1]; //at\n\0
+  char *b;
+
+  if(!str_load(path,buf,sizeof(buf))){
+    return 0;
+  }
+
+  b = str_trim(buf);
+  if(*b && !addr_from_at(addr,b)){
+    log_err("file '%s' contains invalid address: "
+            "'%s' (format is ip:port)",path,b);
+    return 0;
+  }
+
+  return 1;
+}
+
+void disk_read(char const *path){
+  (void)path;
+#ifdef LOG_IOSPAM
+  log_out("file read: '%s'",path);
+#endif
+}
+
+void disk_written(char const *path){
+  (void)path;
+#ifdef LOG_IOSPAM
+  log_out("file written: '%s'",path);
+#endif
+}
+
+void disk_unsync(void){
+  irclog_out("ATTENTION - DISK OUT OF SYNC!");
+}
+
diff -uNr a/src/io.h b/src/io.h
--- a/src/io.h false
+++ b/src/io.h 233728f1fe2e5612be28ab7d7f659b0f75657707b6cb7996469f966fe59032908f5083fb78710e5f02ab927a93edf909c4f952ec466653d2eb8698bae87b76b5
@@ -0,0 +1,46 @@
+#ifndef IO_H
+#define IO_H
+
+#include "type.h"
+#include <stdint.h>
+#include <stdbool.h>
+#include <stddef.h>
+#include <stdio.h>
+#include <sys/stat.h>
+
+bool                file_exists     (char const *path);
+bool                file_touch      (char const *path);
+bool                file_delete     (char const *path);
+bool                file_rename     (char const *from,char const *to);
+bool                file_stat       (char const *path,struct stat *sb);
+
+FILE               *file_open       (char const *path,char const *mode);
+bool                file_close      (FILE *f);
+bool                file_seek       (FILE *f,size_t off,int origin);
+bool                file_read       (FILE *f,void *data,size_t size);
+bool                file_write      (FILE *f,void const *data,size_t size);
+bool                file_gets       (FILE *f,void *buf,size_t buf_size);
+bool                file_printf     (FILE *f,char const *fmt,...);
+
+bool                mkdir_p         (char const *path);
+bool                rm_rf           (char const *path);
+
+bool                str_store       (char const *path,char const *str);
+bool                str_load        (char const *path,char *buf,size_t buf_size);
+bool                int_store       (char const *path,int64_t  i);
+bool                int_load        (char const *path,int64_t *i);
+bool                bool_store      (char const *path,bool  b);
+bool                bool_load       (char const *path,bool *b);
+bool                hash_store      (char const *path,hash_t const *h,size_t  cnt);
+bool                hash_load       (char const *path,hash_t       *h,size_t *cnt,size_t max);
+bool                pass_store      (char const *path,uint8_t const *pass);
+bool                pass_load       (char const *path,uint8_t       *pass);
+bool                addr_store      (char const *path,addr_t const *addr);
+bool                addr_load       (char const *path,addr_t       *addr);
+
+void                disk_read       (char const *path);
+void                disk_written    (char const *path);
+void                disk_unsync     (void);
+
+#endif
+
diff -uNr a/src/irc.c b/src/irc.c
--- a/src/irc.c false
+++ b/src/irc.c ca91f8687a578d792e055ed9604cd9ae3e4b53f4a522c8d8735aec3f7a65867e763e1b9aa6daac6467162d1c4b8f5a15f92e9dbc0a19c4a26da02c8a6ba2ad46
@@ -0,0 +1,685 @@
+#include "ircd.h"
+#include "addr.h"
+#include "pest.h"
+#include "peer.h"
+#include "crypto.h"
+#include "net.h"
+#include "log.h"
+#include "util.h"
+#include "data.h"
+#include "wipe.h"
+#include "state.h"
+#include "string.h"
+#include <string.h>
+#include <stdlib.h>
+
+static void irc_sendmotd(void){
+  ircd_sendf(":%s 375 %s :- %s Message of the Day -",
+             IRC_SERV,self_handle,IRC_SERV);
+  ircd_sendf(":%s 372 %s :- %s",
+             IRC_SERV,self_handle,IRC_MOTD);
+  ircd_sendf(":%s 376 %s :End of MOTD command.",
+             IRC_SERV,self_handle);
+}
+
+static void irc_welcome(void){
+  if( irc_ready  ||
+     !irc_conned ||
+     !irc_usered ||
+     !irc_passed ||
+     !irc_nicked) return;
+  irc_ready = 1;
+
+  ircd_sendf(":%s 001 %s :Welcome to pest %s!%s@%s",
+             IRC_SERV,self_handle,self_handle,irc_user,irc_host);
+  ircd_sendf(":%s 002 %s :Your host is %s, running version "
+             PROG_FULLNAME,
+             IRC_SERV,self_handle,IRC_SERV,PROG_VERSION);
+  ircd_sendf(":%s 003 %s :This server was created at some point",
+             IRC_SERV,self_handle);
+  ircd_sendf(":%s 004 %s %s " PROG_FULLNAME " - -",
+             IRC_SERV,self_handle,IRC_SERV,PROG_VERSION);
+  irc_sendmotd();
+
+  log_out("operator connected");
+}
+
+static void irc_names(char const *chan){
+  if(strncmpci(chan,irc_chan,IRC_CHAN_LEN) == 0){
+    char  names[(HANDLE_LEN+1)*(1+PEER_MAX)+1]; //"handle "*(self+peers)\0
+    char *n = names;
+    char *e = names+sizeof(names);
+
+    *n  = 0;
+    n   = strpcpy(n,self_handle,e);
+    for(size_t x = 0;x < peer_cnt;x++){
+      peer_t *p = peer+x;
+      if(!p->active) continue;
+      n = strpcpy(n," ",e);
+      n = strpcpy(n,p->handle[0],e);
+    }
+
+    ircd_sendf(":%s 353 %s @ %s :%s",
+               IRC_SERV,self_handle,chan,names);
+  }
+  ircd_sendf(":%s 366 %s %s :End of NAMES list.",
+             IRC_SERV,self_handle,chan);
+}
+
+static void ircop_user(ircmsg_t const *m){
+  if(irc_usered) return;
+  if(m->argc < 1 || m->argc > 3){
+    return;
+  }
+
+  char *user = m->argv[0];
+  if(strncmp(user,irc_user,IRC_USER_LEN) != 0){
+    log_err("username mismatch: '%s' != '%s'",user,irc_user);
+    ircd_ckill();
+    return;
+  }
+
+  irc_usered = 1;
+  log_out("username accepted");
+  irc_welcome();
+}
+
+static void ircop_pass(ircmsg_t const *m){
+  char     *pwd;
+  uint8_t   pass[SHA512_SIZE];
+
+  if(irc_passed) return;
+  if(m->argc != 1){
+    return;
+  }
+
+  pwd = m->argv[0];
+  sha512(pass,(uint8_t *)pwd,strlen(pwd));
+  if(memcmp(pass,irc_pass,SHA512_SIZE) != 0){
+    log_err("password mismatch");
+    ircd_ckill();
+    return;
+  }
+
+  irc_passed = 1;
+  log_out("password accepted");
+  irc_welcome();
+}
+
+static void ircop_nick(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: NICK handle");
+    return;
+  }
+
+  char *handle = m->argv[0];
+  if(!str_valid(handle,1,HANDLE_LEN,HANDLE_CHARSET)){
+    ircd_sendf(":%s 432 %s :Erroneus handle",IRC_SERV,handle);
+    irclog_err("invalid handle: '%s'",handle);
+    return;
+  }
+
+  if(peer_lookup_noerr(handle)){
+    ircd_sendf(":%s 433 %s :Nickname is already in use",IRC_SERV,handle);
+    irclog_err("handle '%s' already exists in WOT",handle);
+    return;
+  }
+
+  ircd_sendf(":%s!%s@%s NICK :%s",self_handle,irc_user,irc_host,handle);
+  strzcpy(self_handle,handle,sizeof(self_handle));
+  irc_nicked = 1;
+  log_out("handle set to '%s'",self_handle);
+  irc_welcome();
+}
+
+static void ircop_join(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: JOIN channel");
+    return;
+  }
+
+  char *chan = m->argv[0];
+  if(chan[0] != '#' || strlen(chan) > IRC_CHAN_LEN){
+    irclog_err("invalid channel name: '%s'",chan);
+    return;
+  }
+
+  if(irc_joined){
+    ircd_sendf(":%s!%s@%s PART %s :",self_handle,irc_user,irc_host,irc_chan);
+    log_out("operator parted %s",irc_chan);
+  }
+  irc_joined = 1;
+  strzcpy(irc_chan,chan,sizeof(irc_chan));
+
+  ircd_sendf(":%s!%s@%s JOIN %s",self_handle,irc_user,irc_host,irc_chan);
+  irc_names(irc_chan);
+  log_out("operator joined %s",chan);
+}
+
+static void ircop_part(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: PART channel");
+    return;
+  }
+
+  char *chan = m->argv[0];
+  if(strncmpci(chan,irc_chan,IRC_CHAN_LEN) != 0){
+    ircd_sendf(":%s 442 %s :You're not on that channel",IRC_SERV,self_handle);
+    return;
+  }
+
+  ircd_sendf(":%s!%s@%s PART %s :",self_handle,irc_user,irc_host,irc_chan);
+  log_out("operator parted %s",irc_chan);
+  irc_joined  = 0;
+  *irc_chan   = 0;
+}
+
+static void ircop_privmsg(ircmsg_t const *m){
+  if(m->argc != 1 || !m->trail){
+    irc_err("usage: PRIVMSG [channel | handle] :message");
+    return;
+  }
+
+  char *chan  = m->argv[0];
+  char *msg   = m->trail;
+
+  if(chan[0] == '#'){
+    if(strncmpci(chan,irc_chan,IRC_CHAN_LEN) != 0){
+      ircd_sendf(":%s 404 %s :Cannot send to channel",IRC_SERV,chan);
+      return;
+    }
+    pest_broadcast(msg);
+  }else if(!pest_direct(chan,msg)){
+    ircd_sendf(":%s 401 %s :No such nick",IRC_SERV,chan);
+  }
+}
+
+static void ircop_names(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: NAMES channel");
+    return;
+  }
+
+  char *chan = m->argv[0];
+  irc_names(chan);
+}
+
+static void ircop_version(ircmsg_t const *m){
+  if(m->argc != 0){
+    irc_err("usage: VERSION");
+    return;
+  }
+
+  ircd_sendf(":%s 351 %s Pest-0x%02X. %s :" PROG_FULLNAME,
+             IRC_SERV,self_handle,PEST_VERSION,IRC_SERV);
+}
+
+static void ircop_motd(ircmsg_t const *m){
+  if(m->argc > 1){
+    irc_err("usage: MOTD [target]");
+    return;
+  }
+
+  irc_sendmotd();
+}
+
+static void ircop_ping(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: PING server");
+    return;
+  }
+
+  char *serv = m->argv[0]; (void)serv;
+  ircd_sendf(":%s PONG %s :%s",IRC_SERV,IRC_SERV,IRC_SERV);
+}
+
+static void ircop_quit(ircmsg_t const *m){
+  (void)m;
+  log_out("operator disconnected");
+  ircd_ckill();
+}
+
+static void ircop_wot(ircmsg_t const *m){
+  if(m->argc > 1){
+    irc_err("usage: WOT [handle]");
+    return;
+  }
+
+  if(m->argc > 0){
+    char   *handle  = m->argv[0];
+    peer_t *p       = peer_lookup(handle);
+    if(!p) return;
+    peer_print(p);
+  }else{
+    peer_wot_print();
+  }
+}
+
+static void ircop_peer(ircmsg_t const *m){
+  char    host[IRC_HOST_BUF];
+  peer_t *p;
+
+  if(m->argc != 1){
+    irc_err("usage: PEER handle");
+    return;
+  }
+
+  char *handle = m->argv[0];
+  p = peer_add(handle);
+  if(!p) return;
+  fmt_peerhost(host,sizeof(host),p->handle[0]);
+  //ircd_sendf(":%s JOIN %s",host,irc_chan);
+}
+
+static void ircop_unpeer(ircmsg_t const *m){
+  char host[IRC_HOST_BUF];
+
+  if(m->argc != 1){
+    irc_err("usage: UNPEER handle");
+    return;
+  }
+
+  char   *handle  = m->argv[0];
+  peer_t *p       = peer_lookup(handle);
+  if(!p) return;
+  fmt_peerhost(host,sizeof(host),p->handle[0]);
+  if(p->active){
+    ircd_sendf(":%s PART %s",host,irc_chan);
+  }
+  peer_del(p);
+}
+
+static void ircop_aka(ircmsg_t const *m){
+  if(m->argc != 2){
+    irc_err("usage: AKA handle alias");
+    return;
+  }
+
+  char   *handle  = m->argv[0];
+  char   *alias   = m->argv[1];
+  peer_t *p       = peer_lookup(handle);
+  if(!p) return;
+  if(!peer_alias_add(p,alias)) return;
+}
+
+static void ircop_unaka(ircmsg_t const *m){
+  char host[IRC_HOST_BUF];
+
+  if(m->argc != 1){
+    irc_err("usage: UNAKA handle");
+    return;
+  }
+
+  char   *handle  = m->argv[0];
+  peer_t *p       = peer_lookup(handle);
+  if(!p) return;
+
+  fmt_peerhost(host,sizeof(host),p->handle[0]);
+  unsigned r = peer_alias_del(p,handle);
+  if(!r) return;
+  if(r == 2){ //TODO: this is disgusting but works
+    ircd_sendf(":%s NICK :%s",host,p->handle[0]);
+  }
+}
+
+static void ircop_pause(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: PAUSE handle");
+    return;
+  }
+
+  char   *handle  = m->argv[0];
+  peer_t *p       = peer_lookup(handle);
+  if(!p) return;
+  peer_pause(p,1);
+}
+
+static void ircop_unpause(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: UNPAUSE handle");
+    return;
+  }
+
+  char   *handle  = m->argv[0];
+  peer_t *p       = peer_lookup(handle);
+  if(!p) return;
+  peer_pause(p,0);
+}
+
+static void ircop_key(ircmsg_t const *m){
+  if(m->argc != 2){
+    irc_err("usage: KEY handle key");
+    return;
+  }
+
+  uint8_t key[KEY_SIZE];
+  char   *handle  = m->argv[0];
+  char   *b64_key = m->argv[1];
+  peer_t *p       = peer_lookup(handle);
+  if(!p) return;
+
+  if(!key_from_b64(key,b64_key)){
+    irc_err("invalid key: '%s'",b64_key);
+    key_zero(key);
+    return;
+  }
+
+  peer_key_add(p,key,0);
+  key_zero(key);
+}
+
+static void ircop_unkey(ircmsg_t const *m){
+  uint8_t key[KEY_SIZE];
+
+  if(m->argc != 1){
+    irc_err("usage: UNKEY key");
+    return;
+  }
+
+  char *b64_key = m->argv[0];
+  if(!key_from_b64(key,b64_key)){
+    irc_err("invalid key: '%s'",b64_key);
+    key_zero(key);
+    return;
+  }
+
+  peer_key_del(key,0);
+  key_zero(key);
+}
+
+static void ircop_genkey(ircmsg_t const *m){
+  uint8_t key     [KEY_SIZE];
+  char    b64_key [B64_KEY_BUF];
+
+  if(m->argc != 0){
+    irc_err("usage: GENKEY");
+    return;
+  }
+
+  if(!key_gen(key)){
+    irclog_err("could not generate key");
+    return;
+  }
+
+  b64_from_key(b64_key,sizeof(b64_key),key);
+  irc_out("key generated from '%s': %s",RNG_PATH,b64_key);
+  key_zero(key);
+  BUF_ZERO(b64_key);
+}
+
+static void ircop_rekey(ircmsg_t const *m){
+  if(m->argc > 1){
+    irc_err("usage: REKEY [handle]");
+    return;
+  }
+
+  if(m->argc == 0){
+    rekey_initiate(0,1);
+  }else{
+    char   *handle  = m->argv[0];
+    peer_t *p       = peer_lookup(handle);
+    if(!p) return;
+    rekey_initiate(p,1);
+  }
+}
+
+static void ircop_rktog(ircmsg_t const *m){
+  if(m->argc > 1){
+  usage:
+    irc_err("usage: RKTOG ['ENABLE'/'DISABLE']");
+    return;
+  }
+
+  if(m->argc == 0){
+    knob_display(FILE_RKRECV,0);
+  }else if(strcmpci(m->argv[0],"ENABLE") == 0){
+    knob_set(FILE_RKRECV,"1");
+  }else if(strcmpci(m->argv[0],"DISABLE") == 0){
+    knob_set(FILE_RKRECV,"0");
+  }else{
+    goto usage;
+  }
+}
+
+static void ircop_gag(ircmsg_t const *m){
+  if(m->argc > 1){
+    irc_err("usage: GAG [handle]");
+    return;
+  }
+
+  if(m->argc == 0){
+    killfile_print();
+  }else{
+    char *handle = m->argv[0];
+    killfile_add(handle);
+  }
+}
+
+static void ircop_ungag(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: UNGAG handle");
+    return;
+  }
+
+  char *handle = m->argv[0];
+  killfile_del(handle);
+}
+
+static void ircop_at(ircmsg_t const *m){
+  if(m->argc > 2){
+    irc_err("usage: AT [handle [ip:port]]");
+    return;
+  }
+
+  if(m->argc == 0){
+    peer_at_print();
+  }else if(m->argc == 1){
+    char   *handle  = m->argv[0];
+    peer_t *p       = peer_lookup(handle);
+    if(!p) return;
+    if(addr_null(&p->addr)){
+      irclog_out("no address stored for peer '%s'",handle);
+      return;
+    }
+    peer_addr_print(p);
+  }else{
+    char   *handle  = m->argv[0];
+    char   *at      = m->argv[1];
+    peer_t *p       = peer_lookup(handle);
+    addr_t  addr;
+
+    if(!p) return;
+    if(!addr_from_at(&addr,at)){
+      irclog_err("invalid address (format is ip:port): '%s'",at);
+      return;
+    }
+
+    //char host[IRC_HOST_BUF];
+    //fmt_peerhost(host,sizeof(host),p->handle[0]);
+    //ircd_sendf(":%s PART %s",host,irc_chan);
+    //peer_addr_set(p,&addr);
+    //fmt_peerhost(host,sizeof(host),p->handle[0]);
+    //ircd_sendf(":%s JOIN %s",host,irc_chan);
+    peer_addr_set(p,&addr,1);
+  }
+}
+
+static void ircop_knob(ircmsg_t const *m){
+  if((!m->trail && m->argc  > 2) ||
+     ( m->trail && m->argc != 1)){
+    irc_err("usage: KNOB [knob [value]]");
+    return;
+  }
+
+  if(m->argc == 0){
+    knob_display(0,0);
+  }else if(m->trail){
+    char *knob  = m->argv[0];
+    char *value = m->trail;
+    knob_set(knob,value);
+  }else if(m->argc == 1){
+    char *knob  = m->argv[0];
+    knob_display(knob,0);
+  }else{
+    char *knob  = m->argv[0];
+    char *value = m->argv[1];
+    knob_set(knob,value);
+  }
+}
+
+static void ircop_knobinfo(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: KNOBINFO knob");
+    return;
+  }
+
+  char *knob = m->argv[0];
+  knob_display(knob,1);
+}
+
+static void ircop_cut(ircmsg_t const *m){
+  if(m->argc > 1){
+    irc_err("usage: CUT [cutoff]");
+    return;
+  }
+
+  if(m->argc == 0){
+    knob_display(FILE_CUTOFF,0);
+  }else{
+    knob_set(FILE_CUTOFF,m->argv[0]);
+  }
+}
+
+static void ircop_resolve(ircmsg_t const *m){
+  if(m->argc != 1){
+    irc_err("usage: RESOLVE handle");
+    return;
+  }
+
+  char *handle = m->argv[0];
+  pest_resolve(handle);
+}
+
+static void ircop_achtung(ircmsg_t const *m){
+  if(m->argc != 0 || !m->trail){
+    irc_err("usage: ACHTUNG :message");
+    return;
+  }
+
+  char *msg = m->trail;
+  pest_achtung(msg);
+}
+
+static void ircop_scram(ircmsg_t const *m){
+  char     *pwd;
+  uint8_t   pass[SHA512_SIZE];
+
+  if(m->argc != 1){
+    irc_err("usage: SCRAM scrampass");
+    return;
+  }
+
+  pwd = m->argv[0];
+  sha512(pass,(uint8_t *)pwd,strlen(pwd));
+  if(memcmp(pass,scram_pass,SHA512_SIZE) != 0){
+    irclog_err("SCRAM password mismatch");
+    return;
+  }
+
+  scram_push();
+}
+
+#define IRC_OP(N)           { #N, 0, ircop_##N },
+#define IRC_OP_INIT(N)      { #N, 1, ircop_##N },
+#define IRC_OP_IGNORE(N)    { #N, 0, 0         },
+
+typedef void (*ircmsg_f)(ircmsg_t const *);
+
+typedef struct ircop{
+  char const       *cmd;
+  bool              init;
+  ircmsg_f          func;
+}ircop_t;
+
+static ircop_t const irc_op[] = {
+  IRC_OP_INIT   (user)
+  IRC_OP_INIT   (pass)
+  IRC_OP_INIT   (nick)
+  IRC_OP        (join)
+  IRC_OP        (part)
+  IRC_OP        (privmsg)
+  IRC_OP        (names)
+  IRC_OP        (version)
+  IRC_OP        (motd)
+  IRC_OP        (ping)
+  IRC_OP_IGNORE (cap)
+  IRC_OP_IGNORE (mode)
+  IRC_OP_IGNORE (notice)
+  IRC_OP_IGNORE (who)
+  IRC_OP_IGNORE (whois)
+  IRC_OP_IGNORE (whowas)
+  IRC_OP        (quit)
+
+  IRC_OP        (wot)
+  IRC_OP        (peer)
+  IRC_OP        (unpeer)
+  IRC_OP        (aka)
+  IRC_OP        (unaka)
+  IRC_OP        (pause)
+  IRC_OP        (unpause)
+  IRC_OP        (key)
+  IRC_OP        (unkey)
+  IRC_OP        (genkey)
+  IRC_OP        (rekey)
+  IRC_OP        (rktog)
+  IRC_OP        (gag)
+  IRC_OP        (ungag)
+  IRC_OP        (at)
+  IRC_OP        (knob)
+  IRC_OP        (knobinfo)
+  IRC_OP        (cut)
+  IRC_OP        (resolve)
+  IRC_OP        (achtung)
+  IRC_OP        (scram)
+};
+
+void irc_ev(unsigned e,ircmsg_t const *msg);
+void irc_ev(unsigned e,ircmsg_t const *msg){
+  switch(e){
+    char cmd[IRCD_CMD_BUF];
+
+  case IRCD_CONNECT:
+    ip_str(irc_host,sizeof(irc_host),ircd_getip());
+    irc_conned = 1;
+    break;
+
+  case IRCD_DISCONNECT:
+    *irc_host   = 0;
+    irc_conned  = 0;
+    irc_usered  = 0;
+    irc_passed  = 0;
+    irc_nicked  = 0;
+    irc_joined  = 0;
+    irc_ready   = 0;
+    break;
+
+  case IRCD_MESSAGE:
+    for(size_t x = 0;x < ARR_CNT(irc_op);x++){
+      ircop_t const *op = irc_op+x;
+      if(strncmp(msg->cmd,op->cmd,IRCD_CMD_BUF) != 0) continue;
+      if(op->init || irc_ready){
+        if(op->func) op->func(msg);
+      }
+      return;
+    }
+
+    strncpy(cmd,msg->cmd,sizeof(cmd));
+    str_toupper(cmd);
+    irclog_err("unknown/unhandled IRC command received: %s",cmd);
+    break;
+
+  default:
+    assert(0);
+  }
+}
+
diff -uNr a/src/ircd.c b/src/ircd.c
--- a/src/ircd.c false
+++ b/src/ircd.c a9db131d8fbb8502f14679302097bd60ea5051728b404b20c37c8cd52b040ec673406b52f8b138f75df56f3e63652558c7ee7ba5cdaeb546851fcad460210329
@@ -0,0 +1,197 @@
+#include "ircd.h"
+#include "net.h"
+#include "crypto.h"
+#include "util.h"
+#include "string.h"
+#include "log.h"
+#include "config.h"
+#include "state.h"
+#include <stdio.h>
+#include <string.h>
+#include <assert.h>
+
+static void tcp_ev(unsigned e){
+  switch(e){
+  case TCP_CONNECT:
+    if(ircd_func) ircd_func(IRCD_CONNECT,0);
+    break;
+
+  case TCP_DISCONNECT:
+    if(ircd_func) ircd_func(IRCD_DISCONNECT,0);
+    break;
+
+  default:
+    assert(0);
+  }
+}
+
+void ircd_init(ircev_f func){
+  ircd_func = func;
+  tcp_init(tcp_ev);
+}
+
+void ircd_exit(void){
+  tcp_cclose();
+  tcp_lclose();
+}
+
+void ircd_ckill(void){
+  tcp_cclose();
+}
+
+static bool parse_msg(ircmsg_t *m,char *c){
+  char *t;
+  char *u;
+
+  memset(m,0x00,sizeof(*m));
+
+  if(*c == ':'){
+    c++;
+    m->pre_name = c;
+
+    u = strchr(c,' ');
+    if(!u){
+      log_err("IRC parse_msg: prefix space");
+      return 0;
+    }
+    *u = 0;
+
+    if(t = strchr(c,'!')){
+      c           = t;
+      *c++        = 0;
+      m->pre_user = c;
+    }
+
+    if(t = strchr(c,'@')){
+      c           = t;
+      *c++        = 0;
+      m->pre_host = c;
+    }
+
+    assert(u == strchr(c,0));
+    c = strnotchr0(u+1,' ');
+  }
+
+  m->cmd  = c;
+  c       = strchr(c,' ');
+  if(!c){
+    //RFC borken?
+    goto end;
+    //log_err("IRC parse_msg: first param space");
+    //return 0;
+  }
+  *c++ = 0;
+
+  while(1){
+    c = strnotchr0(c,' ');
+    if(*c == 0) break;
+    if(*c == ':'){
+      c++;
+      m->trail = c;
+      break;
+    }
+
+    if(m->argc >= IRCD_ARG_MAX){
+      log_err("IRC parse_msg: max args exceeded");
+      return 0;
+    }
+
+    m->argv[m->argc] = c;
+    m->argc++;
+    c = strchr(c,' ');
+    if(!c){
+      //RFC borken?
+      break;
+      //log_err("IRC parse_msg: subsequent param space");
+      //return 0;
+    }
+    *c++ = 0;
+  }
+
+end:
+  str_tolower(m->cmd);
+  //TODO: validate al shit
+  return 1;
+}
+
+static void recv_msg(char *cmd){
+  ircmsg_t m;
+  if(!parse_msg(&m,cmd)){
+    log_err("failed to parse IRC message");
+    return;
+  }
+  if(ircd_func) ircd_func(IRCD_MESSAGE,&m);
+}
+
+static bool ircd_recv(void){
+  static char   buf[IRC_MSG_BUF];
+  static char  *buf_e = buf+sizeof(buf);
+  static char  *buf_p = buf;
+  char         *r;
+  size_t        n;
+
+  n = tcp_recv(&ircd_src_ip,
+               &ircd_src_port,
+               irc_port,
+               (uint8_t *)buf_p,
+               buf_e-buf_p);
+  if(!n) return 0;
+  buf_p += n;
+
+  while(r = str_nstr(buf,"\r\n",buf_p-buf)){
+    *r  = 0;
+    r  += 2;
+    recv_msg(buf);
+    assert(r <= buf_p);
+    memmove(buf,r,buf_p-r);
+    buf_p = buf+(buf_p-r);
+  }
+
+  BUF_ZERO(buf);
+  return 1;
+}
+
+void ircd_tick(void){
+  for(size_t x = 0;x < IRCD_RECV_MAX;x++){
+    if(!ircd_recv()) break;
+  }
+}
+
+size_t ircd_send(char const *msg){
+  return tcp_send((uint8_t const *)msg,strlen(msg));
+}
+
+size_t ircd_sendf(char const *fmt,...){
+  va_list args;
+  size_t  n;
+
+  va_start(args,fmt);
+  n = ircd_vsendf(fmt,args);
+  va_end(args);
+  return n;
+}
+
+size_t ircd_vsendf(char const *fmt,va_list args){
+  char    buf[IRC_MSG_BUF];
+  char   *b;
+  int     n;
+  size_t  r;
+
+  n = vsnprintf(buf,sizeof(buf),fmt,args);
+  if(n < 0){
+    BUF_ZERO(buf);
+    log_errno("vsnprintf");
+    return 0;
+  }
+
+  b = buf+n;
+  b = strpcpy(b,"\r\n",buf+sizeof(buf));
+  r = ircd_send(buf);
+  memset_ffs(buf,0x00,b-buf);
+  return r;
+}
+
+uint32_t ircd_getip(void){
+  return ircd_src_ip;
+}
+
diff -uNr a/src/ircd.h b/src/ircd.h
