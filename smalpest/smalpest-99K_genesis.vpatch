@@ -0,0 +1,23 @@
+#ifndef PACKET_H
+#define PACKET_H
+
+#include "data.h"
+#include <stdint.h>
+#include <stdbool.h>
+#include <stddef.h>
+
+void                black_ciph      (uint8_t *b,uint8_t const *r,uint8_t const *key_serp);
+void                black_deciph    (uint8_t *r,uint8_t const *b,uint8_t const *key_serp);
+void                black_sign      (uint8_t *b,uint8_t const *key);
+bool                black_verify    (uint8_t const *b,uint8_t const *key);
+
+bool                red_rebroadcast (uint8_t *r,hash_t const hash,uint8_t bounces);
+
+bool                send_message    (uint8_t command,uint8_t *r,hash_t hash,peer_t *chan,pkey_t *pk);
+bool                send_text       (uint8_t command,uint64_t stamp,uint8_t const *text,size_t text_size,peer_t *chan);
+bool                send_str        (uint8_t cmd,char const *str,peer_t *chan);
+
+bool                pest_recv       (uint64_t time);
+
+#endif
+
diff -uNr a/src/packetlog.c b/src/packetlog.c
--- a/src/packetlog.c false
+++ b/src/packetlog.c 0e49ce5aa71360b2b86eccd3136be14d823c70e0f1e2085611a5cc9c5cc4496364827fb336eb35821ae8b2d8e007509473c0bede80f0086e098458308a64d794
@@ -0,0 +1,160 @@
+#include "log.h"
+#include "term.h"
+#include "addr.h"
+#include "crypto.h"
+#include "time.h"
+#include "config.h"
+#include <assert.h>
+
+#define ARROW_DISCARD         ANSI_GRAY  "<-" ANSI_NORM
+#define ARROW_IN              ANSI_GREEN "<-" ANSI_NORM
+#define ARROW_OUT             ANSI_RED   "->" ANSI_NORM
+
+static char const *cmd_abbrev[] = {
+  [ CMD_BROADCAST   ] = "BC",  
+  [ CMD_DIRECT      ] = "DM",  
+  [ CMD_BANNER      ] = "BA",  
+  [ CMD_GETDATA     ] = "GD",  
+  [ CMD_KEYOFFER    ] = "KO",  
+  [ CMD_KEYSLICE    ] = "KS",  
+  [ CMD_ADDRESSCAST ] = "AC",  
+  [ CMD_IGNORE      ] = "IG",  
+};
+
+void log_packet(hash_t const  hash,
+                uint8_t       cmd,
+                peer_t       *p,
+                addr_t const *addr,
+                bool          outgoing,
+                uint64_t      time,
+                uint64_t      stamp){
+
+  char        hash_hex [HASH_HEX_BUF];
+  char        at       [AT_BUF];
+  char        tdiff    [STAMPDIFF_BUF];
+  char const *dst = p ? p->handle[0] : "*";
+
+#ifndef LOG_IGNORE
+  if(cmd == CMD_IGNORE && outgoing) return;
+#endif
+
+  hash_str_log(hash_hex,sizeof(hash_hex),hash);
+  if(addr){
+    at_from_addr(at,sizeof(at),addr);
+  }else{
+    *at = 0;
+  }
+
+  if(outgoing){
+    log_out("%s %s " ARROW_OUT " %s %s",
+            cmd_abbrev[cmd],hash_hex,dst,at);
+  }else{
+    fmt_stampdiff(tdiff,sizeof(tdiff),time,stamp);
+    log_out("%s %s " ARROW_IN " %s %s [%s]",
+            cmd_abbrev[cmd],hash_hex,dst,at,tdiff);
+  }
+}
+
+void log_martian(addr_t const *addr,bool reason_size){
+  char at[AT_BUF];
+
+#ifndef LOG_MARTIAN
+  return;
+#endif
+
+  at_from_addr(at,sizeof(at),addr);
+  if(reason_size){
+    log_out("?? [  ??  ] " ARROW_DISCARD " %s [martian: size != %d]",
+            at,BLACK_SIZE);
+  }else{
+    log_out("?? [  ??  ] " ARROW_DISCARD " %s [martian: no key]",
+            at);
+  }
+}
+
+static void log_discard(hash_t const   hash,
+                        uint8_t        cmd,
+                        peer_t        *p,
+                        addr_t const  *addr,
+                        char const    *reason){
+
+  char hash_hex [HASH_HEX_BUF];
+  char at       [AT_BUF];
+
+  hash_str_log(hash_hex,sizeof(hash_hex),hash);
+  at_from_addr(at,sizeof(at),addr);
+  log_out("%s %s " ARROW_DISCARD " %s %s [%s]",
+          cmd_abbrev[cmd],hash_hex,p->handle[0],at,reason);
+}
+
+void log_stale(hash_t const   hash,
+               uint8_t        cmd,
+               peer_t        *p,
+               addr_t const  *addr,
+               uint64_t       time,
+               uint64_t       stamp){
+
+#ifndef LOG_STALE
+  return;
+#endif
+
+  char diff[STAMPDIFF_BUF];
+  fmt_stampdiff(diff,sizeof(diff),time,stamp);
+  log_discard(hash,cmd,p,addr,diff);
+}
+
+void log_dupe(hash_t const   hash,
+              uint8_t        cmd,
+              peer_t        *p,
+              addr_t const  *addr){
+
+#ifndef LOG_DUPLICATE
+  return;
+#endif
+
+  log_discard(hash,cmd,p,addr,"duplicate");
+}
+
+void log_dedup_full(hash_t const   hash,
+                    uint8_t        cmd,
+                    peer_t        *p,
+                    addr_t const  *addr){
+
+#ifndef LOG_DUPLICATE
+  return;
+#endif
+
+  log_discard(hash,cmd,p,addr,"dedup buffer full");
+}
+
+void log_ignore(hash_t const   hash,
+                uint8_t        cmd,
+                peer_t        *p,
+                addr_t const  *addr){
+
+#ifndef LOG_IGNORE
+  return;
+#endif
+
+  log_discard(hash,cmd,p,addr,"ignore");
+}
+
+void log_cutoff(hash_t const  hash,
+                uint8_t       cmd,
+                peer_t       *p,
+                addr_t const *addr,
+                uint8_t       bounces){
+
+  char hash_hex [HASH_HEX_BUF];
+  char at       [AT_BUF];
+
+#ifndef LOG_CUTOFF
+  return;
+#endif
+
+  hash_str_log(hash_hex,sizeof(hash_hex),hash);
+  at_from_addr(at,sizeof(at),addr);
+  log_out("%s %s " ARROW_DISCARD " %s %s [discarded: bounces = %u]",
+          cmd_abbrev[cmd],hash_hex,p->handle[0],at,bounces);
+}
+
diff -uNr a/src/peer.c b/src/peer.c
--- a/src/peer.c false
+++ b/src/peer.c f3fcb4725c81aaf279209391dc72553a8ce39d7cb37f92ce2ab1358a3e0b072b33a363a3165ba596b8bc0099bfcb935aa20d9cb20cf4abdd5a1557794d38455a
@@ -0,0 +1,587 @@
+#include "peer.h"
+#include "addr.h"
+#include "chain.h"
+#include "crypto.h"
+#include "pest.h"
+#include "log.h"
+#include "io.h"
+#include "time.h"
+#include "util.h"
+#include "string.h"
+#include "state.h"
+#include <string.h>
+#include <stdio.h>
+#include <stdlib.h>
+
+peer_t *peer_lookup_id(peerid_t id){
+  if(id == PEER_ID_INVALID) return 0;
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p = peer+x;
+    if(p->id == id) return p;
+  }
+  return 0;
+}
+
+peer_t *peer_lookup_noerr(char const *handle){
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p = peer+x;
+    for(size_t y = 0;y < p->handle_cnt;y++){
+      if(strncmp(handle,p->handle[y],HANDLE_LEN) == 0) return p;
+    }
+  }
+  return 0;
+}
+
+peer_t *peer_lookup(char const *handle){
+  peer_t *p = peer_lookup_noerr(handle);
+  if(!p){
+    irc_err("peer '%s' not found in WOT",handle);
+  }
+  return p;
+}
+
+static void peer_path(peer_t *p){
+  char  path[PATH_BUF];
+  char *handle = p->handle[0];
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_MESS,handle);
+  mess_path(&p->mess,path);
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_DCHAIN,handle);
+  chain_path(&p->dchain,path);
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_BCHAIN,handle);
+  chain_path(&p->bchain,path);
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_DCHAIN"/"FILE_HEAD,handle);
+  ht_path(&p->dhead,path);
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_DCHAIN"/"FILE_TAIL,handle);
+  ht_path(&p->dtail,path);
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_BCHAIN"/"FILE_HEAD,handle);
+  ht_path(&p->bhead,path);
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_BCHAIN"/"FILE_TAIL,handle);
+  ht_path(&p->btail,path);
+}
+
+static void peer_init(peer_t *p,char const *handle,peerid_t id){
+  strzcpy(p->handle[0],handle,sizeof(p->handle[0]));
+
+  p->id         = id;
+  p->handle_cnt = 1;
+  p->key_cnt    = 0;
+  p->addr.ip    = 0;
+  p->addr.port  = 0;
+  p->stamp      = 0;
+  p->pak_stamp  = 0;
+  p->con_stamp  = mono_sec();
+  p->active     = 0;
+  p->paused     = 0;
+  p->banner[0]  = 0;
+
+  mess_init(&p->mess);
+  chain_init(&p->dchain);
+  chain_init(&p->bchain);
+  ht_init(&p->dhead);
+  ht_init(&p->dtail);
+  ht_init(&p->bhead);
+  ht_init(&p->btail);
+  hash_zero(p->self);
+  rekey_init(&p->rekey);
+
+  peer_path(p);
+}
+
+static uint16_t id_next(void){
+  peerid_t end = peer_id-1;
+  while(peer_lookup_id(peer_id)){
+    if(peer_id == end)              return PEER_ID_INVALID;
+    if(peer_id == PEER_ID_INVALID)  return PEER_ID_INVALID;
+  }
+  return peer_id++;
+}
+
+peer_t *peer_add_internal(char const *handle,bool boot){
+  log_f     out = boot ? log_void : irclog_out;
+  log_f     err = boot ? log_err  : irc_err;
+  peer_t   *p;
+  peerid_t  id;
+
+  if(peer_cnt >= PEER_MAX){
+    err("max peers reached, increase dunbar number in source");
+    return 0;
+  }
+
+  //TODO: more useful eror, maxlen, chars alowed osv
+  if(!handle_valid(handle)){
+    err("invalid peer handle: '%s'",handle);
+    return 0;
+  }
+
+  if(strncmp(handle,self_handle,HANDLE_LEN) == 0){
+    err("peer handle cannot be same as own handle");
+    return 0;
+  }
+
+  if(peer_lookup_noerr(handle)){
+    err("handle '%s' already exists in WOT",handle);
+    return 0;
+  }
+
+  id = id_next();
+  if(id == PEER_ID_INVALID){
+    err("peer ids exhausted");
+    return 0;
+  }
+
+  p = &peer[peer_cnt++];
+  peer_init(p,handle,id);
+  if(!peer_loadpeer(p)) return 0;
+
+  out("peer '%s' added",handle);
+  return p;
+}
+
+peer_t *peer_add(char const *handle){
+  return peer_add_internal(handle,0);
+}
+
+void peer_del(peer_t *p){
+  char  path[PATH_BUF];
+  char  handle[HANDLE_BUF];
+
+  hearsay_del_peer(p);
+  pending_del_peer(p);
+  getdata_del_peer(p);
+
+  strzcpy(handle,p->handle[0],sizeof(handle));
+  ARR_DEL(peer,peer_cnt,p);
+  peer_cnt--;
+  FMT_PATH(path,DIR_PEER"/%s",handle);
+  if(!rm_rf(path)){
+    disk_unsync();
+  }
+  irclog_out("peer '%s' deleted",handle);
+}
+
+bool peer_alias_add_internal(peer_t *p,char const *alias,bool boot){
+  log_f   out = boot ? log_void : irclog_out;
+  log_f   err = boot ? log_err  : irc_err;
+  char   *handle = p->handle[0];
+
+  if(p->handle_cnt >= HANDLE_MAX){
+    err("max number of aliases (%d) reached for peer '%s'",HANDLE_MAX,handle);
+    return 0;
+  }
+
+  if(!handle_valid(alias)){
+    err("invalid peer alias: '%s'",alias);
+    return 0;
+  }
+
+  if(strncmp(alias,self_handle,HANDLE_LEN) == 0){
+    err("peer alias cannot be same as own handle");
+    return 0;
+  }
+
+  if(peer_lookup_noerr(alias)){
+    err("handle '%s' already exists in WOT",alias);
+    return 0;
+  }
+
+  strzcpy(p->handle[p->handle_cnt],alias,sizeof(p->handle[p->handle_cnt]));
+  p->handle_cnt++;
+
+  if(!boot) peer_alias_store(p);
+
+  out("alias '%s' added for peer '%s'",alias,handle);
+  return 1;
+}
+
+bool peer_alias_add(peer_t *p,char const *alias){
+  return peer_alias_add_internal(p,alias,0);
+}
+
+unsigned peer_alias_del(peer_t *p,char const *alias){
+  char    handle_old[HANDLE_BUF];
+  char   *h;
+  bool    rename;
+
+  strzcpy(handle_old,p->handle[0],sizeof(handle_old));
+
+  if(p->handle_cnt == 1){
+    irc_err("cannot delete last handle for peer '%s'",handle_old);
+    return 0;
+  }
+
+  h = peer_handle_lookup(p,alias);
+  assert(h);
+
+  rename = h == p->handle[0];
+  ARR_DEL(p->handle,p->handle_cnt,(handle_t *)h);
+  p->handle_cnt--;
+
+  irclog_out("alias '%s' for peer '%s' deleted",alias,handle_old);
+
+  if(rename){
+    char  path_from  [PATH_BUF];
+    char  path_to    [PATH_BUF];
+    char *handle_new;
+
+    handle_new = p->handle[0];
+
+    FMT_PATH(path_from, DIR_PEER"/%s",handle_old);
+    FMT_PATH(path_to,   DIR_PEER"/%s",handle_new);
+    if(!file_rename(path_from,path_to)){
+      disk_unsync();
+    }
+    peer_path(p);
+
+    irclog_out("main handle for peer '%s' is now '%s'",handle_old,handle_new);
+  }
+
+  peer_alias_store(p);
+  return rename ? 2 : 1;
+}
+
+static void pkey_init(pkey_t *pk,uint8_t const *key,uint64_t time){
+  memcpy(pk->key.full,key,KEY_SIZE);
+  serpent_init(pk->ciph_serp,pk->key.sub.ciph,sizeof(pk->key.sub.ciph));
+  pk->time = time;
+}
+
+pkey_t *peer_lookup_pkey(peer_t *p,uint8_t const *key){
+  for(size_t x = 0;x < p->key_cnt;x++){
+    pkey_t *pk = p->key+x;
+    if(memcmp(pk->key.full,key,KEY_SIZE) == 0){
+      return pk;
+    }
+  }
+  return 0;
+}
+
+pkey_t *pkey_lookup_noerr(uint8_t const *key,peer_t **peer_out){
+  if(peer_out) *peer_out = 0;
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p   = peer+x;
+    pkey_t *pk  = peer_lookup_pkey(p,key);
+    if(pk){
+      if(peer_out) *peer_out = p;
+      return pk;
+    }
+  }
+  return 0;
+}
+
+static pkey_t *pkey_lookup(uint8_t const *key,peer_t **peer_out){
+  pkey_t *pk = pkey_lookup_noerr(key,peer_out);
+  if(!pk){
+    char b64_key[B64_KEY_BUF];
+    b64_from_key(b64_key,sizeof(b64_key),key);
+    irc_err("key '%s' not found in WOT",b64_key);
+    BUF_ZERO(b64_key);
+  }
+  return pk;
+}
+
+bool peer_key_add_internal(peer_t        *p,
+                           uint8_t const *key,
+                           uint64_t       time,
+                           bool           boot,
+                           bool           silent){
+
+  log_f   out = boot || silent ? log_void : irclog_out;
+  log_f   err = boot           ? log_err  : irc_err;
+  char   *handle = p->handle[0];
+  char    b64_key[B64_KEY_BUF];
+
+  if(p->key_cnt >= KEY_MAX){
+    err("max number of keys (%d) reached for peer '%s'",KEY_MAX,handle);
+    return 0;
+  }
+
+  b64_from_key(b64_key,sizeof(b64_key),key);
+
+  if(entropy_missing(key,sizeof(key))){
+    err("entropy obviously missing from key: '%s'",b64_key);
+    BUF_ZERO(b64_key);
+    return 0;
+  }
+
+  if(pkey_lookup_noerr(key,0)){
+    err("key '%s' already exists in WOT",b64_key);
+    BUF_ZERO(b64_key);
+    return 0;
+  }
+
+  pkey_init(&p->key[p->key_cnt],key,time);
+  p->key_cnt++;
+
+  if(!boot) peer_key_store(p);
+
+  out("key '%s' added for peer '%s'",b64_key,handle);
+  BUF_ZERO(b64_key);
+  return 1;
+}
+
+bool peer_key_add(peer_t *p,uint8_t const *key,bool silent){
+  return peer_key_add_internal(p,key,0,0,silent);
+}
+
+bool peer_key_del(uint8_t const *key,bool silent){
+  log_f     out = silent ? log_void : irclog_out;
+  peer_t   *p;
+  pkey_t   *pk;
+  char      b64_key[B64_KEY_BUF];
+  char     *handle;
+
+  pk = pkey_lookup(key,&p);
+  if(!pk) return 0;
+  handle = p->handle[0];
+
+  if(p->key_cnt <= 1){
+    irc_err("cannot delete last key for peer '%s'",handle);
+    return 0;
+  }
+
+  ARR_DEL(p->key,p->key_cnt,pk);
+  p->key_cnt--;
+  memset_ffs(p->key+p->key_cnt,0x00,sizeof(pkey_t));
+
+  peer_key_store(p);
+
+  b64_from_key(b64_key,sizeof(b64_key),key);
+  out("key '%s' for peer '%s' deleted",b64_key,handle);
+  BUF_ZERO(b64_key);
+  return 1;
+}
+
+void peer_key_stamp(peer_t *p,pkey_t *pk,uint64_t time){
+  pk->time = time;
+  peer_key_store(p);
+}
+
+void peer_banner_set(peer_t *p,char const *banner){
+  strzcpy(p->banner,banner,sizeof(p->banner));
+  peer_banner_store(p);
+}
+
+pkey_t *peer_key_recent(peer_t *p){
+  pkey_t   *k   = 0;
+  uint64_t  max = 0;
+  for(size_t x = 0;x < p->key_cnt;x++){
+    pkey_t *pk = p->key+x;
+    //prefer higher index so uses gorekt key
+    //when rekey even if stamp identical
+    if(pk->time >= max){
+      k   = pk;
+      max = pk->time;
+    }
+  }
+
+  if(!k){
+    irc_err("no key exists for peer '%s'",p->handle[0]);
+  }
+
+  return k;
+}
+
+bool peer_addr_set(peer_t *p,addr_t *addr,bool spam){
+  log_f out = spam ? irclog_out : log_out;
+  char  at[AT_BUF];
+
+  assert(addr_valid(addr));
+  p->addr = *addr;
+
+  peer_addr_store(p);
+
+  at_from_addr(at,sizeof(at),addr);
+  out("address for peer '%s' set to '%s'",p->handle[0],at);
+  return 1;
+}
+
+void peer_pause(peer_t *p,bool pause){
+  p->paused = pause;
+  peer_pause_store(p);
+  irclog_out("peer '%s' %spaused",p->handle[0],p->paused ? "" : "un");
+}
+
+void peer_stamp(peer_t *p,uint64_t stamp){
+  p->stamp = stamp;
+  peer_stamp_store(p);
+}
+
+void peer_pak_stamp(peer_t *p,uint64_t stamp){
+  p->pak_stamp = stamp;
+}
+
+char *peer_handle_lookup(peer_t *p,char const *handle){
+  for(size_t x = 0;x < p->handle_cnt;x++){
+    char *h = p->handle[x];
+    if(strncmp(handle,h,HANDLE_LEN) == 0) return h;
+  }
+  return 0;
+}
+
+bool peer_cansend(peer_t *p,bool error){
+  log_f   err     = error ? irclog_err : log_void;
+  char   *handle  = p->handle[0];
+
+  if(p->key_cnt == 0){
+    err("cannot send to peer '%s', no key exists ",handle);
+    return 0;
+  }
+
+  if(p->addr.ip == 0){
+    err("cannot send to peer '%s', no ip exists",handle);
+    return 0;
+  }
+
+  if(p->addr.port == 0){
+    err("cannot send to peer '%s', no port exists",handle);
+    return 0;
+  }
+
+  if(p->paused){
+    err("cannot send to peer '%s', peer is paused",handle);
+    return 0;
+  }
+
+  return 1;
+}
+
+//TODO: fix this great stuf
+static peer_t *pkey_index_cmp_peer = 0;
+static int pkey_index_cmp(size_t const *a,size_t const *b){
+  peer_t *p = pkey_index_cmp_peer;
+  return  (p->key[*a].time < p->key[*b].time)
+         -(p->key[*a].time > p->key[*b].time);
+}
+
+static void peer_print_internal(peer_t *p,bool key){
+  char        handles [(HANDLE_LEN+2)*HANDLE_MAX]; //handle (alias0, alias1)\0
+  char        at      [AT_BUF];
+  char        forks   [9];  //99 forks\0
+  char        breaks  [10]; //99 breaks\0
+  char        ts      [STAMP_BUF];
+  char        b64_key [B64_KEY_BUF];
+  size_t      f;
+  size_t      b;
+
+  char       *a = handles;
+  char       *e = handles+sizeof(handles);
+  char const *ps;
+
+  a = strpcpy(a,p->handle[0],e);
+  if(p->handle_cnt > 1){
+    a = strpcpy(a," (",e);
+    for(size_t x = 1;x < p->handle_cnt;x++){
+      a = strpcpy(a,p->handle[x],e);
+      if(x+1 < p->handle_cnt){
+        a = strpcpy(a,", ",e);
+      }
+    }
+    a = strpcpy(a,")",e);
+  }
+
+  if(!addr_null(&p->addr)){
+    at_from_addr(at,sizeof(at),&p->addr);
+  }else{
+    *at = 0;
+  }
+
+  f   = 0;
+  b   = 0;
+  f  += ht_forks  (&p->bhead,&p->btail);
+  b  += ht_breaks (&p->bhead,&p->btail);
+  f  += ht_forks  (&p->dhead,&p->dtail);
+  b  += ht_breaks (&p->dhead,&p->dtail);
+  snprintf(forks, sizeof(forks),  "%2zu fork%c",  f,f == 1 ? ' ' : 's');
+  snprintf(breaks,sizeof(breaks), "%2zu break%c", b,b == 1 ? ' ' : 's');
+
+  if(p->stamp){
+    time_str(ts,sizeof(ts),CONSOLE_STAMP_FMT,p->stamp);
+  }else{
+    *ts = 0;
+  }
+
+  ps = p->paused ? "paused" : "";
+
+  if(key) irc_out("--- BEGIN PEER INFO ---");
+  irc_out("%-24s  %-21s  %zu key%c  %-8s  %-9s  %-6s     %s",
+          handles,at,p->key_cnt,p->key_cnt == 1 ? ' ' : 's',forks,breaks,ps,ts);
+  if(!key) return;
+
+  size_t index[KEY_MAX];
+  for(size_t x = 0;x < p->key_cnt;x++){
+    index[x] = x;
+  }
+  pkey_index_cmp_peer = p;
+  qsort(index,p->key_cnt,sizeof(*index),(qsort_f)pkey_index_cmp);
+
+  for(size_t x = 0;x < p->key_cnt;x++){
+    pkey_t *pk = p->key+index[x];
+    b64_from_key(b64_key,sizeof(b64_key),pk->key.full);
+    if(pk->time){
+      *ts = ' ';
+      time_str(ts+1,sizeof(ts)-1,CONSOLE_STAMP_FMT,pk->time);
+    }else{
+      *ts = 0;
+    }
+    irc_out("%s%s",b64_key,ts);
+  }
+  BUF_ZERO(b64_key);
+
+  if(*p->banner){
+    irc_out("banner: '%s'",p->banner);
+  }
+
+  irc_out("--- END PEER INFO ---");
+}
+
+void peer_print(peer_t *p){
+  peer_print_internal(p,1);
+}
+
+void peer_wot_print(void){
+  if(peer_cnt == 0){
+    irc_out("web of trust is empty");
+    return;
+  }
+  irc_out("--- BEGIN WEB OF TRUST ---");
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_print_internal(peer+x,0);
+  }
+  irc_out("--- END WEB OF TRUST ---");
+}
+
+void peer_addr_print(peer_t *p){
+  //TODO: "at" -> something else
+  char at[AT_BUF];
+
+  if(addr_null(&p->addr)) return;
+  at_from_addr(at,sizeof(at),&p->addr);
+  irc_out("%-24s  %s",p->handle[0],at);
+}
+
+static bool at_empty(void){
+  for(size_t x = 0;x < peer_cnt;x++){
+    if(!addr_null(&peer[x].addr)) return 0;
+  }
+  return 1;
+}
+
+void peer_at_print(void){
+  if(at_empty()){
+    irc_out("address table is empty");
+    return;
+  }
+  irc_out("--- BEGIN ADDRESS TABLE ---");
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_addr_print(peer+x);
+  }
+  irc_out("--- END ADDRESS TABLE ---");
+}
+
diff -uNr a/src/peer.h b/src/peer.h
--- a/src/peer.h false
+++ b/src/peer.h c46b19e0ac0249d25313f9759bff038f4ce144f3f6644b8ff7e6d35e05fa60632dbc941040a38055f0e207ba4e9bdc9c439e0f757f15a17ef3e2c50e6c4e4e67
@@ -0,0 +1,49 @@
+#ifndef PEER_H
+#define PEER_H
+
+#include "type.h"
+#include <stdbool.h>
+
+pkey_t             *pkey_lookup_noerr (uint8_t const *key,peer_t **peer_out);
+
+peer_t             *peer_lookup_id          (peerid_t id);
+peer_t             *peer_lookup_noerr       (char const *handle);
+peer_t             *peer_lookup             (char const *handle);
+pkey_t             *peer_lookup_pkey        (peer_t *p,uint8_t const *key);
+peer_t             *peer_add                (char const *handle);
+void                peer_del                (peer_t *p);
+bool                peer_alias_add          (peer_t *p,char const *alias);
+unsigned            peer_alias_del          (peer_t *p,char const *alias);
+bool                peer_key_add            (peer_t *p,uint8_t const *key,bool silent);
+bool                peer_key_del            (uint8_t const *key,bool silent);
+void                peer_key_stamp          (peer_t *p,pkey_t *pk,uint64_t time);
+pkey_t             *peer_key_recent         (peer_t *p);
+bool                peer_addr_set           (peer_t *p,addr_t *addr,bool spam);
+void                peer_pause              (peer_t *p,bool pause);
+void                peer_stamp              (peer_t *p,uint64_t stamp);
+void                peer_pak_stamp          (peer_t *p,uint64_t stamp);
+void                peer_banner_set         (peer_t *p,char const *banner);
+char               *peer_handle_lookup      (peer_t *p,char const *handle);
+bool                peer_cansend            (peer_t *p,bool error);
+
+peer_t             *peer_add_internal       (char const *handle,bool boot);
+bool                peer_alias_add_internal (peer_t *p,char const *alias,bool boot);
+bool                peer_key_add_internal   (peer_t *p,uint8_t const *key,uint64_t time,bool boot,bool silent);
+
+void                peer_print              (peer_t *p);
+void                peer_wot_print          (void);
+void                peer_addr_print         (peer_t *p);
+void                peer_at_print           (void);
+
+bool                peer_alias_store        (peer_t *p);
+bool                peer_key_store          (peer_t *p);
+bool                peer_addr_store         (peer_t *p);
+bool                peer_stamp_store        (peer_t *p);
+bool                peer_pause_store        (peer_t *p);
+bool                peer_banner_store       (peer_t *p);
+
+bool                peer_loadpeer           (peer_t *p);
+bool                peer_load               (void);
+
+#endif
+
diff -uNr a/src/peerio.c b/src/peerio.c
--- a/src/peerio.c false
+++ b/src/peerio.c 6c03825c2db9ce9d1bf96dabcdad757059e3a88a194b41568006fbeea1f5e35d25e860a2fc0d4d54bc41b490b974e939d33cf386261a01bbd8f915bc67fb462e
@@ -0,0 +1,351 @@
+#include "peer.h"
+#include "addr.h"
+#include "chain.h"
+#include "crypto.h"
+#include "io.h"
+#include "log.h"
+#include "util.h"
+#include "string.h"
+#include "state.h"
+#include <dirent.h>
+#include <stdlib.h>
+#include <string.h>
+
+bool peer_alias_store(peer_t *p){
+  char  path[PATH_BUF];
+  FILE *f;
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_ALIAS,p->handle[0]);
+  if(p->handle_cnt <= 1){
+    if(!file_delete(path)){
+      disk_unsync();
+      return 0;
+    }
+    return 1;
+  }
+  f = file_open(path,"wb");
+  if(!f){
+    disk_unsync();
+    return 0;
+  }
+
+  for(size_t x = 1;x < p->handle_cnt;x++){
+    if(!file_printf(f,"%s\n",p->handle[x])){
+      file_close(f);
+      disk_unsync();
+      return 0;
+    }
+  }
+
+  if(!file_close(f)){
+    disk_unsync();
+    return 0;
+  }
+  disk_written(path);
+  return 1;
+}
+
+static bool peer_alias_load(peer_t *p){
+  char    path[PATH_BUF];
+  FILE   *f;
+  char    buf[HANDLE_BUF+1+1]; //\n +1 for detecting invalid handle
+  char   *b;
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_ALIAS,p->handle[0]);
+  if(!file_exists(path)){
+    return file_touch(path);
+  }
+  f = file_open(path,"rb");
+  if(!f) return 0;
+
+  while(file_gets(f,buf,sizeof(buf))){
+    b = str_trim(buf);
+    if(!*b) continue;
+
+    if(!peer_alias_add_internal(p,b,1)){
+      file_close(f);
+      return 0;
+    }
+  }
+
+  if(ferror(f)){
+    file_close(f);
+    return 0;
+  }
+
+  file_close(f);
+  disk_read(path);
+  return 1;
+}
+
+bool peer_key_store(peer_t *p){
+  char  path[PATH_BUF];
+  FILE *f;
+
+  assert(p->key_cnt > 0);
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_KEY,p->handle[0]);
+  f = file_open(path,"wb");
+  if(!f){
+    disk_unsync();
+    return 0;
+  }
+
+  for(size_t x = 0;x < p->key_cnt;x++){
+    pkey_t *pk = p->key+x;
+    char    b64_key[B64_KEY_BUF];
+    bool    r;
+
+    b64_from_key(b64_key,sizeof(b64_key),pk->key.full);
+    if(pk->time > 0) r = file_printf(f,"%s %zu\n",b64_key,pk->time);
+    else             r = file_printf(f,"%s\n",b64_key);
+    BUF_ZERO(b64_key);
+    if(!r){
+      file_close(f);
+      disk_unsync();
+      return 0;
+    }
+  }
+
+  if(!file_close(f)){
+    disk_unsync();
+    return 0;
+  }
+  disk_written(path);
+  return 1;
+}
+
+static bool peer_key_load(peer_t *p){
+  char    path[PATH_BUF];
+  FILE   *f;
+  char    buf[B64_KEY_LEN+WHITE_LEN+INT64_LEN+WHITE_LEN+1+1]; //key_timestamp\n\0
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_KEY,p->handle[0]);
+  if(!file_exists(path)){
+    return file_touch(path);
+  }
+  f = file_open(path,"rb");
+  if(!f) return 0;
+
+  while(file_gets(f,buf,sizeof(buf))){
+    size_t    argc;
+    char     *argv[2];
+    uint64_t  time = 0;
+    uint8_t   key[KEY_SIZE];
+    char     *b64_key;
+
+    argc = str_args(buf,2,argv);
+    if(argc == 0) continue;
+    if(argc > 2){
+      log_err("invalid key file format: '%s'",path);
+      file_close(f);
+      return 0;
+    }
+
+    b64_key = argv[0];
+    if(!key_from_b64(key,b64_key)){
+      log_err("invalid key: '%s'",b64_key);
+      key_zero(key);
+      return 0;
+    }
+
+    if(argc > 1){
+      time = strtoll(argv[1],0,10);
+    }
+
+    if(!peer_key_add_internal(p,key,time,1,0)){
+      memset_ffs(b64_key,0x00,strlen(b64_key));
+      key_zero(key);
+      file_close(f);
+      return 0;
+    }
+
+    memset_ffs(b64_key,0x00,strlen(b64_key));
+    key_zero(key);
+  }
+
+  if(ferror(f)){
+    file_close(f);
+    return 0;
+  }
+
+  file_close(f);
+  disk_read(path);
+  return 1;
+}
+
+bool peer_addr_store(peer_t *p){
+  char path[PATH_BUF];
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_ADDR,p->handle[0]);
+  if(!addr_store(path,&p->addr)){
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool peer_addr_load(peer_t *p){
+  char path[PATH_BUF];
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_ADDR,p->handle[0]);
+  if(!file_exists(path)){
+    return addr_store(path,&p->addr);
+  }else{
+    return addr_load(path,&p->addr);
+  }
+}
+
+bool peer_stamp_store(peer_t *p){
+  char path[PATH_BUF];
+  char stamp[STAMP_BUF];
+
+  snprintf(stamp,sizeof(stamp),"%lu",p->stamp);
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_STAMP,p->handle[0]);
+  if(!str_store(path,stamp)){
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool peer_stamp_load(peer_t *p){
+  char    path[PATH_BUF];
+  int64_t i;
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_STAMP,p->handle[0]);
+  if(!file_exists(path)){
+    return int_store(path,p->stamp);
+  }
+  if(!int_load(path,&i)){
+    return 0;
+  }
+  p->stamp = i;
+  return 1;
+}
+
+bool peer_pause_store(peer_t *p){
+  char path[PATH_BUF];
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_PAUSE,p->handle[0]);
+  if(!bool_store(path,p->paused)){
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool peer_pause_load(peer_t *p){
+  char path[PATH_BUF];
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_PAUSE,p->handle[0]);
+  if(!file_exists(path)){
+    return bool_store(path,p->paused);
+  }else{
+    return bool_load(path,&p->paused);
+  }
+}
+
+bool peer_banner_store(peer_t *p){
+  char path[PATH_BUF];
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_BANNER,p->handle[0]);
+  if(!str_store(path,p->banner)){
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool peer_banner_load(peer_t *p){
+  char  path [PATH_BUF];
+  char  buf  [BANNER_LEN+WHITE_LEN+1+1]; //banner\n\0
+  char *b;
+
+  FMT_PATH(path,DIR_PEER"/%s/"FILE_BANNER,p->handle[0]);
+  if(!file_exists(path)){
+    return file_touch(path);
+  }
+  if(!str_load(path,buf,sizeof(buf))){
+    return 0;
+  }
+
+  b = str_trim(buf);
+  if(strlen(b) > BANNER_LEN){
+    log_err("banner too long (max %zu)",BANNER_LEN);
+    return 0;
+  }
+
+  strzcpy(p->banner,b,sizeof(p->banner));
+  return 1;
+}
+
+static bool peer_chainmess_load(peer_t *p){
+  char    path[PATH_BUF];
+  size_t  cnt;
+
+  if(!mess_load(&p->mess))        return 0;
+  if(!chain_load(&p->dchain))     return 0;
+  if(!chain_load(&p->bchain))     return 0;
+  if(!ht_load(&p->dhead))         return 0;
+  if(!ht_load(&p->dtail))         return 0;
+  if(!ht_load(&p->bhead))         return 0;
+  if(!ht_load(&p->btail))         return 0;
+
+  FMT_PATH(path,DIR_PEER"/%s/"DIR_DCHAIN"/"FILE_SELF,p->handle[0]);
+  if(file_exists(path)){
+    if(!hash_load(path,&p->self,&cnt,1)) return 0;
+  }else{
+    hash_zero(p->self);
+    if(!hash_store(path,(hash_t const *)&p->self,1)) return 0;
+  }
+
+  return 1;
+}
+
+bool peer_loadpeer(peer_t *p){
+  char        path[PATH_BUF];
+  char const *handle = p->handle[0];
+
+  FMT_PATH(path,DIR_PEER"/%s",handle);
+  if(!mkdir_p(path))            return 0;
+
+  if(!peer_alias_load(p))       return 0;
+  if(!peer_key_load(p))         return 0;
+  if(!peer_addr_load(p))        return 0;
+  if(!peer_stamp_load(p))       return 0;
+  if(!peer_pause_load(p))       return 0;
+  if(!peer_banner_load(p))      return 0;
+  if(!peer_chainmess_load(p))   return 0;
+
+  return 1;
+}
+
+bool peer_load(void){
+  char path[PATH_BUF];
+
+  FMT_PATH(path,"%s",DIR_PEER);
+  if(!mkdir_p(path)) return 0;
+
+  //TODO: put shit in io.c
+  //TODO: order??
+  DIR            *d;
+  struct dirent  *de;
+  if((d = opendir(path)) == 0){
+    log_errno("opendir");
+    log_err("failed to list dir '%s'",path);
+    return 0;
+  }
+
+  while(de = readdir(d)){
+    peer_t *p;
+
+    if(strcmp(de->d_name,"." ) == 0) continue;
+    if(strcmp(de->d_name,"..") == 0) continue;
+
+    p = peer_add_internal(de->d_name,1);
+    if(!p) return 0;
+  }
+  closedir(d);
+
+  return 1;
+}
+
diff -uNr a/src/pending.c b/src/pending.c
--- a/src/pending.c false
+++ b/src/pending.c 2bb5d3337152c96c10ccd79580235477b48409fa61bf7819bce37995fc1b58bdd5ee366d1520f830b9224930eb36d9e775c1e9534565879c16524edc98dbfe39
@@ -0,0 +1,197 @@
+#include "pest.h"
+#include "packet.h"
+#include "peer.h"
+#include "log.h"
+#include "time.h"
+#include "crypto.h"
+#include "serial.h"
+#include "util.h"
+#include "string.h"
+#include "config.h"
+#include "state.h"
+
+#define PENDING_TIMEOUT (gdtime*gdatt+10)
+
+static void del(pending_t *e){
+  ARR_DEL(pen,pen_cnt,e);
+  pen_cnt--;
+  memset_ffs(pen+pen_cnt,0x00,sizeof(*pen));
+}
+
+static void send_chain(pending_t *e,bool timeout,bool top){
+  hash_t            hash;
+  peer_t           *p;
+  peer_t           *chan;
+  static uint64_t   stamp;
+
+  hash_copy(hash,e->hash);
+
+  p     = peer_lookup_id(e->peer_id);
+  chan  = peer_lookup_id(e->chan_id);
+  assert(p);
+  if(top) getdata_del(e->hash,0);
+  message_handle(e->m,e->hash,e->speaker,p,chan,1,0,1);
+  read_u64(e->m+TIMESTAMP_OFF,&stamp);
+  del(e);
+
+again:
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t      *f       = pen+x;
+    uint8_t const  *f_prev  = f->m+SELFCHAIN_OFF;
+
+    if(!f->tail) continue;
+    if(!hash_equal(f_prev,hash)) continue;
+
+    send_chain(f,timeout,0);
+    goto again;
+  }
+
+  if(top){
+    //set last stamp to last message in chain
+    console_stamp(chan,stamp);  
+  }
+}
+
+//TODO: undumbtarded algo for keping trak of bigness
+static size_t bigness(pending_t *e){
+  size_t n = 1;
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t      *f       = pen+x;
+    uint8_t const  *f_prev  = f->m+SELFCHAIN_OFF;
+
+    if(e == f) continue;
+    if(!f->tail) continue;
+    if(!hash_equal(f_prev,e->hash)) continue;
+
+    n += bigness(f);
+  }
+  return n;
+}
+
+static void force_timeout(void){
+  size_t      big_max = 0;
+  pending_t  *big     = 0; 
+
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t  *e = pen+x;
+    size_t      e_big;
+
+    if(e->tail) continue;
+
+    e_big = bigness(e);
+    if(e_big > big_max){
+      big     = e;
+      big_max = e_big;
+    }
+  }
+
+  assert(big);
+  send_chain(big,1,1);
+}
+
+bool pending_dontfull(void){
+  if(pen_cnt >= PENDING_MAX){
+    irclog_out("pending message buffer full, forcing timeout");
+    force_timeout();
+    return 1;
+  }
+  return 0;
+}
+
+bool pending_lookup(hash_t const hash){
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t *e = pen+x;
+    if(hash_equal(e->hash,hash)) return 1;
+  }
+  return 0;
+}
+
+static bool test_heads(hash_t const prev){
+  return pending_lookup(prev);
+}
+
+static void test_tails(hash_t const hash){
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t      *e       = pen+x;
+    uint8_t const  *e_prev  = e->m+SELFCHAIN_OFF;
+    if(hash_equal(e_prev,hash)){
+      e->tail = 1;
+    }
+  }
+}
+
+bool pending_push(uint8_t const  *m,
+                  hash_t const    hash,
+                  char const     *speaker,
+                  peer_t         *p,
+                  peer_t         *chan){
+
+  pending_t      *e;
+  uint8_t const  *prev = m+SELFCHAIN_OFF;
+
+  assert(pen_cnt < PENDING_MAX);
+
+  e           = &pen[pen_cnt++];
+  e->peer_id  = p->id;
+  e->chan_id  = chan ? chan->id : PEER_ID_INVALID;
+  e->ntime    = mono_nsec();
+  hash_copy(e->hash,hash);
+  memcpy(e->m,m,sizeof(e->m));
+  strzcpy(e->speaker,speaker,sizeof(e->speaker));
+
+  //see if this is continuation in > dir
+  e->tail = test_heads(prev);
+
+  //see if this is continuation in < dir
+  test_tails(hash);
+
+  if(!e->tail && !hearsay_lookup(e->m+SELFCHAIN_OFF)){
+    getdata_push(p,chan,e->m+SELFCHAIN_OFF);
+  }
+
+  return 1;
+}
+
+//TODO: this shit is entirely stupid
+bool pending_send_chain(hash_t const prev){
+  bool r = 0;
+again:
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t *e = pen+x;
+    if(hash_equal(e->m+SELFCHAIN_OFF,prev)){
+      send_chain(e,0,1);
+      r = 1;
+      goto again;
+    }
+  }
+  return r;
+}
+
+void pending_del_peer(peer_t *p){
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t *e = pen+x;
+    if(e->chan_id == p->id){
+      del(e);
+      x--;
+    }
+  }
+}
+
+void pending_process(uint64_t ntime){
+again:
+  for(size_t x = 0;x < pen_cnt;x++){
+    pending_t *e = pen+x;
+
+    if(ntime < e->ntime+(PENDING_TIMEOUT*NSEC_MSEC)){
+      continue;
+    }
+
+    if(e->tail){
+      continue;
+    }
+
+    send_chain(e,1,1);
+    goto again;
+  }
+}
+
diff -uNr a/src/pest.c b/src/pest.c
--- a/src/pest.c false
+++ b/src/pest.c 0d88c0ec9a99737d7170d40604d91da2bb2879ed96d054aadce9ac4cf0b6245808c662a15cf0650cfc6f0036d89575f0f41693ae343525ec23b430f7f9c561b8
@@ -0,0 +1,177 @@
+#include "pest.h"
+#include "packet.h"
+#include "peer.h"
+#include "chain.h"
+#include "crypto.h"
+#include "net.h"
+#include "io.h"
+#include "log.h"
+#include "time.h"
+#include "util.h"
+#include "config.h"
+#include "state.h"
+
+//TODO: brian name for this
+bool pest_init(pestev_f func){
+  char    path[PATH_BUF];
+  size_t  cnt;
+
+  pest_func = func;
+
+  if(!knob_load()) return 0;
+  dedup_load();
+
+  FMT_PATH(path,"%s",DIR_MESS);
+  mess_init(&mess);
+  mess_path(&mess,path);
+  if(!mess_load(&mess)){
+    irclog_err("failed to load mess: '%s'",path);
+    return 0;
+  }
+
+  FMT_PATH(path,"%s",DIR_CHAIN);
+  if(!mkdir_p(path)) return 0;
+
+  FMT_PATH(path,DIR_CHAIN"/%s",FILE_SELF);
+  if(file_exists(path)){
+    if(!hash_load(path,&self,&cnt,1)) return 0;
+  }else{
+    hash_zero(self);
+    if(!hash_store(path,(hash_t const *)&self,1)) return 0;
+  }
+
+  FMT_PATH(path,DIR_CHAIN"/%s",FILE_NET);
+  if(file_exists(path)){
+    if(!hash_load(path,&net,&cnt,1)) return 0;
+  }else{
+    hash_zero(self);
+    if(!hash_store(path,(hash_t const *)&net,1)) return 0;
+  }
+
+  console_stamp(0,mono_sec());
+
+  return 1;
+}
+
+static void peer_check_active(uint64_t time){
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p       = peer+x; 
+    bool    active  = p->active;
+
+    p->active = time < p->pak_stamp+irctime;
+    if(pest_func && !active && p->active){
+      pest_func(PEST_ACTIVE,p->handle[0],0);
+    }
+    if(pest_func && active && !p->active){
+      pest_func(PEST_INACTIVE,p->handle[0],0);
+    }
+  }
+}
+
+void pest_tick(uint64_t time,uint64_t ntime,bool active){
+  if(!active){
+    udp_recv(0,0,pest_port,0,0);
+    return;
+  }
+
+  dedup_clean       (time);
+  hearsay_process   (ntime);
+  pending_process   (ntime);
+  getdata_process   (ntime);
+  getdata_retry     (time);
+  rekey_clean       (time);
+  rekey_broadcast   (time);
+  banner_broadcast  (time);
+  ignore_broadcast  (ntime);
+  peer_check_active (time);
+
+  for(size_t x = 0;x < PEST_RECV_MAX;x++){
+    if(!pest_recv(time)) break;
+  }
+}
+
+bool pest_broadcast(char const *msg){
+  return send_str(CMD_BROADCAST,msg,0);
+}
+
+bool pest_direct(char const *handle,char const *msg){
+  peer_t *p = peer_lookup(handle);
+  if(!p) return 0;
+  if(!peer_cansend(p,1)) return 0;
+  return send_str(CMD_DIRECT,msg,p);
+}
+
+bool pest_achtung(char const *msg){
+  uint16_t peer_idx[peer_cnt];
+
+  if(!index_shuffle(peer_idx,peer_cnt)){
+    irclog_err("could not shuffle index, achtung not sent");
+    return 0;
+  }
+
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p = peer+peer_idx[x];
+    if(!peer_cansend(p,0)) continue;
+    send_str(CMD_DIRECT,msg,p);
+  }
+
+  return 1;
+}
+
+static bool resolve(char const *handle,
+                    char const *chname,
+                    chain_t    *c,
+                    ht_t       *head,
+                    ht_t       *tail){
+
+  hash_t *l;
+  hash_t  h;
+  hash_t  t;
+
+  if(ht_forks (head,tail) == 0 &&
+     ht_breaks(head,tail) == 0){
+    return 0;
+  }
+
+  l = ht_last(head);
+  if(!l){
+    irc_err("make sure you have seen at least one "
+            "message from peer before resolve fork/break");
+    return 1;
+  }
+  hash_copy(h,*l);
+
+  if(chain_resolve(c,h,t)){
+    ht_clear(head,h);
+    ht_clear(tail,t);
+    irclog_out("peer '%s' %s fork/break resolved",
+               handle,chname);
+  }else{
+    irclog_err("failed to resolve peer '%s' %s fork/break",
+               handle,chname);
+  }
+
+  return 1;
+}
+
+void pest_resolve(char const *handle){
+  size_t  n = 0;
+  peer_t *p = peer_lookup(handle);
+  if(!p) return;
+
+  if(resolve(p->handle[0],"broadcast",
+             &p->bchain,&p->bhead,&p->btail)){
+    n++;
+  }
+
+  if(resolve(p->handle[0],"direct message",
+             &p->dchain,&p->dhead,&p->dtail)){
+    n++;
+  }
+
+  if(!n){
+    irc_err("cannot resolve, peer '%s' chain is not forked/broken",
+            p->handle[0]);
+  }
+}
+
diff -uNr a/src/pest.h b/src/pest.h
--- a/src/pest.h false
+++ b/src/pest.h 19430dad03f8f0f29a1f49bc8fcb887014cbcf7b7214f316e80db5b2c0cda52eeb7e3a94ba6e1eee40e8daa720d1e7d92af289f95b2deaaf841f1b695e86ef4b
@@ -0,0 +1,78 @@
+#ifndef PEST_H
+#define PEST_H
+
+#include "type.h"
+#include <stdint.h>
+#include <stdbool.h>
+
+bool                pest_init           (pestev_f func);
+void                pest_tick           (uint64_t time,uint64_t ntime,bool active);
+bool                pest_broadcast      (char const *msg);
+bool                pest_direct         (char const *handle,char const *msg);
+bool                pest_achtung        (char const *msg);
+void                pest_resolve        (char const *handle);
+
+void                knob_display        (char const *name,bool alt);
+void                knob_set            (char const *name,char const *val);
+bool                knob_load           (void);
+
+bool                dedup_load          (void);
+bool                dedup_lookup        (hash_t const hash);
+bool                dedup_push          (hash_t const hash,uint64_t time);
+void                dedup_clean         (uint64_t time);
+
+bool                getdata_push        (peer_t *p,peer_t *chan,hash_t const hash);
+bool                getdata_push_cond   (peer_t *p,peer_t *chan,hash_t const hash);
+bool                getdata_lookup      (hash_t const hash);
+bool                getdata_del         (hash_t const hash,peer_t **peer);
+void                getdata_del_peer    (peer_t *p);
+void                getdata_process     (uint64_t ntime);
+void                getdata_retry       (uint64_t time);
+void                getdata_handle      (peer_t *p,hash_t hash);
+
+bool                pending_dontfull    (void);
+bool                pending_lookup      (hash_t const hash);
+bool                pending_push        (uint8_t const *m,hash_t const hash,char const *speaker,peer_t *p,peer_t *chan);
+bool                pending_send_chain  (hash_t const prev);
+void                pending_del_peer    (peer_t *p);
+void                pending_process     (uint64_t ntime);
+
+void               *hearsay_lookup      (hash_t const hash);
+void                hearsay_peer        (void *h,peer_t *p,uint8_t bounces);
+bool                hearsay_peered      (void *h,peer_t *p);
+void               *hearsay_push        (hash_t const hash,uint8_t const *red,peer_t *speaker,peer_t *p,uint8_t bounces);
+void                hearsay_del         (void *h);
+void                hearsay_del_peer    (peer_t *p);
+
+void                hearsay_process     (uint64_t ntime);
+
+void                banner_handle       (peer_t *p,uint8_t const *m);
+void                banner_broadcast    (uint64_t time);
+
+void                rekey_init          (rekey_t *rk);
+bool                rekey_active        (rekey_t *rk);
+bool                rekey_keyexists     (rekey_t *rk);
+void                rekey_initiate      (peer_t *p,bool log);
+bool                rekey_handle_offer  (peer_t *p,uint8_t const *offer);
+bool                rekey_handle_slice  (peer_t *p,uint8_t const *slice);
+bool                rekey_handle_ignore (peer_t *p,pkey_t *pk,uint64_t time);
+bool                rekey_handle_packet (peer_t *p,pkey_t *pk);
+void                rekey_broadcast     (uint64_t time);
+void                rekey_clean         (uint64_t time);
+
+void                addrcast_broadcast  (addr_t const *addr);
+bool                addrcast_handle     (uint8_t const *ab);
+
+bool                ignore_send         (peer_t *chan,pkey_t *pk);
+void                ignore_broadcast    (uint64_t time);
+
+void                message_handle      (uint8_t const *m,hash_t const hash,char const *speaker,peer_t *p,peer_t *chan,bool stampold,bool pend,bool display);
+void                message_handle_simp (uint8_t const *m,hash_t const hash,char const *speaker,bool stampold);
+bool                broadcast_handle    (peer_t *p,peer_t *gd_peer,bool immediate,uint8_t *r,hash_t const hash,uint8_t bounces,char const *speaker);
+bool                direct_handle       (peer_t *p,peer_t *gd_peer,bool immediate,uint8_t *r,hash_t const hash,uint8_t bounces,char const *speaker);
+
+void                console_send        (peer_t *chan,char const *speaker,uint8_t const *m,bool stampold);
+void                console_stamp       (peer_t *p,uint64_t stamp);
+
+#endif
+
diff -uNr a/src/recv.c b/src/recv.c
--- a/src/recv.c false
+++ b/src/recv.c fc3ea1a11277977f44e47200be0e50cbd3b1c7d16e3030284344a865c1d2a29c72534c0166a5b0d011441489b13209081932ba1e7319b3fe0566232dbfac2d14
@@ -0,0 +1,268 @@
+#include "packet.h"
+#include "pest.h"
+#include "chain.h"
+#include "addr.h"
+#include "peer.h"
+#include "net.h"
+#include "crypto.h"
+#include "time.h"
+#include "log.h"
+#include "io.h"
+#include "serial.h"
+#include "util.h"
+#include "string.h"
+#include "config.h"
+#include "state.h"
+#include <string.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <assert.h>
+
+static bool stamp_stale(uint64_t time,uint64_t stamp){
+  return stamp < time-TIMESTAMP_MAXDIFF ||
+         stamp > time+TIMESTAMP_MAXDIFF;
+}
+
+static bool find_key(uint8_t const *b,peer_t **p_out,pkey_t **pk_out){
+  uint16_t peer_idx[peer_cnt];
+
+  if(!index_shuffle(peer_idx,peer_cnt)){
+    irclog_err("could not shuffle index, "
+               "black packet cannot be processed");
+    return 0;
+  }
+
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t *p = peer+peer_idx[x];
+    if(p->paused) continue;
+
+    for(size_t y = 0;y < p->key_cnt;y++){
+      pkey_t *pk = p->key+y;
+      if(!black_verify(b,pk->key.sub.sign)) continue;
+      *p_out  = p;
+      *pk_out = pk;
+      return 1;
+    }
+  }
+  return 0;
+}
+
+static void at_update(peer_t *p,addr_t *addr){
+  if(setport){
+    if(!addr_equal(&p->addr,addr)){
+      peer_addr_set(p,addr,0);
+    }
+  }else if(p->addr.ip != addr->ip){
+    addr_t p_addr;
+    p_addr.ip   = addr->ip;
+    p_addr.port = p->addr.port;
+    peer_addr_set(p,&p_addr,0);
+  }
+}
+
+//TODO: this func needs to become smaller or smth
+bool pest_recv(uint64_t time){
+  uint8_t       b           [BLACK_SIZE+1]; //+1 for detecting oversize
+  char          speaker     [HANDLE_BUF];
+  hash_t        hash;
+  uint8_t      *r;
+  uint8_t      *m;
+  uint8_t      *t;
+  size_t        n;
+  addr_t        addr;
+  uint8_t       bounces;
+  uint8_t       version;
+  uint8_t       command;
+  uint64_t      stamp;
+  peer_t       *p;
+  pkey_t       *pk;
+  char         *handle;
+  void         *h;
+  bool          immediate;
+  bool          gd;
+  peer_t       *gd_peer;
+  bool          ig;
+
+  //TMP xtrem spam test
+  //static int ass = 0;
+  ////if(irc_ready && ++ass > 1){
+  ////if(irc_ready && ++ass > 14){
+  //if(irc_ready && ++ass > 20){
+  ////if(irc_ready && ++ass > 40){
+    //char cunt[45];
+    //rng_read(cunt,sizeof(cunt));
+    //for(size_t x = 0;x < sizeof(cunt);x++){
+      //if(cunt[x] < 0x20 || cunt[x] > 0x7E) cunt[x] = '.';
+    //}
+    //cunt[sizeof(cunt)-1] = 0;
+    //pest_broadcast(cunt);
+    //ass = 0;
+  //}
+
+  n = udp_recv(&addr.ip,&addr.port,pest_port,b,sizeof(b));
+  if(!n) return 0;
+
+  //TMP xtrem shity conection test
+  //if(rand()%5 == 0) return 0;
+
+  if(n != BLACK_SIZE){
+    log_martian(&addr,1);
+    return 1;
+  }
+
+  if(!find_key(b,&p,&pk)){
+    log_martian(&addr,0);
+    return 1;
+  }
+
+  r = b+RED_OFF;
+  m = r+MESSAGE_OFF;
+  t = m+TEXT_OFF;
+
+  black_deciph(r,b,pk->ciph_serp);
+  hash_data(hash,m,MESSAGE_SIZE);
+  peer_pak_stamp(p,time);
+
+  read_u8   (r+BOUNCES_OFF,   &bounces);
+  read_u8   (r+VERSION_OFF,   &version);
+  read_u8   (r+COMMAND_OFF,   &command);
+  read_u64  (m+TIMESTAMP_OFF, &stamp);
+
+  handle = p->handle[0];
+
+  if(version > PEST_VERSION){
+    log_out("protocol version 0x%02X (current: 0x%02X) "
+            "packet rejected from peer '%s'",
+            version,PEST_VERSION,handle);
+    goto clear;
+  }
+
+  if(command >= CMD_UNDEF_MIN &&
+     command <= CMD_UNDEF_MAX){
+    irclog_err("unknown pest command (0x%02X) "
+               "received from peer '%s'",
+               command,handle);
+    goto clear;
+  }
+
+  ig = command == CMD_IGNORE;
+  if(ig &&
+     (!rekey_keyexists(&p->rekey) ||
+      !key_equal(pk->key.full,p->rekey.key_new))){
+    log_ignore(hash,command,p,&addr);
+    goto clear;
+  }
+
+  if(bounces > cutoff){
+    log_cutoff(hash,command,p,&addr,bounces);
+    goto clear;
+  }
+
+  //TODO: vtf do with netchain
+  gd = getdata_del(hash,&gd_peer);
+  if(gd){
+    //TMP, vat do with !gd_peer response?
+    assert(gd_peer);
+  }
+
+  //skip stamp stale check if expecting getdata or rekey ignore
+  if(!gd && !ig && stamp_stale(time,stamp)){
+    log_stale(hash,command,p,&addr,time,stamp);
+    goto clear;
+  }
+
+  if(!gd && command == CMD_BROADCAST){
+    h = hearsay_lookup(hash);
+  }else{
+    h = 0;
+  }
+
+  //dont dedup or push (cuz alredy in) if in hearsay buffer
+  if(!h){
+    //dont dedup if getdata response, in some extreme cases
+    //have to throw away packets and no good way to delete
+    //data from middle of dedup buffer. instead, make sure
+    //to never send getdata for message that exists somewhere
+    if(!gd && dedup_lookup(hash)){
+      log_dupe(hash,command,p,&addr);
+      goto clear;
+    }
+
+    if(!dedup_push(hash,time)){
+      log_dedup_full(hash,command,p,&addr);
+      goto clear;
+    }
+  }
+
+  cpy_speaker(speaker,sizeof(speaker),m);
+  immediate = peer_handle_lookup(p,speaker);
+
+  if(h){
+    if(immediate){
+      //replace hearsay with immediate version
+      hearsay_del(h);
+    }else{
+      //add peer to message already in hearsay buffer
+      hearsay_peer(h,p,bounces);
+      log_dupe(hash,command,p,&addr);
+      goto clear;
+    }
+  }
+
+  peer_stamp(p,time);
+  peer_key_stamp(p,pk,time);
+  at_update(p,&addr);
+
+  log_packet(hash,command,p,&addr,0,time,stamp);
+
+  //TODO: should this be handled only for BROADCAST/DIRECT? add to chain?
+  if(killfile_lookup(speaker)){
+    log_out("speaker '%s' in killfile, ignoring packet",speaker);
+    goto clear;
+  }
+
+  switch(command){
+  case CMD_BROADCAST:
+    broadcast_handle(p,gd ? gd_peer : 0,immediate,r,hash,bounces,speaker);
+    break;
+
+  case CMD_DIRECT:
+    direct_handle(p,gd ? gd_peer : 0,immediate,r,hash,bounces,speaker);
+    break;
+
+  case CMD_BANNER:
+    banner_handle(p,m);
+    break;
+
+  case CMD_GETDATA:
+    getdata_handle(p,t);
+    break;
+
+  case CMD_KEYOFFER:
+    rekey_handle_offer(p,t);
+    break;
+
+  case CMD_KEYSLICE:
+    rekey_handle_slice(p,t);
+    break;
+
+  case CMD_ADDRESSCAST:
+    addrcast_handle(t);
+    red_rebroadcast(r,hash,bounces);
+    break;
+
+  case CMD_IGNORE:
+    rekey_handle_ignore(p,pk,time);
+    break;
+
+  default:
+    assert(0);
+  }
+
+  rekey_handle_packet(p,pk);
+
+clear:
+  memset_ffs(r,0x00,RED_SIZE);
+  return 1;
+}
+
diff -uNr a/src/rekey.c b/src/rekey.c
--- a/src/rekey.c false
+++ b/src/rekey.c e23a864b5742bd972e12dc4c5881b89305c43691bd5bd1bc8736c56474aaa74e3df60e8e0a6c8d390994f70ad315fe7a832e5f83f1d3f32dd0ba2049d5c9da83
@@ -0,0 +1,366 @@
+#include "pest.h"
+#include "peer.h"
+#include "crypto.h"
+#include "packet.h"
+#include "log.h"
+#include "time.h"
+#include "util.h"
+#include "state.h"
+
+//TODO: retry on no response
+
+#define STATE_INACTIVE WAIT_OFFER1
+
+enum{
+  WAIT_OFFER1,
+  WAIT_OFFER2,
+  WAIT_SLICE1,
+  WAIT_SLICE2,
+  WAIT_IGNORE1,
+  WAIT_IGNORE2,
+  WAIT_PACKET,
+};
+
+bool rekey_active(rekey_t *rk){
+  return rk->state != STATE_INACTIVE;
+}
+
+bool rekey_keyexists(rekey_t *rk){
+  return rk->state == WAIT_IGNORE1 ||
+         rk->state == WAIT_IGNORE2 ||
+         rk->state == WAIT_PACKET;
+}
+
+static void rekey_abort(peer_t *p,char const *reason){
+  rekey_t  *rk  = &p->rekey;
+  log_f     err = rk->log ? irclog_err : log_err;
+
+  err("rekeying with peer '%s' aborted: %s",p->handle[0],reason); 
+  rekey_init(rk);
+}
+
+static bool keyoffer_send(peer_t *p){
+  rekey_t  *rk  = &p->rekey;
+
+  if(!key_gen(rk->slice_self)){
+    rekey_abort(p,"could not generate key slice");
+    return 0;
+  }
+  sha512(rk->offer_self,rk->slice_self,sizeof(rk->slice_self));
+
+  if(!send_text(CMD_KEYOFFER,
+                mono_sec(),
+                rk->offer_self,
+                sizeof(rk->offer_self),
+                p)){
+    rekey_abort(p,"could not send data");
+    return 0;
+  }
+
+  return 1;
+}
+
+static bool keyslice_send(peer_t *p){
+  rekey_t    *rk      = &p->rekey;
+
+  if(!send_text(CMD_KEYSLICE,
+                mono_sec(),
+                rk->slice_self,
+                sizeof(rk->slice_self),
+                p)){
+    rekey_abort(p,"could not send data");
+    return 0;
+  }
+
+  return 1;
+}
+
+static bool keyoffer_recv(peer_t *p,uint8_t const *offer){
+  rekey_t *rk = &p->rekey;
+
+  memcpy(rk->offer_peer,offer,sizeof(rk->offer_peer));
+
+  if(memcmp(rk->offer_peer,
+            rk->offer_self,
+            sizeof(rk->offer_peer)) == 0){
+    rekey_abort(p,"received key offer was "
+                  "identical to key offer sent");
+    return 0;
+  }
+
+  return 1;
+}
+
+static bool keyslice_recv(peer_t *p,uint8_t const *slice){
+  uint8_t   hash[SHA512_SIZE];
+  rekey_t  *rk = &p->rekey;
+  pkey_t   *pk;
+
+  key_copy(rk->slice_peer,slice);
+  sha512(hash,rk->slice_peer,sizeof(rk->slice_peer));
+
+  if(memcmp(hash,rk->offer_peer,sizeof(hash)) != 0){
+    BUF_ZERO(hash);
+    rekey_abort(p,"received key slice did not match key offer");
+    return 0;
+  }
+  BUF_ZERO(hash);
+
+  if(entropy_missing(rk->slice_peer,sizeof(rk->slice_peer))){
+    rekey_abort(p,"entropy obviously missing "
+                  "from received key slice");
+    return 0;
+  }
+
+  pk = peer_key_recent(p);
+  assert(pk);
+
+  key_copy(rk->key_old,pk->key.full);
+  key_xor(rk->key_new,rk->key_old,rk->slice_self);
+  key_xor(rk->key_new,rk->key_new,rk->slice_peer);
+
+  if(!peer_key_add(p,rk->key_new,1)){
+    rekey_abort(p,"could not add new key");
+    return 0;
+  }
+
+  return 1;
+}
+
+static pkey_t *rekey_pkey(peer_t *p){
+  rekey_t  *rk = &p->rekey;
+  pkey_t   *pk = peer_lookup_pkey(p,rk->key_new);
+  if(!pk){
+    rekey_abort(p,"new key has been deleted");
+    return 0;
+  }
+  return pk;
+}
+
+static bool rkignore_send(peer_t *p){
+  pkey_t *pk;
+
+  pk = rekey_pkey(p);
+  if(!pk) return 0;
+
+  return ignore_send(p,pk);
+}
+
+static bool rkignore_recv(peer_t *p,pkey_t *pk,uint64_t time){
+  peer_stamp(p,time);
+  peer_key_stamp(p,pk,time);
+  return 1;
+}
+
+static bool packet_recv(peer_t *p,pkey_t *pk){
+  rekey_t *rk = &p->rekey;
+
+  if(!key_equal(pk->key.full,rk->key_new)){
+    //TODO: delete key here or vat?
+    return 0;
+  }
+
+  rk->pak_cnt++;
+  if(rk->pak_cnt >= REKEY_PACKET_CNT){
+    peer_key_del(rk->key_old,1);
+    rekey_init(rk);
+  }
+
+  return 1;
+}
+
+static void rekey_complete(peer_t *p){
+  rekey_t *rk = &p->rekey;
+  rk->state   = WAIT_PACKET;
+  rk->pak_cnt = 0;
+  irclog_out("rekeying with peer '%s' successful",
+             p->handle[0]);   
+}
+
+static bool initiate(peer_t *p,bool log){
+  rekey_t  *rk  = &p->rekey;
+  log_f     err = log ? irclog_err : log_err;
+
+  if(!peer_cansend(p,log)) return 0;
+
+  if(rekey_active(rk)){
+    err("rekeying with peer '%s' already in progress",p->handle[0]);
+    return 0;
+  }
+
+  if(!keyoffer_send(p)) return 0;
+
+  rk->state   = WAIT_OFFER2;
+  rk->log     = log;
+  rk->time    = mono_sec();
+  rk->pak_cnt = 0;
+
+  return 1;
+}
+
+void rekey_initiate(peer_t *p,bool log){
+  log_f out = log ? irclog_out : log_out;
+
+  if(p){
+    initiate(p,log);
+    out("rekeying with peer '%s' initiated",p->handle[0]);
+  }else{
+    uint16_t peer_idx[peer_cnt];
+
+    if(!index_shuffle(peer_idx,peer_cnt)){
+      irclog_err("could not shuffle index, "
+                 "rekeying cannot be initiated");
+      return;
+    }
+
+    for(size_t x = 0;x < peer_cnt;x++){
+      peer_t *q = peer+peer_idx[x];
+      if(!peer_cansend(q,0))      continue;
+      if(rekey_active(&q->rekey)) continue;
+      initiate(q,log);
+    }
+
+    out("rekeying with all peers initiated");
+  }
+}
+
+void rekey_init(rekey_t *rk){
+  rk->state     = STATE_INACTIVE;
+  rk->log       = 0;
+  rk->time      = 0;
+  rk->pak_cnt   = 0;
+
+  BUF_ZERO(rk->offer_self);
+  BUF_ZERO(rk->offer_peer);
+  BUF_ZERO(rk->slice_self);
+  BUF_ZERO(rk->slice_peer);
+  BUF_ZERO(rk->key_old);
+  BUF_ZERO(rk->key_new);
+}
+
+bool rekey_handle_offer(peer_t *p,uint8_t const *offer){
+  rekey_t *rk = &p->rekey;
+  if(!peer_cansend(p,rk->log)) return 0;
+
+  switch(rk->state){
+  case WAIT_OFFER1:
+    if(!rkrecv)                   return 1;
+    if(!peer_cansend(p,rk->log))  return 0;
+    if(!keyoffer_recv(p,offer))   return 0;
+    if(!keyoffer_send(p))         return 0;
+
+    rk->state   = WAIT_SLICE1;
+    rk->log     = 0;
+    rk->time    = mono_sec();
+    rk->pak_cnt = 0;
+    return 1;
+
+  case WAIT_OFFER2:
+    if(!peer_cansend(p,rk->log))  return 0;
+    if(!keyoffer_recv(p,offer))   return 0;
+    if(!keyslice_send(p))         return 0;
+
+    rk->state = WAIT_SLICE2;
+    return 1;
+
+  default:
+    rekey_abort(p,"invalid sequence");
+    return 0;
+  }
+}
+
+bool rekey_handle_slice(peer_t *p,uint8_t const *slice){
+  rekey_t *rk = &p->rekey;
+
+  switch(rk->state){
+  case STATE_INACTIVE:
+    return 0;
+
+  case WAIT_SLICE1:
+    if(!peer_cansend(p,rk->log))  return 0;
+    if(!keyslice_recv(p,slice))   return 0;
+    if(!keyslice_send(p))         return 0;
+    rk->state = WAIT_IGNORE1;
+    return 1;
+
+  case WAIT_SLICE2:
+    if(!peer_cansend(p,rk->log))  return 0;
+    if(!keyslice_recv(p,slice))   return 0;
+    if(!rkignore_send(p))         return 0;
+    rk->state = WAIT_IGNORE2;
+    return 1;
+
+  default:
+    rekey_abort(p,"invalid sequence");
+    return 0;
+  }
+}
+
+bool rekey_handle_ignore(peer_t *p,pkey_t *pk,uint64_t time){
+  rekey_t *rk = &p->rekey;
+
+  switch(rk->state){
+  case STATE_INACTIVE:
+    return 0;
+
+  case WAIT_IGNORE1:
+    if(!peer_cansend(p,rk->log))  return 0;
+    if(!rkignore_recv(p,pk,time)) return 0;
+    if(!rkignore_send(p))         return 0;
+    rekey_complete(p);
+    return 1;
+
+  case WAIT_IGNORE2:
+    if(!peer_cansend(p,rk->log))  return 0;
+    if(!rkignore_recv(p,pk,time)) return 0;
+    rekey_complete(p);
+    return 1;
+
+  default:
+    return 0;
+  }
+}
+
+bool rekey_handle_packet(peer_t *p,pkey_t *pk){
+  rekey_t *rk = &p->rekey;
+
+  switch(rk->state){
+  case STATE_INACTIVE:
+    return 0;
+
+  case WAIT_PACKET:
+    if(!peer_cansend(p,rk->log)) return 0;
+    if(!packet_recv(p,pk))       return 0;
+    return 1;
+
+  default:
+    return 0;
+  }
+}
+
+void rekey_broadcast(uint64_t time){
+  if(time < rekey_last+rkint*SEC_HOUR) return;
+  if(rksend && rekey_last != 0){
+    rekey_initiate(0,0);
+  }
+  rekey_last = time;
+}
+
+void rekey_clean(uint64_t time){
+  for(size_t x = 0;x < peer_cnt;x++){
+    peer_t   *p   = peer+x;
+    rekey_t  *rk  = &p->rekey;
+    log_f     out = rk->log ? irclog_out : log_out;
+
+    if(!rekey_active(rk))         continue;
+    if(time < rk->time+rktime)    continue;
+    if(rk->state == WAIT_PACKET)  continue;
+
+    if(rekey_keyexists(rk)){
+      peer_key_del(rk->key_new,1);
+    }
+    rekey_init(rk);
+    out("rekeying with peer '%s' timed out",p->handle[0]);
+  }
+}
+
diff -uNr a/src/rng.c b/src/rng.c
--- a/src/rng.c false
+++ b/src/rng.c e8d59c906b888a13d3fdeb93699ab91204c96430d38195c89dcc517f708cb9dc40fb2f9e661682261cdf2a718ac6e22fcb2a29511526ffef0f8ced10b404831e
@@ -0,0 +1,67 @@
+#include "crypto.h"
+#include "log.h"
+#include "state.h"
+#include <unistd.h>
+#include <fcntl.h>
+#include <string.h>
+#include <assert.h>
+
+#define RNG_BORKTEST_SIZE             256
+
+bool rng_open(char const *path){
+  uint8_t bork[RNG_BORKTEST_SIZE];
+
+  rng_fd = open(path,O_RDONLY);
+  if(rng_fd == -1){
+    log_errno("open");
+    irclog_err("could not open rng '%s'",path);
+    return 0;
+  }
+
+  if(!rng_read(bork,sizeof(bork))){
+    close(rng_fd);
+    return 0;
+  }
+
+  if(entropy_missing(bork,sizeof(bork))){
+    irclog_err("rng '%s' is borken, all bytes were 0x%02X",
+               path,bork[0]);
+    close(rng_fd);
+    return 0;
+  }
+
+  return 1;
+}
+
+void rng_close(void){
+  close(rng_fd);
+  rng_fd = -1;
+}
+
+static ssize_t _rng_read(void *data,size_t size){
+  memset_ffs(data,0x00,size);
+  return read(rng_fd,data,size);
+}
+
+bool rng_read(void *data,size_t size){
+  ssize_t r = _rng_read(data,size);
+  if(r != (ssize_t)size){
+    if(r == -1) log_errno("read");
+    irclog_err("could not read %zu bytes from rng",size);
+    return 0;
+  }
+  return 1;
+}
+
+bool rng_read_nolog(void *data,size_t size){
+  return _rng_read(data,size) == (ssize_t)size;
+}
+
+bool entropy_missing(uint8_t const *data,size_t size){
+  uint8_t first = data[0];
+  for(size_t x = 1;x < size;x++){
+    if(data[x] != first) return 0;
+  }
+  return 1;
+}
+
diff -uNr a/src/send.c b/src/send.c
--- a/src/send.c false
+++ b/src/send.c d96aa0f12d8e1b426819faef138d466f78e612eb81a202d537f927e6b76c92f58b7efba0ead1f6a8552848b0a5050854e8a7159ae6a2f44f3457e78c320066a5
@@ -0,0 +1,236 @@
+#include "packet.h"
+#include "pest.h"
+#include "peer.h"
+#include "chain.h"
+#include "log.h"
+#include "net.h"
+#include "crypto.h"
+#include "io.h"
+#include "serial.h"
+#include "time.h"
+#include "util.h"
+#include "type.h"
+#include "state.h"
+#include "config.h"
+
+static bool red_send(uint8_t *r,
+                     peer_t  *p,
+                     pkey_t  *pk){
+
+  uint8_t b[BLACK_SIZE];
+
+  if(!peer_cansend(p,0)){
+    return 1;
+  }
+
+  if(!rng_read(r+NONCE_OFF,NONCE_SIZE)){
+    return 0;
+  }
+
+  if(pk){
+  #ifndef NDEBUG
+    peer_t *q;
+    assert(pkey_lookup_noerr(pk->key.full,&q));
+    assert(q == p);
+  #endif
+  }else{
+    pk = peer_key_recent(p);
+    assert(pk);
+  }
+
+  black_ciph(b,r,pk->ciph_serp);
+  black_sign(b,pk->key.sub.sign);
+
+  if(udp_send(p->addr.ip,p->addr.port,b,sizeof(b)) != sizeof(b)){
+    irclog_err("failed to send UDP packet to peer '%s'",p->handle[0]);
+    return 0;
+  }
+
+  return 1;
+}
+
+static bool red_send_many(uint8_t      *r,
+                          hash_t const  hash,
+                          peer_t       *chan,
+                          pkey_t       *pk){
+
+  peer_t   *p       = chan ? chan : peer;
+  size_t    p_cnt   = chan ?  1 : peer_cnt;
+  uint16_t  peer_idx[p_cnt];
+  bool      ret;
+  uint8_t   command;
+
+  assert(!pk || chan);
+
+  if(p_cnt == 1){
+    peer_idx[0] = 0;
+  }else if(!index_shuffle(peer_idx,p_cnt)){
+    irclog_err("could not shuffle index, "
+               "message cannot be sent");
+    return 0;
+  }
+
+  read_u8(r+COMMAND_OFF,&command);
+
+  ret = 1;
+  for(size_t x = 0;x < p_cnt;x++){
+    peer_t *q = p+peer_idx[x];
+    if(!red_send(r,q,pk)) ret = 0;
+#ifndef LOG_COLLAPSE
+    log_packet(hash,command,q,&q->addr,1,0,0);
+#endif
+  }
+
+#ifdef LOG_COLLAPSE
+  log_packet(hash,command,chan,chan ? &chan->addr : 0,1,0,0);
+#endif
+
+  memset_ffs(r,0x00,RED_SIZE);
+  return ret;
+}
+
+bool red_rebroadcast(uint8_t *r,hash_t const hash,uint8_t bounces){
+  if(bounces >= BOUNCES_MAX) return 1;
+  bounces++;
+  write_u8(r+BOUNCES_OFF,&bounces);
+  return red_send_many(r,hash,0,0);
+}
+
+bool send_message(uint8_t   command,
+                  uint8_t  *r,
+                  hash_t    hash,
+                  peer_t   *chan,
+                  pkey_t   *pk){
+
+  uint8_t     bounces;
+  uint8_t     version;
+  uint8_t     reserved;
+
+  assert(!pk || chan);
+
+  bounces   = 0;
+  version   = PEST_VERSION;
+  reserved  = 0;
+
+  write_u8  (r+BOUNCES_OFF,   &bounces);
+  write_u8  (r+VERSION_OFF,   &version);
+  write_u8  (r+RESERVED_OFF,  &reserved);
+  write_u8  (r+COMMAND_OFF,   &command);
+
+  return red_send_many(r,hash,chan,pk);
+}
+
+static void set_hash(hash_t        *dst,
+                     hash_t const   src,
+                     peer_t        *p,
+                     char const    *file){
+
+  char path[PATH_BUF];
+  if(p){
+    FMT_PATH(path,DIR_PEER"/%s/"DIR_DCHAIN"/%s",p->handle[0],file);
+  }else{
+    FMT_PATH(path,DIR_CHAIN"/%s",file);
+  }
+  hash_copy(*dst,src);
+  if(!hash_store(path,(hash_t const *)dst,1)){
+    disk_unsync();
+  }
+}
+
+bool send_text(uint8_t        command,
+               uint64_t       stamp,
+               uint8_t const *text,
+               size_t         text_size,
+               peer_t        *chan){
+
+  uint8_t     r[RED_SIZE];
+  uint8_t    *m;
+  hash_t      hash;
+
+  m = r+MESSAGE_OFF;
+  write_u64(m+TIMESTAMP_OFF,&stamp);
+
+  strncpy((char *)m+SPEAKER_OFF,self_handle,SPEAKER_SIZE);
+
+  assert(text_size <= TEXT_SIZE);
+  memcpy(m+TEXT_OFF,text,text_size);
+  memset(m+TEXT_OFF+text_size,0x00,TEXT_SIZE-text_size);
+
+  switch(command){
+  case CMD_BROADCAST:
+    hash_copy(m+SELFCHAIN_OFF,self);
+    hash_copy(m+NETCHAIN_OFF,net);
+    break;
+
+  case CMD_DIRECT:
+    assert(chan);
+    hash_copy(m+SELFCHAIN_OFF,chan->self);
+    hash_zero(m+NETCHAIN_OFF);
+    break;
+
+  default:
+    hash_zero(m+SELFCHAIN_OFF);
+    hash_zero(m+NETCHAIN_OFF);
+  }
+
+  hash_data(hash,m,MESSAGE_SIZE);
+
+  switch(command){
+  case CMD_BROADCAST:
+    set_hash(&self,hash,0,FILE_SELF);
+    set_hash(&net, hash,0,FILE_NET);
+    mess_push(&mess,hash,m);
+    dedup_push(hash,stamp);
+    break;
+
+  case CMD_DIRECT:
+    assert(chan);
+    set_hash(&chan->self,hash,chan,FILE_SELF);
+    mess_push(&chan->mess,hash,m);
+    dedup_push(hash,stamp);
+    break;
+  }
+
+  return send_message(command,r,hash,chan,0);
+}
+
+bool send_str(uint8_t cmd,char const *str,peer_t *chan){
+  char const *str_orig;
+  uint64_t    stamp;
+  size_t      str_len;
+  bool        ret;
+
+  ret       = 1;
+  str_orig  = str;
+  str_len   = strlen(str);
+  stamp     = mono_sec();
+
+  do{
+    size_t text_len = str_len;
+    if(text_len > TEXT_SIZE){
+      text_len = TEXT_SIZE;
+    }
+
+    if(!send_text(cmd,
+                  stamp,
+                  (uint8_t const *)str,
+                  text_len,
+                  chan)){
+      ret = 0;
+    }
+
+    str     += text_len;
+    str_len -= text_len;
+  }while(str_len > 0);
+
+  if(!ret){
+    irclog_err("pest message (%.10s...) "
+               "was not sent to all peers",
+               str_orig);
+  }
+
+  console_stamp(chan,stamp);
+
+  return ret;
+}
+
diff -uNr a/src/serial.c b/src/serial.c
--- a/src/serial.c false
+++ b/src/serial.c 4304ebe227116f3f45449596fd99f7a86e83bb0eef20b1bc2b036f480e3d748704a1e15e27bcfc5ef0710829b569cf27caa76fa2ca246a621a7d29b81e8b9f5a
@@ -0,0 +1,18 @@
+#include "serial.h"
+
+#define __EXTERN_READWRITE(NAME_PFIX,TYPE,WIDTH)\
+  extern void read_##NAME_PFIX##WIDTH (uint8_t const *buf,TYPE       *data);\
+  extern void write_##NAME_PFIX##WIDTH(uint8_t       *buf,TYPE const *data);
+
+#define _EXTERN_READWRITE(WIDTH)\
+  __EXTERN_READWRITE(u,uint##WIDTH##_t,WIDTH)\
+
+_EXTERN_READWRITE(8)
+_EXTERN_READWRITE(16)
+_EXTERN_READWRITE(32)
+_EXTERN_READWRITE(64)
+
+extern uint16_t     byteswap16(uint16_t n);
+extern uint32_t     byteswap32(uint32_t n);
+extern uint64_t     byteswap64(uint64_t n);
+
diff -uNr a/src/serial.h b/src/serial.h
--- a/src/serial.h false
+++ b/src/serial.h ae9f3112613fc53c8bf76c8d18425dfa4d7aa61623ccbd0b9263d0ca19aa2679fc64150a11ef2362fb1ca11dd5273acb717f38064cdfc155caa623a1bd5c7f0c
@@ -0,0 +1,86 @@
+#ifndef SERIAL_H
+#define SERIAL_H
+
+#include <stdint.h>
+#include <string.h>
+
+#define host8le           (uint8_t)
+#ifdef BIGENDIAN
+  #define host16le        byteswap16
+  #define host32le        byteswap32
+  #define host64le        byteswap64
+#else
+  #define host16le        (uint16_t)
+  #define host32le        (uint32_t)
+  #define host64le        (uint64_t)
+#endif
+
+#define __DEF_READ(NAME_PFIX,TYPE,WIDTH)\
+  inline void read_##NAME_PFIX##WIDTH(uint8_t const *buf,TYPE *data);\
+  inline void read_##NAME_PFIX##WIDTH(uint8_t const *buf,TYPE *data){\
+    TYPE tmp;\
+    memcpy(&tmp,buf,sizeof(TYPE));\
+    *data = host##WIDTH##le(tmp);\
+  }
+
+#define __DEF_WRITE(NAME_PFIX,TYPE,WIDTH)\
+  inline void write_##NAME_PFIX##WIDTH(uint8_t *buf,TYPE const *data);\
+  inline void write_##NAME_PFIX##WIDTH(uint8_t *buf,TYPE const *data){\
+    TYPE tmp;\
+    tmp = host##WIDTH##le(*data);\
+    memcpy(buf,&tmp,sizeof(TYPE));\
+  }
+
+#define _DEF_READWRITE(WIDTH)\
+  __DEF_READ  (u,uint##WIDTH##_t,WIDTH)\
+  __DEF_WRITE (u,uint##WIDTH##_t,WIDTH)\
+
+_DEF_READWRITE(8)
+_DEF_READWRITE(16)
+_DEF_READWRITE(32)
+_DEF_READWRITE(64)
+
+#undef __DEF_READ
+#undef __DEF_WRITE
+#undef _DEF_READWRITE
+
+inline uint16_t     byteswap16(uint16_t n);
+inline uint32_t     byteswap32(uint32_t n);
+inline uint64_t     byteswap64(uint64_t n);
+
+inline uint16_t byteswap16(uint16_t n){
+#ifdef __GNUC__
+  return __builtin_bswap16(n);
+#else
+  return n>>8 | n<<8;
+#endif
+}
+
+inline uint32_t byteswap32(uint32_t n){
+#ifdef __GNUC__
+  return __builtin_bswap32(n);
+#else
+  return (n              ) >> 24 |
+         (n & 0x00FF0000u) >>  8 | 
+         (n & 0x0000FF00u) <<  8 | 
+         (n              ) << 24;
+#endif
+}
+
+inline uint64_t byteswap64(uint64_t n){
+#ifdef __GNUC__
+  return __builtin_bswap64(n);
+#else
+  return (n                        ) >> 56 |
+         (n & 0x00FF000000000000ull) >> 40 | 
+         (n & 0x0000FF0000000000ull) >> 24 | 
+         (n & 0x000000FF00000000ull) >>  8 | 
+         (n & 0x00000000FF000000ull) <<  8 | 
+         (n & 0x0000000000FF0000ull) << 24 | 
+         (n & 0x000000000000FF00ull) << 40 | 
+         (n                        ) << 56;
+#endif
+}
+
+#endif
+
diff -uNr a/src/serpent.c b/src/serpent.c
--- a/src/serpent.c false
+++ b/src/serpent.c 4c5290e5241430dfd5e5d7acdc3d494a16be2de41af3031a8677cf72e3dbf8fcc8f992170cea8513c08726227b0e5e8675be402e80c0b40864ea3ea317359868
@@ -0,0 +1,71 @@
+#include "crypto.h"
+#include "otherpplgode/serpent.h"
+#include <string.h>
+#include <assert.h>
+
+void serpent_init(uint8_t        *skey,
+                  uint8_t const  *key,
+                  size_t          key_size){
+
+  int r = serpent_setkey((void *)skey,key,key_size);
+  assert(r); (void)r;
+}
+
+static inline void xor_block(uint8_t       *r,
+                             uint8_t const *a,
+                             uint8_t const *b){
+
+  for(size_t x = 0;x < SERPENT_BLOCK_SIZE;x++){
+    r[x] = a[x]^b[x];
+  }
+}
+
+void serpent_cbc_ciph(uint8_t const  *skey,
+                      uint8_t        *dst,
+                      uint8_t const  *src,
+                      size_t          size){
+
+  uint8_t tmp[SERPENT_BLOCK_SIZE]; 
+  size_t  block_cnt;
+
+  assert(size%SERPENT_BLOCK_SIZE == 0);
+  block_cnt = size/SERPENT_BLOCK_SIZE;
+  memset(tmp,0x00,SERPENT_BLOCK_SIZE);
+
+  for(size_t x = 0;x < block_cnt;x++){
+    size_t off = x*SERPENT_BLOCK_SIZE;
+    xor_block(tmp,src+off,tmp); 
+    serpent_block_enc((void const *)skey,dst+off,tmp);
+    memcpy(tmp,dst+off,SERPENT_BLOCK_SIZE);
+  }
+}
+
+void serpent_cbc_deciph(uint8_t const  *skey,
+                        uint8_t        *dst,
+                        uint8_t const  *src,
+                        size_t          size){
+
+  uint8_t  _tmp1[SERPENT_BLOCK_SIZE]; 
+  uint8_t  _tmp2[SERPENT_BLOCK_SIZE]; 
+  uint8_t  *tmp1 = _tmp1;
+  uint8_t  *tmp2 = _tmp2;
+  uint8_t  *tmp3;
+  size_t    block_cnt;
+
+  assert(size%SERPENT_BLOCK_SIZE == 0);
+  block_cnt = size/SERPENT_BLOCK_SIZE;
+  memset(tmp2,0x00,SERPENT_BLOCK_SIZE);
+
+  for(size_t x = 0;x < block_cnt;x++){
+    size_t off = x*SERPENT_BLOCK_SIZE;
+
+    memcpy(tmp1,src+off,SERPENT_BLOCK_SIZE);
+    serpent_block_dec((void const *)skey,dst+off,src+off);
+    xor_block(dst+off,src+off,tmp2);
+
+    tmp3 = tmp1;
+    tmp1 = tmp2;
+    tmp2 = tmp3;
+  }
+}
+
diff -uNr a/src/sha.c b/src/sha.c
--- a/src/sha.c false
+++ b/src/sha.c 9be502a88358aee254f755d25ff1d2a732db0ef5bd98ac5d5071ccc4d04744e4cc2cdd496dd7b7668fef900b48f70dab5b959db34900a0cd426b4abf2d30939c
@@ -0,0 +1,28 @@
+#include "crypto.h"
+#include "otherpplgode/sha.h"
+#include <string.h>
+
+void sha256(uint8_t *sha,uint8_t const *msg,size_t msg_len){
+  sha256_ctx ctx;
+  sha256_init(&ctx);
+  sha256_update(&ctx,msg,msg_len);
+  sha256_final(&ctx,sha);
+  VAR_ZERO(ctx);
+}
+
+void sha384(uint8_t *sha,uint8_t const *msg,size_t msg_len){
+  sha384_ctx ctx;
+  sha384_init(&ctx);
+  sha384_update(&ctx,msg,msg_len);
+  sha384_final(&ctx,sha);
+  VAR_ZERO(ctx);
+}
+
+void sha512(uint8_t *sha,uint8_t const *msg,size_t msg_len){
+  sha512_ctx ctx;
+  sha512_init(&ctx);
+  sha512_update(&ctx,msg,msg_len);
+  sha512_final(&ctx,sha);
+  VAR_ZERO(ctx);
+}
+
