+++ b/src/ircd.h 54388690539166f09facba1462c8a7bf04fa8230f2aaf2d5df977a90163480d5321a3930c471241c4da247fea37ba84928317ec2dab38eb50ad5c717b6d731ab
@@ -0,0 +1,23 @@
+#ifndef IRCD_H
+#define IRCD_H
+
+#include "type.h"
+#include <stddef.h>
+#include <stdint.h>
