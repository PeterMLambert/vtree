+#include <stdarg.h>
+
+void                ircd_init   (ircev_f func);
+void                ircd_exit   (void);
+void                ircd_ckill  (void);
+
+void                ircd_tick   (void);
+
+size_t              ircd_send   (char const *msg);
+size_t              ircd_sendf  (char const *fmt,...);
+size_t              ircd_vsendf (char const *fmt,va_list args);
+
+uint32_t            ircd_getip  (void);
+
+#endif
+
diff -uNr a/src/irclog.c b/src/irclog.c
--- a/src/irclog.c false
+++ b/src/irclog.c 644bec1fb7fe784192c2cc1270fe6cf4b44e6ab657bd9c9328b52dbf4b7219c659ad5a36a47559047903ce1d41246548863daac23d6d766b66e0a99062a19fac
@@ -0,0 +1,98 @@
+#include "log.h"
+#include "crypto.h"
+#include "def.h"
+#include "ircd.h"
+#include "string.h"
+#include "state.h"
+#include <stdbool.h>
+#include <string.h>
+#include <stdio.h>
+
+static void _irc_vnotice(char const  *chan,
+                         char const  *pre,
+                         char const  *fmt,
+                         va_list      args){
+
+  char    buf[IRC_MSG_BUF];
+  char   *b = buf;
+  char   *e = buf+sizeof(buf);
+
+  if(!irc_ready) return;
+
+  if(!chan){
+#ifdef NOTICE_CHAN
+    chan = irc_chan;
+    if(!*chan) chan = self_handle;
+#else
+    chan = self_handle;
+#endif
+  }
+
+  //TODO: notice to irc_chan knob ??
+  b += snprintf(b,e-b,":%s NOTICE %s :%s",IRC_SERV,chan,pre);
+  b += vsnprintf(b,e-b,fmt,args);
+  b  = strpcpy(b,"\r\n",e);
+  ircd_send(buf);
+  memset_ffs(buf,0x00,b-buf);
+}
+
+void irc_out(char const *fmt,...){
+  va_list args;
+  va_start(args,fmt);
+  _irc_vnotice(0,"",fmt,args);
+  va_end(args);
+}
+
+void irc_err(char const *fmt,...){
+  va_list args;
+  va_start(args,fmt);
+  _irc_vnotice(0,"error: ",fmt,args);
+  va_end(args);
+}
+
+void irclog_out(char const *fmt,...){
+  va_list args;
+  va_list args2;
+  va_start(args,fmt);
+  va_copy(args2,args);
+  log_vout(fmt,args);
+  _irc_vnotice(0,"",fmt,args2);
+  va_end(args);
+  va_end(args2);
+}
+
+void irclog_err(char const *fmt,...){
+  va_list args;
+  va_list args2;
+  va_start(args,fmt);
+  va_copy(args2,args);
+  log_verr(fmt,args);
+  _irc_vnotice(0,"error: ",fmt,args2);
+  va_end(args);
+  va_end(args2);
+}
+
+//cunt
+void irclog_out_chan(char const *chan,char const *fmt,...){
+  va_list args;
+  va_list args2;
+  va_start(args,fmt);
+  va_copy(args2,args);
+  log_vout(fmt,args);
+  _irc_vnotice(chan,"",fmt,args2);
+  va_end(args);
+  va_end(args2);
+}
+
+//cunt
+void irclog_err_chan(char const *chan,char const *fmt,...){
+  va_list args;
+  va_list args2;
+  va_start(args,fmt);
+  va_copy(args2,args);
+  log_verr(fmt,args);
+  _irc_vnotice(chan,"error: ",fmt,args2);
+  va_end(args);
+  va_end(args2);
+}
+
diff -uNr a/src/key.c b/src/key.c
--- a/src/key.c false
+++ b/src/key.c 4dd5c2b70a6bc7b3b2be1537fcd7e179020e6bda8f6c2df37bf9b05d045af9a868584f973769d58941e64f7c81d207d2d7620b34c37bd6363b873615f641f2be
@@ -0,0 +1,55 @@
+#include "crypto.h"
+#include "spec.h"
+#include "string.h"
+#include "def.h"
+#include "log.h"
+#include <assert.h>
+
+bool key_gen(uint8_t *key){
+  if(!rng_read(key,KEY_SIZE)){
+    return 0;
+  }
+
+  if(entropy_missing(key,KEY_SIZE)){
+    irclog_err("could not generate key, rng borken");
+    return 0;
+  }
+
+  return 1;
+}
+
+void b64_from_key(char *buf,size_t buf_size,uint8_t const *key){
+  size_t n = base64_enc(key,KEY_SIZE,buf,buf_size);
+  assert(n == BASE64_ENC_SIZE(KEY_SIZE,1)); (void)n;
+}
+
+bool key_from_b64(uint8_t *key,char const *b64_key){
+  size_t n;
+
+  if(!str_valid(b64_key,B64_KEY_LEN,B64_KEY_LEN,BASE64_CHARSET)){
+    return 0;
+  }
+
+  n = base64_dec(b64_key,key,KEY_SIZE,0);
+  assert(n == KEY_SIZE); (void)n;
+  return 1;
+}
+
+void key_zero(uint8_t *key){
+  memset_ffs(key,0x00,KEY_SIZE);
+}
+
+void key_copy(uint8_t *dst,uint8_t const *src){
+  memcpy(dst,src,KEY_SIZE);
+}
+
+void key_xor(uint8_t *dst,uint8_t const *a,uint8_t const *b){
+  for(size_t x = 0;x < KEY_SIZE;x++){
+    dst[x] = a[x]^b[x];
+  }
+}
+
+bool key_equal(uint8_t const *a,uint8_t const *b){
+  return memcmp(a,b,KEY_SIZE) == 0;
+}
+
diff -uNr a/src/killfile.c b/src/killfile.c
--- a/src/killfile.c false
+++ b/src/killfile.c ac43ab4baa783948ff151c0434a101e59bd0662b0c5528f744adf82086acba2ee76ac8c3f84d9b357683403fb348de06d6184b8c3c0a9e33db276293d3ebb66b
@@ -0,0 +1,147 @@
+#include "data.h"
+#include "state.h"
+#include "io.h"
+#include "log.h"
+#include "util.h"
+#include "string.h"
+#include <stdio.h>
+#include <string.h>
+
+static bool killfile_add_internal(char const *handle,bool boot){
+  log_f   out = boot ? log_void : irclog_out;
+  log_f   err = boot ? log_err  : irc_err;
+
+  if(killfile_cnt >= KILLFILE_MAX){
+    err("max kills reached");
+    return 0;
+  }
+
+  if(!handle_valid(handle)){
+    err("invalid handle: '%s'",handle);
+    return 0;
+  }
+
+  if(killfile_lookup(handle)){
+    err("handle '%s' already exists in killfile",handle);
+    return 0;
+  }
+
+  strzcpy(killfile[killfile_cnt],handle,sizeof(killfile[killfile_cnt]));
+  killfile_cnt++;
+
+  if(!boot) killfile_store();
+
+  out("handle '%s' added to killfile",handle);
+  return 1;
+}
+
+bool killfile_add(char const *handle){
+  return killfile_add_internal(handle,0);
+}
+
+bool killfile_del(char const *handle){
+  handle_t *h;
+
+  if(!handle_valid(handle)){
+    irc_err("invalid handle: '%s'",handle);
+    return 0;
+  }
+
+  h = killfile_lookup(handle);
+  if(!h){
+    irc_err("handle '%s' not found in killfile",handle);
+    return 0;
+  }
+
+  ARR_DEL(killfile,killfile_cnt,h);
+  killfile_cnt--;
+  killfile_store();
+  irclog_out("handle '%s' deleted from killfile",handle);
+  return 1;
+}
+
+handle_t *killfile_lookup(char const *handle){
+  for(size_t x = 0;x < killfile_cnt;x++){
+    handle_t *h = killfile+x;
+    if(strncmp(*h,handle,HANDLE_LEN) == 0) return h;
+  }
+  return 0;
+}
+
+void killfile_print(void){
+  if(killfile_cnt == 0){
+    irc_out("killfile is empty");
+    return;
+  }
+  irc_out("--- BEGIN KILLFILE ---");
+  for(size_t x = 0;x < killfile_cnt;x++){
+    irc_out("%s",killfile+x);
+  }
+  irc_out("--- END KILLFILE ---");
+}
+
+bool killfile_load(void){
+  char    path[PATH_BUF];
+  FILE   *f;
+  char    buf[HANDLE_BUF+1+1]; //\n+1 for detecting invalid handle
+  char   *b;
+
+  FMT_PATH(path,"%s",FILE_KILLFILE);
+  if(!file_exists(path)) return 1;
+  f = file_open(path,"rb");
+  if(!f) return 0;
+
+  while(file_gets(f,buf,sizeof(buf))){
+    b = str_trim(buf);
+    if(!*b) continue;
+
+    if(!killfile_add_internal(b,1)){
+      file_close(f);
+      return 0;
+    }
+  }
+
+  if(ferror(f)){
+    file_close(f);
+    return 0;
+  }
+
+  file_close(f);
+  disk_read(path);
+  return 1;
+}
+
+bool killfile_store(void){
+  char  path[PATH_BUF];
+  FILE *f;
+
+  FMT_PATH(path,"%s",FILE_KILLFILE);
+  if(killfile_cnt == 0){
+    if(!file_delete(path)){
+      disk_unsync();
+      return 0;
+    }
+    return 1;
+  }
+  f = file_open(path,"wb");
+  if(!f){
+    disk_unsync();
+    return 0;
+  }
+
+  for(size_t x = 0;x < killfile_cnt;x++){
+    if(!file_printf(f,"%s\n",killfile[x])){
+      file_close(f);
+      disk_unsync();
+      return 0;
+    }
+  }
+
+  if(!file_close(f)){
+    disk_unsync();
+    return 0;
+  }
+  disk_written(path);
+  return 1;
+}
+
diff -uNr a/src/knob.c b/src/knob.c
--- a/src/knob.c false
+++ b/src/knob.c be744fc5044b7007b2deadada7aa49196eec1df7038d27bfcd64b733af4527a5f15426c466f604ac0c9945d8dbce9afd759335b7f68885a9655b5b491566a83a
@@ -0,0 +1,357 @@
+#include "pest.h"
+#include "spec.h"
+#include "log.h"
+#include "io.h"
+#include "string.h"
+#include "def.h"
+#include "state.h"
+#include <stdio.h>
+#include <string.h>
+#include <stdlib.h>
+
+#include "knobs.h"
+
+#define KNOBINFO(N,S) irc_out("%-7s = %s",N,S);
+
+static char const *knobtype_name[] = {
+  [KNOB_BOOL]   = "bool",
+  [KNOB_INT]    = "int",
+  [KNOB_STR]    = "str",
+};
+
+static knob_t const *knob_lookup(char const *name){
+  for(size_t x = 0;x < ARR_CNT(knob);x++){
+    knob_t const *k = knob+x;
+    if(strcmpci(k->name,name) == 0) return k;
+  }
+  irc_err("knob '%s' does not exist",name);
+  return 0;
+}
+
+static void strval_bool(char *buf,size_t buf_size,bool const *data){
+  snprintf(buf,buf_size,"%d",*data);
+}
+
+static void strval_int(char *buf,size_t buf_size,int64_t const *data){
+  snprintf(buf,buf_size,"%ld",*data);
+}
+
+static void strval_str(char *buf,size_t buf_size,char const *const *data){
+  strzcpy_quote(buf,*data,buf_size);
+}
+
+static unsigned setval_bool(knob_t const *k,char const *val){
+  bool *data = k->data;
+
+  if(!val){
+    *data = k->def.b;
+    return KNOB_SUCCESS;
+  }
+
+  if(val[0] == 0 || val[1] != 0){
+    return KNOB_INVALID;
+  }
+
+  switch(val[0]){
+  case '0': *data = 0;  return KNOB_SUCCESS;
+  case '1': *data = 1;  return KNOB_SUCCESS;
+  default:              return KNOB_INVALID;
+  }
+}
+
+static bool char_num(char c){
+  return c >= '0' && c <= '9';
+}
+
+static bool char_sign(char c){
+  return c == '+' || c == '-';
+}
+
+static unsigned setval_int(knob_t const *k,char const *val){
+  int64_t  *data = k->data;
+  int64_t   v;
+
+  if(!val){
+    *data = k->def.i;
+    return KNOB_SUCCESS;
+  }
+
+  if(!char_num(val[0]) && !char_sign(val[0])){
+    return KNOB_INVALID;
+  }
+
+  for(char const *c = val+1;*c;c++){
+    if(!char_num(*c)) return KNOB_INVALID;
+  }
+
+  v = strtoll(val,0,10);
+  if(v < k->min || v > k->max){
+    return KNOB_RANGE;
+  }
+
+  *data = v;
+  return KNOB_SUCCESS;
+}
+
+static unsigned setval_str(knob_t const *k,char const *val){
+  char    **data = k->data;
+  int64_t   len;
+
+  if(!val){
+    strcpy(*data,k->def.s);
+    return KNOB_SUCCESS;
+  }
+
+  len = strlen(val); 
+  if(len < k->min || len > k->max){
+    return KNOB_RANGE;
+  }
+
+  strcpy(*data,val);
+  return KNOB_SUCCESS;
+}
+
+static bool storeval_bool(knob_t const *k,char const *path){
+  bool const *v = k->data;
+  return bool_store(path,*v) ? KNOB_SUCCESS : KNOB_STORE;
+}
+
+static unsigned loadval_bool(knob_t const *k,char const *path){
+  return bool_load(path,k->data) ? KNOB_SUCCESS : KNOB_LOAD;
+}
+
+static bool storeval_int(knob_t const *k,char const *path){
+  int64_t const *v = k->data;
+  return int_store(path,*v) ? KNOB_SUCCESS : KNOB_STORE;
+}
+
+static unsigned loadval_int(knob_t const *k,char const *path){
+  char buf[INT64_LEN+1+1]; //str\0 +1 for detecting oversize
+
+  if(!str_load(path,buf,sizeof(buf))){
+    return KNOB_LOAD;
+  }
+
+  return setval_int(k,buf);
+}
+
+static bool storeval_str(knob_t const *k,char const *path){
+  char const **v = k->data;
+  return str_store(path,*v) ? KNOB_SUCCESS : KNOB_STORE;
+}
+
+static unsigned loadval_str(knob_t const *k,char const *path){
+  char buf[k->max+1+1]; //str\0 +1 for detecting oversize
+
+  if(!str_load(path,buf,sizeof(buf))){
+    return KNOB_LOAD;
+  }
+
+  return setval_str(k,buf);
+}
+
+static strval_f knob_strval[] = {
+  [KNOB_BOOL]   = (strval_f)    strval_bool,
+  [KNOB_INT]    = (strval_f)    strval_int,
+  [KNOB_STR]    = (strval_f)    strval_str,
+};
+
+static setval_f knob_setval[] = {
+  [KNOB_BOOL]   = (setval_f)    setval_bool,
+  [KNOB_INT]    = (setval_f)    setval_int,
+  [KNOB_STR]    = (setval_f)    setval_str,
+};
+
+static storeval_f knob_storeval[] = {
+  [KNOB_BOOL]   = (storeval_f)  storeval_bool,
+  [KNOB_INT]    = (storeval_f)  storeval_int,
+  [KNOB_STR]    = (storeval_f)  storeval_str,
+};
+
+static loadval_f knob_loadval[] = {
+  [KNOB_BOOL]   = (loadval_f)   loadval_bool,
+  [KNOB_INT]    = (loadval_f)   loadval_int,
+  [KNOB_STR]    = (loadval_f)   loadval_str,
+};
+
+static void knob_print_val(knob_t const *k){
+  char val[KNOB_VAL_BUF];
+  knob_strval[k->type](val,sizeof(val),k->data);
+  irc_out("%s = %s",k->name,val);
+}
+
+static void knob_print(knob_t const *k,bool alt){
+  char val[KNOB_VAL_BUF];
+  char def[KNOB_VAL_BUF];
+  char min[KNOB_VAL_BUF];
+  char max[KNOB_VAL_BUF];
+
+  knob_strval[k->type](val,sizeof(val),k->data);
+  knob_strval[k->type](def,sizeof(def),&k->def);
+
+  switch(k->type){
+  case KNOB_INT:
+  case KNOB_STR:
+    strval_int(min,sizeof(min),&k->min);
+    strval_int(max,sizeof(max),&k->max);
+    break;
+  }
+
+  if(!alt){
+    irc_out("%s = %s",k->name,val);
+    return;
+  }
+
+  irc_out("--- BEGIN KNOB INFO ---");
+
+  KNOBINFO("name",        k->name);
+  KNOBINFO("type",        knobtype_name[k->type]);
+  KNOBINFO("descrip",     k->desc);
+  KNOBINFO("value",       val);
+  KNOBINFO("default",     def);
+
+  switch(k->type){
+  case KNOB_INT:
+    if(k->min != KNOB_MIN) KNOBINFO("minimum",min);
+    if(k->max != KNOB_MAX) KNOBINFO("maximum",max);
+    break;
+
+  case KNOB_STR:
+    if(k->min != KNOB_MIN) KNOBINFO("min len",min);
+    if(k->max != KNOB_MAX) KNOBINFO("max len",max);
+    break;
+  }
+
+  irc_out("--- END KNOB INFO ---");
+}
+
+static void knob_desc(knob_t const *k){
+  char val[KNOB_VAL_BUF];
+  knob_strval[k->type](val,sizeof(val),k->data);
+  irc_out("%-7s = %-20s %-5s %s",
+          k->name,val,knobtype_name[k->type],k->desc);
+}
+
+void knob_display(char const *name,bool alt){
+  if(name){
+    knob_t const *k = knob_lookup(name);
+    if(!k) return;
+    knob_print(k,alt);
+  }else{
+    irc_out("--- BEGIN KNOB LIST ---");
+    for(size_t x = 0;x < ARR_CNT(knob);x++){
+      knob_t const *k = knob+x;
+      knob_desc(k);
+    }
+    irc_out("--- END KNOB LIST ---");
+  }
+}
+
+static void knob_err(knob_t const *k,unsigned rc,char const *val){
+  switch(rc){
+    bool min;
+    bool max;
+
+  case KNOB_INVALID:
+    irc_err("invalid value '%s' for knob '%s'",
+            val,k->name);
+    break;
+
+  case KNOB_RANGE:
+    min = k->min != KNOB_MIN;
+    max = k->max != KNOB_MAX;
+    if(!min && !max){
+      assert(0);
+    }else if(!min && max){
+      irc_err("knob '%s' expects value <= %ld",
+              k->name,k->min,k->max);
+    }else if(min && !max){
+      irc_err("knob '%s' expects value >= %ld",
+              k->name,k->min,k->max);
+    }else if(min && max){
+      irc_err("knob '%s' expects value in range [%ld,%ld]",
+              k->name,k->min,k->max);
+    }
+    break;
+
+  case KNOB_STORE:
+    irc_err("couldn't store knob '%s' on disk",
+            k->name);
+    break;
+
+  case KNOB_LOAD:
+    irc_err("couldn't load knob '%s' from disk",
+            k->name);
+    break;
+  }
+}
+
+static bool knob_storef(knob_t const *k){
+  char      path[PATH_BUF];
+  unsigned  rc;
+
+  FMT_PATH(path,"%s",k->name);
+  rc = knob_storeval[k->type](k,path);
+
+  switch(rc){
+  case KNOB_SUCCESS:
+    return 1;
+
+  default:
+    knob_err(k,rc,0);
+    return 0;
+  }
+}
+
+static bool knob_loadf(knob_t const *k){
+  char      path[PATH_BUF];
+  unsigned  rc;
+
+  FMT_PATH(path,"%s",k->name);
+  if(!file_exists(path)){
+    unsigned rc = knob_setval[k->type](k,0);
+    assert(rc == KNOB_SUCCESS); (void)rc;
+    return knob_storef(k);
+  }
+
+  rc = knob_loadval[k->type](k,path);
+
+  switch(rc){
+  case KNOB_SUCCESS:
+    return 1;
+
+  default:
+    knob_err(k,rc,0);
+    return 0;
+  }
+}
+
+void knob_set(char const *name,char const *val){
+  knob_t const *k;
+  unsigned      rc;
+
+  k = knob_lookup(name);
+  if(!k) return;
+
+  rc = knob_setval[k->type](k,val);
+
+  switch(rc){
+  case KNOB_SUCCESS:
+    knob_storef(k);
+    knob_print_val(k);
+    break;
+
+  default:
+    knob_err(k,rc,val);
+    break;
+  }
+}
+
+bool knob_load(void){
+  for(size_t x = 0;x < ARR_CNT(knob);x++){
+    knob_t const *k = knob+x;
+    if(!knob_loadf(k)) return 0;
+  }
+  return 1;
+}
+
diff -uNr a/src/knobs.h b/src/knobs.h
--- a/src/knobs.h false
+++ b/src/knobs.h d820883bc554df727e55b55a22f49402f101ea2b27309b8d4b9b862d604fde79986371caee6d39aa7876331ff82231ef7afe38180ceffa04b90c618086dc3ed6
@@ -0,0 +1,130 @@
+static char *p_banner = banner;
+
+static knob_t const knob[] = {
+
+  { .data       = &setport,
+    .name       = FILE_SETPORT,
+    .desc       = "update source port in addition to ip address in AT entries",
+    .type       = KNOB_BOOL,
+    .def.b      = 1,
+  },
+
+  { .data       = &cutoff,
+    .name       = FILE_CUTOFF,
+    .desc       = "bounce cutoff for rejecting packets",
+    .type       = KNOB_INT,
+    .def.i      = 3,
+    .min        = CUTOFF_MIN,
+    .max        = CUTOFF_MAX,
+  },
+
+  { .data       = &hstime,
+    .name       = FILE_HSTIME,
+    .desc       = "hearsay buffer timeout in milliseconds",
+    .type       = KNOB_INT,
+    .def.i      = 1000,
+    .min        = 0,
+    .max        = KNOB_MAX,
+  },
+
+  { .data       = &gdtime,
+    .name       = FILE_GDTIME,
+    .desc       = "getdata attempt timeout in milliseconds "
+                  "(actual = gdtime*gdatt)",
+    .type       = KNOB_INT,
+    .def.i      = 500,
+    .min        = 0,
+    .max        = KNOB_MAX,
+  },
+
+  { .data       = &gdatt,
+    .name       = FILE_GDATT,
+    .desc       = "number of getdata attempts before give up",
+    .type       = KNOB_INT,
+    .def.i      = 2,
+    .min        = 1,
+    .max        = KNOB_MAX,
+  },
+
+  { .data       = &gdint,
+    .name       = FILE_GDINT,
+    .desc       = "interval in seconds between attempts "
+                  "to repair broken chains",
+    .type       = KNOB_INT,
+    .def.i      = 10,
+    .min        = 1,
+    .max        = KNOB_MAX,
+  },
+
+  { .data       = &rkrecv,
+    .name       = FILE_RKRECV,
+    .desc       = "processing of incoming rekey requests",
+    .type       = KNOB_BOOL,
+    .def.b      = 0,
+  },
+
+  { .data       = &rksend,
+    .name       = FILE_RKSEND,
+    .desc       = "automatic rekeying requests",
+    .type       = KNOB_BOOL,
+    .def.b      = 0,
+  },
+
+  { .data       = &rkint,
+    .name       = FILE_RKINT,
+    .desc       = "automatic rekeying request interval in hours",
+    .type       = KNOB_INT,
+    .def.i      = 24,
+    .min        = 1,
+    .max        = KNOB_MAX,
+  },
+
+  { .data       = &rktime,
+    .name       = FILE_RKTIME,
+    .desc       = "rekeying ritual timeout in seconds",
+    .type       = KNOB_INT,
+    .def.i      = 10,
+    .min        = 1,
+    .max        = KNOB_MAX,
+  },
+
+  { .data       = &igint,
+    .name       = FILE_IGINT,
+    .desc       = "average interval in milliseconds between "
+                  "ignore messages sent",
+    .type       = KNOB_INT,
+    .def.i      = 1000,
+    .min        = 100,
+    .max        = 10000,
+  },
+
+  { .data       = &p_banner,
+    .name       = FILE_BANNER,
+    .desc       = "human-readable description of station",
+    .type       = KNOB_STR,
+    .def.s      = PROG_NAME,
+    .min        = 0,
+    .max        = sizeof(banner)-1,
+  },
+
+  { .data       = &baint,
+    .name       = FILE_BAINT,
+    .desc       = "banner broadcast interval in seconds",
+    .type       = KNOB_INT,
+    .def.i      = 600,
+    .min        = 1,
+    .max        = KNOB_MAX,
+  },
+
+  { .data       = &irctime,
+    .name       = FILE_IRCTIME,
+    .desc       = "timeout in seconds before peer not "
+                  "sending packets parts channel",
+    .type       = KNOB_INT,
+    .def.i      = 60,
+    .min        = 1,
+    .max        = KNOB_MAX,
+  },
+
+};
+
diff -uNr a/src/log.c b/src/log.c
--- a/src/log.c false
+++ b/src/log.c bd88855ac64d530903e4c3992151c251b90f40bf5fce60c8b04edd43bb08a9456424a6f3e2cd68459baf1a6f7a2a9cd72064f0dcd89d697d1282d36a7d96ee6f
@@ -0,0 +1,89 @@
+#include "log.h"
+#include "string.h"
+#include "time.h"
+#include "io.h"
+#include "util.h"
+#include "state.h"
+#include "config.h"
+#include <errno.h>
+#include <stdio.h>
+#include <string.h>
+#include <time.h>
+
+#define LOG_STAMP_BUF       256
+
+static void timestamp(FILE *f,uint64_t time){
+  char ts[LOG_STAMP_BUF];
+  time_str(ts,sizeof(ts),LOG_STAMP_FMT" ",time);
+  fputs(ts,f);
+}
+
+static void _log_vout(FILE *f,char const *fmt,va_list args,uint64_t time){
+  timestamp(f,time);
+  vfprintf(f,fmt,args);
+  fputc('\n',f);
+}
+
+static void _log_verr(FILE *f,char const *fmt,va_list args,uint64_t time){
+  timestamp(f,time);
+  fputs("error: ",stderr);
+  vfprintf(f,fmt,args);
+  fputc('\n',f);
+}
+
+bool log_open(char const *path){
+  log_fp = file_open(path,"ab");
+  return log_fp != 0;
+}
+
+bool log_close(void){
+  if(!log_fp) return 1;
+  bool r = file_close(log_fp);
+  log_fp = 0;
+  return r;
+}
+
+void log_void(char const *fmt,...){
+  (void)fmt;
+}
+
+void log_out(char const *fmt,...){
+  va_list args;
+  va_start(args,fmt);
+  log_vout(fmt,args);
+  va_end(args);
+}
+
+void log_vout(char const *fmt,va_list args){
+  uint64_t time = time_sec();
+  if(log_fp){
+    va_list args2;
+    va_copy(args2,args);
+    _log_vout(log_fp,fmt,args2,time);
+    va_end(args2);
+  }
+  _log_vout(stderr,fmt,args,time);
+}
+
+void log_err(char const *fmt,...){
+  va_list args;
+  va_start(args,fmt);
+  log_verr(fmt,args);
+  va_end(args);
+}
+
+void log_verr(char const *fmt,va_list args){
+  uint64_t time = time_sec();
+  if(log_fp){
+    va_list args2;
+    va_copy(args2,args);
+    _log_verr(log_fp,fmt,args2,time);
+    va_end(args2);
+  }
+  _log_verr(stderr,fmt,args,time);
+}
+
+void log_errno(char const *call){
+  log_err("%s(): %s",call,strerror(errno));
+}
+
diff -uNr a/src/log.h b/src/log.h
--- a/src/log.h false
