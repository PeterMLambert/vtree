+
+void *memset_ffs(void *dst,int c,size_t size){
+  return memset(dst,c,size);
+}
+
diff -uNr a/src/mess.c b/src/mess.c
--- a/src/mess.c false
+++ b/src/mess.c 382d78e6376f4bf12d272d569e3706bb653110933598dfb226953c6ea1c379d9779ffaf1e46f3c0809962883822c0902cdf667fa7d9daec03c3664dc7800c819
@@ -0,0 +1,104 @@
+#include "chain.h"
+#include "crypto.h"
+#include "io.h"
+#include "log.h"
+#include "util.h"
+#include "config.h"
+#include "string.h"
+#include <string.h>
+
+void mess_init(mess_t *c){
+  *c->path    = 0;
+  c->idx_cnt  = 0;
+  c->msg_cnt  = 0;
+  c->idx_ecnt = 0;
+  c->msg_ecnt = 0;
+}
+
+void mess_path(mess_t *c,char const *path){
+  strzcpy(c->path,path,sizeof(c->path));
+}
+
+bool mess_load(mess_t *c){
+  if(!mkdir_p(c->path)) return 0;
+
+  if(!idx_cnt (c,&c->idx_cnt )) return 0;
+  if(!idx_ecnt(c,&c->idx_ecnt)) return 0;
+  if(!msg_cnt (c,&c->msg_cnt )) return 0;
+  if(!msg_ecnt(c,&c->msg_ecnt)) return 0;
+
+  //TODO: chek if idx and msg total count matches
+  //TODO: log al operations
+
+#ifdef LOG_MESS
+  log_out("mess loaded: '%s' (message count: %zu)",
+          c->path,msg_count(c));
+#endif
+
+  return 1;
+}
+
+bool mess_push(mess_t        *c,
+               hash_t const   hash,
+               uint8_t const *m){
+
+  uint64_t index;
+
+  assert(mess_lookup(c,hash,0) != LOOKUP_FOUND);
+
+#ifndef NDEBUG
+  hash_t mhash;
+  hash_data(mhash,m,MESSAGE_SIZE);
+  assert(hash_equal(mhash,hash));
+#endif
+
+  if(!msg_ins(c,m,&index))    return 0;
+  if(!idx_ins(c,hash,index))  return 0;
+
+#ifdef LOG_MESS
+  char hash_hex[HASH_HEX_BUF];
+  hash_str_log(hash_hex,sizeof(hash_hex),hash);
+  log_out("%s pushed to mess: '%s'",hash_hex,c->path);
+#endif
+
+  return 1;
+}
+
+unsigned mess_lookup(mess_t        *c,
+                     hash_t const   hash,
+                     uint8_t       *m){
+
+  uint64_t index;
+
+  if(hash_null(hash)) return LOOKUP_NOTFOUND;
+
+  switch(idx_lookup(c,hash,&index)){
+  case LOOKUP_FOUND:
+    break;
+
+  case LOOKUP_NOTFOUND:
+#ifdef LOG_MESS
+    ;char hash_hex[HASH_HEX_BUF];
+    hash_str_log(hash_hex,sizeof(hash_hex),hash);
+    log_out("%s not found in mess: '%s'",hash_hex,c->path);
+#endif
+    return LOOKUP_NOTFOUND;
+
+  case LOOKUP_IO:
+    return LOOKUP_IO;
+  }
+
+  if(!msg_get(c,m,index)){
+    if(m) memset_ffs(m,0x00,MESSAGE_SIZE);
+    return LOOKUP_IO;
+  }
+
+#ifdef LOG_MESS
+  char hash_hex[HASH_HEX_BUF];
+  hash_str_log(hash_hex,sizeof(hash_hex),hash);
+  log_out("%s found in mess: '%s'",hash_hex,c->path);
+#endif
+
+  return 1;
+}
+
diff -uNr a/src/message.c b/src/message.c
--- a/src/message.c false
+++ b/src/message.c 158a7730cc79d296a17d50eb803ff5c7b34054a4c29b89a8a94cd1fe1f5f4d83f38bf081f3c58ee5d968e1176bcd184b5ccdb213a9dfd89503e0fad7f402e8a9
@@ -0,0 +1,258 @@
+//okesoft illegal to look at gode license
+//this file is illegal to look at btw. do NOT look at the gode in this file
+//u can look at the other files they are covered under difrent license
+
+#include "pest.h"
+#include "peer.h"
+#include "chain.h"
+#include "packet.h"
+#include "crypto.h"
+#include "log.h"
+#include "util.h"
+#include "state.h"
+
+static void problems_display(peer_t      *p,
+                             peer_t      *chan,
+                             char const  *speaker){
+
+  char const     *handle  = p->handle[0];
+  char const     *chname  = chan ? "direct message"  : "broadcast";
+  char const     *ichan   = chan ? speaker           : irc_chan;
+  ht_t           *head    = chan ? &p->dhead         : &p->bhead;
+  ht_t           *tail    = chan ? &p->dtail         : &p->btail;
+
+  size_t f = ht_forks  (head,tail);
+  size_t b = ht_breaks (head,tail);
+
+  if(f == 0 && b == 0) return;
+  irclog_out_chan(ichan,
+                  "peer '%s' %s chain has %zu fork%s and %zu break%s",
+                  handle,chname,
+                  f,f == 1 ? "" : "s",
+                  b,b == 1 ? "" : "s");
+}
+
+static void message_display(mess_t         *ms,
+                            chain_t        *ch,
+                            peer_t         *p,
+                            peer_t         *chan,
+                            uint8_t const  *m,
+                            hash_t const    hash,
+                            char const     *speaker,
+                            bool            stampold){
+
+  if(ch) chain_push(ch,hash,m+SELFCHAIN_OFF);
+  if(ms){
+    if(mess_lookup(ms,hash,0) != LOOKUP_NOTFOUND){
+      //eror or mesage already shown to operator at some point
+      return;
+    }
+    mess_push(ms,hash,m);
+    if(p){
+      problems_display(p,chan,speaker);
+    }
+    console_send(chan,speaker,m,stampold);
+  }
+}
+
+//TODO: this gode is udderly ridiculous FIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIIX
+void message_handle(uint8_t const  *m,
+                    hash_t const    hash,
+                    char const     *speaker,
+                    peer_t         *p,
+                    peer_t         *chan,
+                    bool            stampold,
+                    bool            pend,
+                    bool            display){
+
+  mess_t         *ms      = chan ? &p->mess          : &mess;
+  chain_t        *ch      = chan ? &p->dchain        : &p->bchain;
+  ht_t           *head    = chan ? &p->dhead         : &p->bhead;
+  ht_t           *tail    = chan ? &p->dtail         : &p->btail;
+  char const     *chname  = chan ? "direct message"  : "broadcast";
+  char const     *ichan   = chan ? speaker           : irc_chan;
+  mess_t         *mms     = display ? ms : 0;
+  uint8_t const  *prev    = m+SELFCHAIN_OFF;
+  char const     *handle  = p->handle[0];
+  hash_t         *h;
+  hash_t         *t;
+  unsigned        r; 
+  uint8_t         m_prev[MESSAGE_SIZE];
+
+  getdata_del(hash,0);
+
+again:
+  if(h = ht_lookup(head,prev)){
+    //continuation in > dir of existing head, common case
+    if(ht_null(head,tail) && hash_null(prev)){
+      irclog_out_chan(ichan,"peer '%s' met! (%s)",
+                      handle,chname);
+    }
+
+    //see if this merges something
+    if(t = ht_lookup(tail,hash)){
+      ht_del(head,h);
+      ht_del(tail,t);
+      irclog_out_chan(ichan,"peer '%s' %s chain break repaired",
+                      handle,chname);
+    }else{
+      ht_set(head,h,hash);
+    }
+
+    message_display(mms,ch,p,chan,m,hash,speaker,stampold);
+
+    //see if this fixed pending problems
+    if(pend) pending_send_chain(hash);
+
+  }else if(((r = LOOKUP_FOUND) && ht_lookup(tail,prev)) || //this gode is tmp
+           (r = chain_lookup(ch,prev,0)) == LOOKUP_FOUND){
+
+    if(r == LOOKUP_IO) return;
+    
+    switch(chain_lookup(ch,hash,0)){
+    case LOOKUP_FOUND:
+      //dupe.. shud never hapen but... ????????
+      //throw away mesage i gues
+    case LOOKUP_IO:
+      return;
+
+    case LOOKUP_NOTFOUND:
+      break;
+    }
+
+    //new fork city
+
+    if(ht_full(head)){
+      irc_err("head buffer full for peer '%s'",handle);
+      return;
+    }else{
+      h = ht_add(head,hash);
+    }
+
+    //see if this merges something
+    if(t = ht_lookup(tail,hash)){
+      ht_del(head,h);
+      ht_del(tail,t);
+      irclog_out_chan(ichan,"peer '%s' %s chain break repaired",
+                      handle,chname);
+    }
+
+    irclog_out_chan(ichan,"peer '%s' %s chain forked!",
+                    handle,chname);
+    message_display(mms,ch,p,chan,m,hash,speaker,stampold);
+
+    //see if this "fixed" pending problems
+    if(pend) pending_send_chain(hash);
+
+  }else if((r = mess_lookup(ms,prev,m_prev)) != LOOKUP_NOTFOUND){
+    if(r == LOOKUP_IO) return;
+    //TODO: fix total retart gode
+    message_handle(m_prev,prev,speaker,p,chan,stampold,0,0);
+    goto again; //retard
+
+  }else if(pend){
+    //new break or continuation in < or > dir of existing pending break
+    if(pending_dontfull()) goto again; //retard
+    pending_push(m,hash,speaker,p,chan);
+
+  }else if(t = ht_lookup(tail,hash)){
+    //continuation in < dir of existing break/valid chain
+    ht_set(tail,t,prev);
+
+    message_display(mms,ch,p,chan,m,hash,speaker,1);
+    getdata_push_cond(p,chan,prev);
+
+  }else{
+    //new break, dont add to pending table
+    if(ht_full(head) || ht_full(tail)){
+      irc_err("head/tail buffer full for peer '%s'",handle);
+      return;
+    }
+
+    ht_add(head,hash);
+    ht_add(tail,prev);
+
+    irclog_out_chan(ichan,"peer '%s' %s chain broken!",
+                    handle,chname);
+    message_display(mms,ch,p,chan,m,hash,speaker,stampold);
+    getdata_push_cond(p,chan,prev);
+  }
+}
+
+void message_handle_simp(uint8_t const *m,
+                         hash_t const   hash,
+                         char const    *speaker,
+                         bool           stampold){
+
+  //uint8_t    *m_self  = m+SELFCHAIN_OFF;
+  //uint8_t    *m_net   = m+NETCHAIN_OFF;
+
+  message_display(&mess,0,0,0,m,hash,speaker,stampold);
+  //TODO: vtf do with responses to this? put in hearsay baffer or vat?
+  //getdata_push_cond(0,0,m_self);
+  //getdata_push_cond(0,0,m_net);
+}
+
+bool broadcast_handle(peer_t       *p,
+                      peer_t       *gd_peer,
+                      bool          immediate,
+                      uint8_t      *r,
+                      hash_t const  hash,
+                      uint8_t       bounces,
+                      char const   *speaker){
+
+  //TODO: vat a mess
+  uint8_t const *m = r+MESSAGE_OFF;
+
+  if(gd_peer){
+    //getdata response
+    message_handle(m,hash,speaker,gd_peer,0,1,1,1);
+  }else if(immediate){
+    //immediate message
+    message_handle(m,hash,speaker,p,0,0,1,1);
+    red_rebroadcast(r,hash,bounces);
+  }else{
+    //hearsay
+    if(bounces == 0){
+      log_out("hearsay message with 0 bounces "
+              "discarded from peer '%s'",p->handle[0]);
+      return 0;
+    }
+
+    peer_t *q = peer_lookup_noerr(speaker);
+    hearsay_push(hash,r,q,p,bounces);
+  }
+
+  return 1;
+}
+
+bool direct_handle(peer_t        *p,
+                   peer_t        *gd_peer,
+                   bool           immediate,
+                   uint8_t       *r,
+                   hash_t const   hash,
+                   uint8_t        bounces,
+                   char const    *speaker){
+
+  uint8_t const  *m = r+MESSAGE_OFF;
+  char            speaker_ext[HANDLE_EXT_BUF];
+  char const     *speaker_ptr;
+
+  if(bounces != 0){
+    irclog_err("direct message with bounces != 0 "
+               "received from peer '%s'",p->handle[0]);
+    return 0;
+  }
+
+  if(immediate){
+    speaker_ptr = speaker;
+  }else{
+    fmt_handle_ext(speaker_ext,sizeof(speaker_ext),
+                   speaker,p->handle,p->handle_cnt);
+    speaker_ptr = speaker_ext;
+  }
+
+  message_handle(m,hash,speaker_ptr,p,p,(bool)gd_peer,1,1);
+  return 1;
+}
+
diff -uNr a/src/msg.c b/src/msg.c
--- a/src/msg.c false
+++ b/src/msg.c be84df66345c3edc60375e3d7e5eea3c990183dded348263c779321861b8ea7be775678bb6ca2852978c091cd49343e9760e0dc679b9105d4b5ab2902ed4ee67
@@ -0,0 +1,186 @@
+#include "chain.h"
+#include "io.h"
+#include "log.h"
+#include "util.h"
+
+#define MSG_POW2                        MESS_MSG_POW2
+#define MSG_MAX                         (1<<MSG_POW2)
+#define MSG_FILE_SIZE                   (MSG_MAX*MSG_SIZE)
+#define MSG_FILE                        "msg"
+#define MSG_FILE_ZEROS                  MESS_MSG_ZEROS
+
+//--- mess message -----------------------------------------------------------
+#define MSG_MESSAGE_SIZE                MESSAGE_SIZE
+
+#define MSG_MESSAGE_OFF                 ( 0                                   )
+
+#define MSG_SIZE                        ( MSG_MESSAGE_OFF + MSG_MESSAGE_SIZE  )
+
+static void msg_path(char *buf,size_t buf_size,mess_t const *c,size_t i){
+  snprintf(buf,buf_size,"%s/"MSG_FILE"%0"STR(MSG_FILE_ZEROS)"zu",c->path,i);
+}
+
+static void msg_corrupt(char const *path,bool write){
+  irclog_err("mess message file corrupt: '%s'",path);
+  if(write) disk_unsync();
+}
+
+static FILE *msg_open(char const *path,char const *mode,bool write){
+  FILE *f = file_open(path,mode);
+  if(!f){
+    if(write) disk_unsync();
+  }
+  return f;
+}
+
+static bool msg_close(FILE *f,char const *path,bool write){
+  if(!file_close(f)){
+    if(write) disk_unsync();
+    return 0;
+  }
+  if(write){
+    disk_written(path);
+  }else{
+    disk_read(path);
+  }
+  return 1;
+}
+
+static bool msg_seek_entry(FILE *f,size_t index,bool write){
+  if(!file_seek(f,index*MSG_SIZE,SEEK_SET)){
+    file_close(f);
+    if(write) disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+static bool msg_read_message(FILE *f,uint8_t *m,bool write){
+  if(m){
+    if(!file_read(f,m,MSG_MESSAGE_SIZE)){
+      file_close(f);
+      if(write) disk_unsync();
+      return 0;
+    }
+  }else{
+    if(!file_seek(f,MSG_MESSAGE_SIZE,SEEK_CUR)){
+      file_close(f);
+      if(write) disk_unsync();
+      return 0;
+    }
+  }
+  return 1;
+}
+
+static bool msg_write_message(FILE *f,uint8_t const *m){
+  if(!file_write(f,m,MSG_MESSAGE_SIZE)){
+    file_close(f);
+    disk_unsync();
+    return 0;
+  }
+  return 1;
+}
+
+bool msg_cnt(mess_t *c,size_t *msg_cnt_out){
+  size_t msg_cnt = 0;
+  while(1){
+    char path[PATH_BUF];
+    msg_path(path,sizeof(path),c,msg_cnt);
+    if(!file_exists(path)) break;
+    msg_cnt++;
+  }
+  *msg_cnt_out = msg_cnt;
+  return 1;
+}
+
+bool msg_ecnt(mess_t *c,size_t *ecnt_out){
+  char        path[PATH_BUF];
+  struct stat sb;
+  size_t      size;
+
+  msg_path(path,sizeof(path),c,c->msg_cnt-1);
+  if(c->msg_cnt == 0 || !file_exists(path)){
+    *ecnt_out = 0;
+    return 1;
+  }
+  if(!file_stat(path,&sb)) return 0;
+
+  size = (size_t)sb.st_size;
+  if(size % MSG_SIZE != 0 ||
+     size > MSG_SIZE*MSG_MAX){
+    msg_corrupt(path,0);
+    return 0;
+  }
+
+  *ecnt_out = size/MSG_SIZE;
+  return 1;
+}
+
+static inline size_t msg_file_idx(size_t index){
+  return index>>MSG_POW2;
+}
+
+static inline size_t msg_file_off(size_t index){
+  return index & MSG_MAX-1;
+}
+
+static inline size_t msg_index_next(mess_t const *c){
+  return (c->msg_cnt-1)*MSG_MAX+c->msg_ecnt;
+}
+
+size_t msg_count(mess_t const *c){
+  return c->msg_cnt > 0 ? msg_index_next(c) : 0;
+}
+
+bool msg_ins(mess_t        *c,
+             uint8_t const *m,
+             uint64_t      *index){
+
+  char  path[PATH_BUF];
+  FILE *f;
+
+  if(c->msg_cnt == 0 || c->msg_ecnt+1 > MSG_MAX){
+    c->msg_cnt++;
+    c->msg_ecnt = 0;
+  }
+
+  msg_path(path,sizeof(path),c,c->msg_cnt-1);
+  f = msg_open(path,"ab",1);
+  if(!f) return 0;
+
+  if(!msg_write_message (f,m))          return 0;
+  if(!msg_close         (f,path,1))     return 0;
+
+  *index = msg_index_next(c);
+  c->msg_ecnt++;
+
+  return 1;
+}
+
+bool msg_get(mess_t    *c,
+             uint8_t   *m,
+             uint64_t   index){
+
+  char    path[PATH_BUF];
+  size_t  file_idx;
+  size_t  file_off;
+  FILE   *f;
+
+  if(!m) return 1;
+
+  file_idx = msg_file_idx(index);
+  file_off = msg_file_off(index);
+
+  msg_path(path,sizeof(path),c,file_idx);
+  f = msg_open(path,"rb",0);
+  if(!f) return 0;
+
+  //TODO: chek filesize
+
+  if(!msg_seek_entry    (f,file_off,0)) return 0;
+  if(!msg_read_message  (f,m,0))        return 0;
+  if(!msg_close         (f,path,0))     return 0;
+
+  return 1;
+}
+
diff -uNr a/src/net.c b/src/net.c
--- a/src/net.c false
+++ b/src/net.c 1b24b705d236d1a47b9785ca2dd95314a7846fb2016e949b1e3cf00bca1140b5db2d9f64d3e68365ee5d54b05839387e570bc6792532a6fdbf1b304f6d950401
@@ -0,0 +1,291 @@
+#include "net.h"
+#include "def.h"
+#include "log.h"
+#include "crypto.h"
+#include "util.h"
+#include "time.h"
+#include "config.h"
+#include "state.h"
+#include <sys/socket.h>
+#include <netinet/in.h>
+#include <arpa/inet.h>
+#include <fcntl.h>
+#include <unistd.h>
+#include <errno.h>
+#include <string.h>
+
+bool ip_u32(uint32_t *ip,char const *str){
+  struct sockaddr_in sa;
+  if(inet_pton(AF_INET,str,&sa.sin_addr) != 1){
+    log_errno("inet_pton");
+    return 0;
+  }
+  *ip = ntohl(sa.sin_addr.s_addr);
+  return 1;
+}
+
+bool ip_str(char *str,size_t str_size,uint32_t ip){
+  struct sockaddr_in sa;
+  VAR_ZERO(sa);
+  sa.sin_addr.s_addr = htonl(ip);
+  if(inet_ntop(AF_INET,&sa.sin_addr,str,str_size) == 0){
+    log_errno("inet_ntop");
+    return 0;
+  }
+  return 1;
+}
+
+size_t udp_recv(uint32_t *src_ip,
+                uint16_t *src_port,
+                uint16_t  port,
+                uint8_t  *data,
+                size_t    size){
+
+  struct sockaddr_in  addr;
+  struct sockaddr_in  cli_addr;
+  socklen_t           cli_addr_len;
+  ssize_t             n;
+
+  if(udp_listen_fd == -1){
+    udp_listen_fd = socket(AF_INET,SOCK_DGRAM,IPPROTO_UDP);
+    if(udp_listen_fd == -1){
+      log_errno("socket");
+      return 0;
+    }
+
+    if(fcntl(udp_listen_fd,F_SETFL,O_NONBLOCK) != 0){
+      log_errno("fcntl");
+      close(udp_listen_fd);
+      udp_listen_fd = -1;
+      return 0;
+    }
+
+    VAR_ZERO(addr);
+    addr.sin_family       = AF_INET;
+    addr.sin_port         = htons(port);
+    addr.sin_addr.s_addr  = htonl(INADDR_ANY);
+
+    if(bind(udp_listen_fd,
+            (struct sockaddr *)&addr,
+            sizeof(addr)) != 0){
+      log_errno("bind");
+      close(udp_listen_fd);
+      udp_listen_fd = -1;
+      sleep_nsec(NET_RETRY_SLEEP*NSEC_MSEC);
+      return 0;
+    }
+    log_out("listening on UDP port %u",port);
+  }
+
+  if(data == 0) return 0;
+
+  cli_addr_len  = sizeof(cli_addr);
+  n             = recvfrom(udp_listen_fd,
+                           data,
+                           size,
+                           0,
+                           (struct sockaddr *)&cli_addr,
+                           &cli_addr_len);
+
+  if(n == -1){
+    if(errno == EAGAIN || errno == EWOULDBLOCK){
+      udp_silent = 1;
+      return 0;
+    }
+    log_errno("recvfrom");
+    return 0;
+  }
+  udp_silent = 0;
+
+  *src_ip   = ntohl(cli_addr.sin_addr.s_addr);
+  *src_port = ntohs(cli_addr.sin_port);
+  return n;
+}
+
+size_t udp_send(uint32_t        ip,
+                uint16_t        port,
+                uint8_t const  *data,
+                size_t          size){
+
+  int                 fd;
+  struct sockaddr_in  addr;
+  ssize_t             n;
+
+  VAR_ZERO(addr);
+  addr.sin_family       = AF_INET;
+  addr.sin_port         = htons(port);
+  addr.sin_addr.s_addr  = htonl(ip);
+
+  fd = socket(AF_INET,SOCK_DGRAM,IPPROTO_UDP);
+  if(fd == -1){
+    log_errno("socket");
+    return 0;
+  }
+
+  n = sendto(fd,  
+             data,
+             size,
+             0,
+             (struct sockaddr const *)&addr,
+             sizeof(addr));
+
+  if(n == -1){
+    log_errno("sendto");
+    close(fd);
+    return 0;
+  }
+  close(fd);
+  return n;
+}
+
+void tcp_init(tcpev_f func){
+  tcp_func = func;
+}
+
+size_t tcp_recv(uint32_t *src_ip,
+                uint16_t *src_port,
+                uint16_t  port,
+                uint8_t  *data,
+                size_t    size){
+
+  struct sockaddr_in  addr;
+  struct sockaddr_in  cli_addr;
+  socklen_t           cli_addr_len;
+  ssize_t             n;
+
+  if(tcp_listen_fd == -1){
+    tcp_listen_fd = socket(AF_INET,SOCK_STREAM,IPPROTO_TCP);
+    if(tcp_listen_fd == -1){
+      log_errno("socket");
+      return 0;
+    }
+
+    int enable = 1;
+    if(setsockopt(tcp_listen_fd,
+                  SOL_SOCKET,
+                  SO_REUSEADDR,
+                  &enable,
+                  sizeof(int)) == -1){
+      log_errno("setsockopt");
+    }
+
+    if(fcntl(tcp_listen_fd,F_SETFL,O_NONBLOCK) != 0){
+      log_errno("fcntl");
+      tcp_lclose();
+      sleep_nsec(NET_RETRY_SLEEP*NSEC_MSEC);
+      return 0;
+    }
+
+    VAR_ZERO(addr);
+    addr.sin_family       = AF_INET;
+    addr.sin_port         = htons(port);
+    addr.sin_addr.s_addr  = htonl(INADDR_ANY);
+
+    if(bind(tcp_listen_fd,
+            (struct sockaddr *)&addr,
+            sizeof(addr)) != 0){
+      log_errno("bind");
+      tcp_lclose();
+      sleep_nsec(NET_RETRY_SLEEP*NSEC_MSEC);
+      return 0;
+    }
+
+    if(listen(tcp_listen_fd,10) != 0){
+      log_errno("listen");
+      tcp_lclose();
+      sleep_nsec(NET_RETRY_SLEEP*NSEC_MSEC);
+      return 0;
+    }
+    log_out("listening on TCP port %u",port);
+  }
+
+  if(tcp_client_fd == -1){
+    char ips[IPV4_BUF];
+
+    cli_addr_len  = sizeof(cli_addr);
+    tcp_client_fd = accept(tcp_listen_fd,
+                           (struct sockaddr *)&cli_addr,
+                           &cli_addr_len);
+    if(tcp_client_fd == -1){
+      if(errno == EAGAIN || errno == EWOULDBLOCK){
+        if(udp_silent){
+          sleep_nsec(NET_SILENT_SLEEP*NSEC_MSEC);
+        }
+        return 0;
+      }
+      log_errno("accept");
+      return 0;
+    }
+
+    if(fcntl(tcp_client_fd,F_SETFL,O_NONBLOCK) != 0){
+      log_errno("fcntl");
+      close(tcp_client_fd);
+      tcp_client_fd = -1;
+      return 0;
+    }
+
+    tcp_client_ip   = ntohl(cli_addr.sin_addr.s_addr);
+    tcp_client_port = ntohs(cli_addr.sin_port);
+    *src_ip         = tcp_client_ip;
+    *src_port       = tcp_client_port;
+
+    ip_str(ips,sizeof(ips),tcp_client_ip);
+    log_out("accepted TCP client from %s:%u",
+            ips,tcp_client_port);
+    if(tcp_func) tcp_func(TCP_CONNECT);
+  }else{
+    *src_ip         = tcp_client_ip;
+    *src_port       = tcp_client_port;
+  }
+
+  n = recv(tcp_client_fd,data,size,0);
+  if(n == -1){
+    if(errno == EAGAIN || errno == EWOULDBLOCK){
+      tcp_silent = 1;
+      if(udp_silent){
+        sleep_nsec(NET_SILENT_SLEEP*NSEC_MSEC);
+      }
+      return 0;
+    }
+    log_errno("recv");
+    tcp_cclose();
+    return 0;
+  }else if(n == 0){
+    tcp_cclose();
+    return 0;
+  }
+
+  tcp_silent = 0;
+  return n;
+}
+
+size_t tcp_send(uint8_t const *data,size_t size){
+  ssize_t n;
+
+  if(tcp_client_fd == -1) return 0;
+
+  n = send(tcp_client_fd,data,size,0);
+  if(n == -1){
+    log_errno("send");
+    tcp_cclose();
+    return 0;
+  }
+
+  return n;
+}
+
+void tcp_lclose(void){
+  if(tcp_listen_fd == -1) return;
+  close(tcp_listen_fd);
+  tcp_listen_fd = -1;
+  log_out("TCP listening socket closed");
+}
+
+void tcp_cclose(void){
+  if(tcp_client_fd == -1) return;
+  close(tcp_client_fd);
+  tcp_client_fd = -1;
+  log_out("TCP client socket closed");
+  if(tcp_func) tcp_func(TCP_DISCONNECT);
+}
+
diff -uNr a/src/net.h b/src/net.h
--- a/src/net.h false
+++ b/src/net.h 592fd4acffa17981edb080ecb9abae7fef094e1c248fbab5f398d31a70727002c7b801a2090c600e45467f1080cafaadf481d108fe695f87795c1a13fb040c72
@@ -0,0 +1,22 @@
+#ifndef UDP_H
+#define UDP_H
+
+#include "type.h"
+#include <stddef.h>
+#include <stdint.h>
+#include <stdbool.h>
+
+bool                ip_u32          (uint32_t *ip,char const *str);
+bool                ip_str          (char *str,size_t str_size,uint32_t ip);
+
+size_t              udp_recv        (uint32_t *src_ip,uint16_t *src_port,uint16_t port,uint8_t *data,size_t size);
+size_t              udp_send        (uint32_t ip,uint16_t port,uint8_t const *data,size_t size);
+
+void                tcp_init        (tcpev_f func);
+size_t              tcp_recv        (uint32_t *src_ip,uint16_t *src_port,uint16_t port,uint8_t *data,size_t size);
+size_t              tcp_send        (uint8_t const *data,size_t size);
+void                tcp_lclose      (void);
+void                tcp_cclose      (void);
+
+#endif
+
diff -uNr a/src/otherpplgode/base64.c b/src/otherpplgode/base64.c
--- a/src/otherpplgode/base64.c false
+++ b/src/otherpplgode/base64.c f0333a5fb12249484fa5b2fb3afdb548be36e97fd123a8fdc315b59ead1c3a4e5d4b834c4a58afa10167508343ade9e624e577647cc2fc6d36dd99c62cd1123d
@@ -0,0 +1,103 @@
+#include "../crypto.h"
+#include <string.h>
+#include <assert.h>
+
+static uint8_t const base64_pr2six[256] = {
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x3E,0x40,0x40,0x40,0x3F,
+  0x34,0x35,0x36,0x37,0x38,0x39,0x3A,0x3B,0x3C,0x3D,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x00,0x01,0x02,0x03,0x04,0x05,0x06,0x07,0x08,0x09,0x0A,0x0B,0x0C,0x0D,0x0E,
+  0x0F,0x10,0x11,0x12,0x13,0x14,0x15,0x16,0x17,0x18,0x19,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x1A,0x1B,0x1C,0x1D,0x1E,0x1F,0x20,0x21,0x22,0x23,0x24,0x25,0x26,0x27,0x28,
+  0x29,0x2A,0x2B,0x2C,0x2D,0x2E,0x2F,0x30,0x31,0x32,0x33,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+  0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,0x40,
+};
+
+static char const base64_basis[] = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
+
+size_t base64_dec_size(char const *in,bool nullterm){
+  size_t      nbd;
+  size_t      npr;
+  char const *in2;
+
+  in2 = in;
+  while(base64_pr2six[(uint8_t)*(in2++)] < 0x40);
+  npr = in2-in-1;
+  nbd = ((npr+3)/4)*3;
+
+  while(npr > 4) npr -= 4;
+  nbd -= (4-npr) & 3;
+  nbd += nullterm;
+  return nbd;
+}
+
+size_t base64_dec(char const *in,uint8_t *out,size_t out_size,bool nullterm){
+  size_t      nbd;
+  char const *in2;
+  size_t      npr;
+
+  assert(out_size >= base64_dec_size(in,nullterm));
+  (void)out_size;
+
+  in2   = in;
+  while(base64_pr2six[(uint8_t)*(in2++)] < 0x40);
+  npr   = in2-in-1;
+  nbd   = ((npr+3)/4)*3;
+  in2   = in;
+
+  while(npr > 4){
+    *out++  = base64_pr2six[(uint8_t)*in2]   << 2 | base64_pr2six[(uint8_t)in2[1]]>>4;
+    *out++  = base64_pr2six[(uint8_t)in2[1]] << 4 | base64_pr2six[(uint8_t)in2[2]]>>2;
+    *out++  = base64_pr2six[(uint8_t)in2[2]] << 6 | base64_pr2six[(uint8_t)in2[3]];
+    in2    += 4;
+    npr    -= 4;
+  }
+
+  if(npr > 1) *out++ = base64_pr2six[(uint8_t)*in2]   << 2 | base64_pr2six[(uint8_t)in2[1]]>>4;
+  if(npr > 2) *out++ = base64_pr2six[(uint8_t)in2[1]] << 4 | base64_pr2six[(uint8_t)in2[2]]>>2;
+  if(npr > 3) *out++ = base64_pr2six[(uint8_t)in2[2]] << 6 | base64_pr2six[(uint8_t)in2[3]];
+
+  if(nullterm) *out++ = 0;
+  nbd -= (4-npr) & 3;
+  nbd += nullterm;
+  return nbd;
+}
+
+size_t base64_enc(uint8_t const *in,size_t in_size,char *out,size_t out_size){
+  char   *p = out;
+  size_t  i;
+
+  assert(out_size >= BASE64_ENC_SIZE(in_size,1));
+  (void)out_size;
+
+  for(i = 0;i < in_size-2;i += 3){
+    *p++ = base64_basis[in[i]>>2 & 0x3F];
+    *p++ = base64_basis[(in[i]   & 0x03)<<4 | (int32_t)(in[i+1] & 0xF0)>>4];
+    *p++ = base64_basis[(in[i+1] & 0x0F)<<2 | (int32_t)(in[i+2] & 0xC0)>>6];
+    *p++ = base64_basis[in[i+2] & 0x3F];
+  }
+
+  if(i < in_size){
+    *p++ = base64_basis[in[i]>>2 & 0x3F];
+    if(i == in_size-1){
+      *p++ = base64_basis[(in[i] & 0x03)<<4];
+      *p++ = '=';
+    }else{
+      *p++ = base64_basis[(in[i] & 0x03)<<4 | (int32_t)(in[i+1] & 0xF0)>>4];
+      *p++ = base64_basis[(in[i+1] & 0x0F)<<2];
+    }
+    *p++ = '=';
+  }
+
+  *p++ = 0;
+  return p-out;
+}
+
diff -uNr a/src/otherpplgode/hmac.c b/src/otherpplgode/hmac.c
--- a/src/otherpplgode/hmac.c false
+++ b/src/otherpplgode/hmac.c 753dda1c250612d1189c94b6b919dc049f3587fb607aca9a02b6d8a2c1646dd5e1c70b256cacbf540ba7ecf364c3c57c67ed4104b9c9199b9cbebc3ea88434cd
@@ -0,0 +1,118 @@
+/*
+ * HMAC-SHA-224/256/384/512 implementation
+ * Last update: 06/15/2005
+ * Issue date:  06/15/2005
+ *
+ * Copyright (C) 2005 Olivier Gay <olivier.gay@a3.epfl.ch>
+ * All rights reserved.
+ *
+ * Redistribution and use in source and binary forms, with or without
+ * modification, are permitted provided that the following conditions
+ * are met:
+ * 1. Redistributions of source code must retain the above copyright
+ *    notice, this list of conditions and the following disclaimer.
+ * 2. Redistributions in binary form must reproduce the above copyright
+ *    notice, this list of conditions and the following disclaimer in the
+ *    documentation and/or other materials provided with the distribution.
+ * 3. Neither the name of the project nor the names of its contributors
+ *    may be used to endorse or promote products derived from this software
+ *    without specific prior written permission.
+ *
+ * ********************MODIFIED FOR USE IN SMALPEST********************
+ *
+ * THIS SOFTWARE IS PROVIDED BY THE PROJECT AND CONTRIBUTORS ``AS IS'' AND
+ * ANY EXPRESS OR IMPLIED WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE
+ * IMPLIED WARRANTIES OF MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE
+ * ARE DISCLAIMED.  IN NO EVENT SHALL THE PROJECT OR CONTRIBUTORS BE LIABLE
+ * FOR ANY DIRECT, INDIRECT, INCIDENTAL, SPECIAL, EXEMPLARY, OR CONSEQUENTIAL
+ * DAMAGES (INCLUDING, BUT NOT LIMITED TO, PROCUREMENT OF SUBSTITUTE GOODS
+ * OR SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS INTERRUPTION)
+ * HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT
+ * LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY
+ * OUT OF THE USE OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF
+ * SUCH DAMAGE.
+ */
+
+#include "hmac.h"
+#include <string.h>
+
+static void sha384(uint8_t *sha,uint8_t const *msg,size_t msg_len){
+  sha384_ctx ctx;
+  sha384_init(&ctx);
+  sha384_update(&ctx,msg,msg_len);
+  sha384_final(&ctx,sha);
+}
+
+void hmac_sha384_init(hmac_sha384_ctx *ctx, const unsigned char *key,
+                      unsigned int key_size)
+{
+    unsigned int fill;
+    unsigned int num;
+
+    const unsigned char *key_used;
+    unsigned char key_temp[SHA384_DIGEST_SIZE];
+    int i;
+
+    if (key_size == SHA384_BLOCK_SIZE) {
+        key_used = key;
+        num = SHA384_BLOCK_SIZE;
+    } else {
+        if (key_size > SHA384_BLOCK_SIZE){
+            num = SHA384_DIGEST_SIZE;
+            sha384(key_temp,key,key_size);
+            key_used = key_temp;
+        } else { /* key_size > SHA384_BLOCK_SIZE */
+            key_used = key;
+            num = key_size;
+        }
+        fill = SHA384_BLOCK_SIZE - num;
+
+        memset(ctx->block_ipad + num, 0x36, fill);
+        memset(ctx->block_opad + num, 0x5c, fill);
+    }
+
+    for (i = 0; i < (int) num; i++) {
+        ctx->block_ipad[i] = key_used[i] ^ 0x36;
+        ctx->block_opad[i] = key_used[i] ^ 0x5c;
+    }
+
+    sha384_init(&ctx->ctx_inside);
+    sha384_update(&ctx->ctx_inside, ctx->block_ipad, SHA384_BLOCK_SIZE);
+
+    sha384_init(&ctx->ctx_outside);
+    sha384_update(&ctx->ctx_outside, ctx->block_opad,
+                  SHA384_BLOCK_SIZE);
+
+    /* for hmac_reinit */
+    memcpy(&ctx->ctx_inside_reinit, &ctx->ctx_inside,
+           sizeof(sha384_ctx));
+    memcpy(&ctx->ctx_outside_reinit, &ctx->ctx_outside,
+           sizeof(sha384_ctx));
+}
+
+void hmac_sha384_reinit(hmac_sha384_ctx *ctx)
+{
+    memcpy(&ctx->ctx_inside, &ctx->ctx_inside_reinit,
+           sizeof(sha384_ctx));
+    memcpy(&ctx->ctx_outside, &ctx->ctx_outside_reinit,
+           sizeof(sha384_ctx));
+}
+
+void hmac_sha384_update(hmac_sha384_ctx *ctx, const unsigned char *message,
+                        unsigned int message_len)
+{
+    sha384_update(&ctx->ctx_inside, message, message_len);
+}
+
+void hmac_sha384_final(hmac_sha384_ctx *ctx, unsigned char *mac,
+                       unsigned int mac_size)
+{
+    unsigned char digest_inside[SHA384_DIGEST_SIZE];
+    unsigned char mac_temp[SHA384_DIGEST_SIZE];
+
+    sha384_final(&ctx->ctx_inside, digest_inside);
+    sha384_update(&ctx->ctx_outside, digest_inside, SHA384_DIGEST_SIZE);
+    sha384_final(&ctx->ctx_outside, mac_temp);
+    memcpy(mac, mac_temp, mac_size);
+}
+
diff -uNr a/src/otherpplgode/hmac.h b/src/otherpplgode/hmac.h
--- a/src/otherpplgode/hmac.h false
+++ b/src/otherpplgode/hmac.h edc00426d5a81ff3e6fba03aa372540e04d6dbbde6309bc9a5e7974f03366dba16dee546f50f211ee53aacf208d5ba888260b1f3f1eedee389266d045c4f2851
@@ -0,0 +1,64 @@
+/*
+ * HMAC-SHA-224/256/384/512 implementation
+ * Last update: 06/15/2005
+ * Issue date:  06/15/2005
+ *
+ * Copyright (C) 2005 Olivier Gay <olivier.gay@a3.epfl.ch>
