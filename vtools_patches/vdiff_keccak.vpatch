diff -uNr a/vtools/src/keccak.h b/vtools/src/keccak.h
--- a/vtools/src/keccak.h false
+++ b/vtools/src/keccak.h 4690c5fc14651a07b10242229ed106f68daefb21b48ed9275c265c6a122af0bf900fd9ac01fab96800b9e5b7341869a45a8ff65aa4043a03e2dd0b1d10efc390
