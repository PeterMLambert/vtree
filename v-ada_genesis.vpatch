+-------------------------------------------------------------------------------
+-- This file is part of V-Ada.                                               --
+--                                                                           --
+-- (C) $2025 Peter Lambert                                                   --
+--                                                                           --
+-- This product is distributed under "The V Public License"                  --
+-- ("VPL"; version 0xFF.)                                                    --
+--                                                                           --
+-- This means that it is a document with a cryptographically-verifiable      --
+-- history of attributable authorship.                                       --
+--                                                                           --
+-- See LICENSE.txt for further details.                                      --
+--                                                                           --
+-- This notice is to be retained where found.                                --
+-------------------------------------------------------------------------------
+
+-- Type for holding things like directory or file names
+
+package Str is
+	
+	-- We might have to increase this if there are larger file names?
+	subtype Str_Index is Natural range 1 .. 128; 
+	
+	type Str_L is 
+		record
+			Text : String(Str_Index'Range);
+			Len  : Natural;
+		end record;
+		
+	procedure Set(SL : in out Str_L; S : in String);
+	
+	function Get(SL : Str_L) return String;
+	
+	function "=" (Left : Str_L; Right : Str_L) return Boolean;
+	
+	function Startswith(Long : String; Short : String) return Boolean;
+	function Startswith(Long : Str_L;  Short : String) return Boolean;
+	function Startswith(Long : Str_L;  Short : Str_L)  return Boolean;
+	
+private
+
+end Str;
