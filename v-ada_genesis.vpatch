@@ -0,0 +1,83 @@
+-------------------------------------------------------------------------------
+-- This file is part of V-Ada.                                               --
+--                                                                           --
+-- (C) $2025 Peter Lambert                                                   --
+--                                                                           --
+-- This product is distributed under "The V Public License"                  --
+-- ("VPL"; version 0xFF.)                                                    --
+--                                                                           --
+-- This means that it is a document with a cryptographically-verifiable      --
+-- history of attributable authorship.                                       --
+--                                                                           --
+-- See LICENSE.txt for further details.                                      --
+--                                                                           --
+-- This notice is to be retained where found.                                --
+-------------------------------------------------------------------------------
+
+package body Str is
+	
+	-- Functions for Str_L type
+	procedure Set(SL : in out Str_L; S : in String) is
+	begin
+		SL.Text(1 .. S'Length) := S;
+		SL.Len := S'Length;
+	end Set;
+	
+	function Get(SL : Str_L) return String is
+	begin
+		return SL.Text(1 .. SL.Len);
+	end Get;
+	
+	function "=" (Left : Str_L; Right : Str_L) return Boolean is
+	begin
+		return Get(Left) = Get(Right);
+	end "=";
+	
+	
+	-- useful function for checking normal strings
+	function Startswith(Long : String; Short : String) return Boolean is
+	begin
+		if Long'Length < Short'Length then
+			return False;
+		else
+			for I in 0 .. Short'Length - 1 loop
+				if Short(Short'First + I) /= Long(Long'First + I) then
+					return False;
+				end if;
+			end loop;
+			return True;
+		end if;
+	end Startswith;
+	
+	
+	-- And the equivalents for use with our Str_L type
+	function Startswith(Long : Str_L; Short : String) return Boolean is
+	begin
+		if Long.Len < Short'Length then
+			return False;
+		else
+			for I in 0 .. Short'Length - 1 loop
+				if Short(Short'First + I) /= Long.Text(Long.Text'First + I) then
+					return False;
+				end if;
+			end loop;
+			return True;
+		end if;
+	end Startswith;
+	
+	function Startswith(Long : Str_L; Short : Str_L) return Boolean is
+	begin
+		if Long.Len < Short.Len then
+			return False;
+		else
+			for I in 0 .. Short.Len - 1 loop
+				if Short.Text(Short.Text'First + I) 
+				                          /= Long.Text(Long.Text'First + I) then
+					return False;
+				end if;
+			end loop;
+			return True;
+		end if;
+	end Startswith;
+
+end Str;
