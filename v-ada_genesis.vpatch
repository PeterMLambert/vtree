--- a/v-ada/src/lists.adb false
+++ b/v-ada/src/lists.adb f00b7a9304ded726ba9c3b32b216c0727e2e0e9539f5e8554e3e6f5635105244a77c9902078b02bd03132c971c3ff6752b239c2c0c1a1765137e1cf289d53c9b
@@ -0,0 +1,68 @@
+-------------------------------------------------------------------------------
+-- This file is part of V-Ada.                                               --
+--                                                                           --
+-- (C) $2025 Peter Lambert                                                   --
+--                                                                           --
+-- This product is distributed under "The V Public License"                  --
+-- ("VPL"; version 0xFF.)                                                    --
+--                                                                           --
+-- This means that it is a document with a cryptographically-verifiable      --
+-- history of attributable authorship.                                       --
+--                                                                           --
+-- See LICENSE.txt for further details.                                      --
+--                                                                           --
+-- This notice is to be retained where found.                                --
+-------------------------------------------------------------------------------
+
+package body Lists is
+
+	
+	procedure Append(List : in out LL_Ptr; New_Item : in Item_Type) is
+		Cur : LL_Ptr := List;
+	begin
+		if Cur = null then
+			List := new Linked_List'(Next => null, Item => New_Item);
+		else
+			while Cur.Next /= null loop
+				Cur := Cur.Next;
+			end loop;
+			Cur.Next := new Linked_List'(Next => null, Item => New_Item);
+		end if;
+	end Append;
+	
+	
+	procedure Remove(List : in out LL_Ptr; Old_Item : in Item_Type) is
+		Cur  : LL_Ptr := List;
+		Prev : LL_Ptr := List;
+	begin
+		if Eq(List.Item, Old_Item) then
+			List := List.Next;
+			Free(Cur);
+		else
+			while Cur /= null loop
+				if Eq(Cur.Item, Old_Item) then
+					Prev.Next := Cur.Next;
+					Free(Cur);
+					exit;
+				end if;
+				Prev := Cur;
+				Cur  := Cur.Next;
+			end loop;
+		end if;
+	end Remove;
+	
+	
+	function Has(List : LL_Ptr; Search_Item : Item_Type) return Boolean is
+		Cur : LL_Ptr := List;
+	begin
+		while Cur /= null loop
+			if Eq(Cur.Item, Search_Item) then
+				return True;
+			end if;
+			Cur := Cur.Next;
+		end loop;
+		return False;
+	end Has;
+	
+	
+end Lists;
