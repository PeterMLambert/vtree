+-------------------------------------------------------------------------------
+
+package body Sys is
+
+	procedure Run_Command(Command : in  String; 
+	                       Result  : out Ada.Command_Line.Exit_Status) is
+		Res : C.int;
+		Com : C.char_array := To_C(Command);
+	begin
+		Res := System(Com);
+		if Res = 0 then
+			Result := Ada.Command_Line.Success;
+		else
+			Result := Ada.Command_Line.Failure;
+		end if;
+	end Run_Command;
+	
+	
+	-- If you want to use this on Windows, switch this function
+	function Path_Join(A : String; B : String) return String is
+	begin
+		return A & "/" & B;
+	end Path_Join;
+	
+	
+end Sys;
\ No newline at end of file
