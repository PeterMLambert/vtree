@@ -0,0 +1,44 @@
+-------------------------------------------------------------------------------
+-- This file is part of V-Ada.                                               --
+--                                                                           --
+-- (C) $2025 Peter Lambert                                                   --
+--                                                                           --
+-- This product is distributed under "The V Public License"                  --
+-- ("VPL"; version 0xFF.)                                                    --
+--                                                                           --
+-- This means that it is a document with a cryptographically-verifiable      --
+-- history of attributable authorship.                                       --
+--                                                                           --
+-- See LICENSE.txt for further details.                                      --
+--                                                                           --
+-- This notice is to be retained where found.                                --
+-------------------------------------------------------------------------------
+
+-- This is a simple linked-list generic package.
+
+with Ada.Unchecked_Deallocation;
+
+generic 
+	type Item_Type is private;
+	with function Eq (Left , Right : Item_Type) return Boolean;
+package Lists is	
+	
+	type Linked_List;
+	type LL_Ptr is access Linked_List;
+	type Linked_List is 
+		record
+			Item : Item_Type;
+			Next : LL_Ptr;
+		end record;
+	
+	procedure Free is new Ada.Unchecked_Deallocation(Linked_List, LL_Ptr);
+	
+	procedure Append(List : in out LL_Ptr; New_Item : in Item_Type);
+
+	procedure Remove(List : in out LL_Ptr; Old_Item : in Item_Type);
+	
+	function Has(List : LL_Ptr; Search_Item : Item_Type) return Boolean;
+	
+private
+
+end Lists;
