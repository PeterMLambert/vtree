+-------------------------------------------------------------------------------
+-- This file is part of V-Ada.                                               --
+--                                                                           --
+-- (C) $2025 Peter Lambert                                                   --
+--                                                                           --
+-- This product is distributed under "The V Public License"                  --
+-- ("VPL"; version 0xFF.)                                                    --
+--                                                                           --
+-- This means that it is a document with a cryptographically-verifiable      --
+-- history of attributable authorship.                                       --
+--                                                                           --
+-- See LICENSE.txt for further details.                                      --
+--                                                                           --
+-- This notice is to be retained where found.                                --
+-------------------------------------------------------------------------------
+
+with Interfaces.C; use Interfaces.C;
+with Ada.Command_Line;
+
+
+package Sys is
+	
+	package C renames Interfaces.C;
+	use type C.int;
+	use type C.char_array;
+	
+	procedure Run_Command(Command : in  String; 
+	                       Result  : out Ada.Command_Line.Exit_Status);
+	
+	function Path_Join(A : String; B : String) return String;
+	
+private
+
+	function System(Arg : Char_Array) return Int;
+   pragma Import(C, System, "system");
+	
+end Sys;
diff -uNr a/v-ada/src/v.adb b/v-ada/src/v.adb
--- a/v-ada/src/v.adb false
+++ b/v-ada/src/v.adb e5ae2bbc69f9b321643fb0901bd705630637f71ca67f8c5304c3c1a440d219baf802aca98b4e5e6bcb5bae0f45f9d0e7b33465a9bdd182c677045b770a57c96b
@@ -0,0 +1,421 @@
+-------------------------------------------------------------------------------
+-- This file is part of V-Ada.                                               --
+--                                                                           --
+-- (C) $2025 Peter Lambert                                                   --
+--                                                                           --
+-- This product is distributed under "The V Public License"                  --
+-- ("VPL"; version 0xFF.)                                                    --
+--                                                                           --
+-- This means that it is a document with a cryptographically-verifiable      --
+-- history of attributable authorship.                                       --
+--                                                                           --
+-- See LICENSE.txt for further details.                                      --
+--                                                                           --
+-- This notice is to be retained where found.                                --
+-------------------------------------------------------------------------------
+
+
+-- Ada Library
+with Ada.Text_IO;      use Ada.Text_IO;
+with Ada.Command_Line; use Ada.Command_Line;
+with Ada.Directories;  use Ada.Directories;
+
+-- Modules for functions
+with Sys;    use Sys;   -- System calls
+with Str;    use Str;   -- String handling
+with Lists;              -- generic linked lists 
+
+
+procedure V is
+	V_Error : exception;
+	
+	-- Option for output, can be turned on/off with +v/-v as command argument
+	Verbose : Boolean := False; 
+	
+	procedure Spew(Message : String) is
+	begin
+		if Verbose then
+			Put_Line(Message);
+		end if;
+	end Spew;
+	
+	
+	type Dir_Values is (Patches, Seals, Wot, Target);
+	subtype In_Dirs is Dir_Values range Patches .. Wot;
+	
+	
+	-- Type for a list of files in a folder, and function to generate it
+	type Dir_Listing is array(Integer range <>) of Str_L;
+	
+	function Get_List(Dir : String; Pattern : String) return Dir_Listing is
+		File_List : Search_Type;          -- Type from Ada.Directories
+		File_Name : Directory_Entry_Type; -- Type from Ada.Directories
+		Count     : Natural :=0;
+	begin
+		-- Maybe there is an easier way to get a count of files without needing 
+		-- to repeat the search?
+		-- First, count the files
+		Start_Search(Search    => File_List, 
+						 Directory => Dir,
+						 Pattern   => Pattern,
+						 Filter    => (Ordinary_File => True, others => False));
+						 
+		while More_Entries(File_List) loop
+			Get_Next_Entry(File_List, File_Name);
+			Count := Count + 1;
+		end loop;
+		
+		-- Second, save file names
+		declare
+			Res : Dir_Listing(1 .. Count);
+		begin
+			Start_Search(Search    => File_List, 
+							 Directory => Dir,
+							 Pattern   => Pattern,
+							 Filter    => (Ordinary_File => True, others => False));
+			Count := 1;				 
+			while More_Entries(File_List) loop
+				Get_Next_Entry(File_List, File_Name);
+				Set(Res(Count), Simple_Name(File_Name));
+				Count := Count + 1;
+			end loop;
+			
+			return Res;
+		end;
+	end Get_List;
+	
+	
+	-- type for holding filename/hash sets for sorting patches, 
+	type File_State is 
+		record
+			File_Name : Str_L;
+			Hash      : Str_L;
+		end record;
+	
+	-- This function will get the filename/hash pairs as found in vpatches
+	function Split(L : String) return File_State is
+		Res : File_State;
+		C   : Character;
+		Pos : Natural := 7;
+	begin
+		-- line is of form "--- a/filename hash" or "+++ b/filename hash"
+		-- start at pos 7 to skip the a or b in the filename 
+		-- (need to verify, do all vpatches start with a/b?)
+		for I in Str_Index'Range loop
+			C   := L(Pos);
+			Pos := Pos + 1;
+			exit when C = ' ';
+			Res.File_Name.Text(I) := C;
+			Res.File_Name.Len := I;
+		end loop;
+		
+		for I in Str_Index'Range loop
+			exit when Pos > L'Last;
+			C := L(Pos);
+			Pos := Pos + 1;
+			Res.Hash.Text(I) := C;
+			Res.Hash.Len := I;
+		end loop;
+		
+		return Res;
+	end;
+	
+	function "=" (Left : File_State; Right : File_State) return Boolean is
+	begin
+		return Left.File_Name = Right.File_Name and Left.Hash = Right.Hash;
+	end "=";
+	
+	-- Linked list types
+	package Str_List   is new Lists (Item_Type => Str_L, Eq => "=");
+	use Str_List;
+	package State_List is new Lists (Item_Type => File_State, Eq => "=");
+	use State_List;
+	
+	
+	-- need a structure to hold {patch_1: [parents, children], ...}
+	type Chunk_Set is 
+		record
+			Patch    : Str_L; -- filname of patch
+			Parents  : State_List.LL_Ptr;
+			Children : State_List.LL_Ptr;
+		end record;
+	
+	
+	-- Variables for use below
+	Dirs : array(Dir_Values) of Str_L;
+	
+	Arg_Num  : Natural := 1;
+	
+	
+	Result  : Exit_Status;       -- Holds result of system commands
+	Found   : Boolean;
+	F       : File_Type;        -- used for reading patch files
+	FLine   : String(1..1000);  -- buffer for reading lines of files
+	Len     : Natural;
+	
+	Unsorted : Str_List.LL_Ptr := null;
+	Flow     : Str_List.LL_Ptr := null;
+	Cursor   : Str_List.LL_Ptr;
+
+begin
+	-- Default dir settings
+	Set( Dirs(Patches), "patches");
+	Set( Dirs(Seals),   "seals");
+	Set( Dirs(Wot),     "wot");
+	Set( Dirs(Target),  "v_out");
+	
+	-- Process the command line args
+	while Arg_Num <= Argument_Count loop
+		declare
+			Arg : String := Argument(Arg_Num);
+		begin
+			Arg_Num := Arg_Num + 1;
+			if Startswith(Arg, "-w") then
+				if Arg_Num > Argument_Count then
+					raise V_Error with "Need a WOT dir after -w";
+				end if;
+				declare
+					Arg2 : String := Argument(Arg_Num);
+				begin
+					Set(Dirs(Wot), Arg2);
+					Arg_Num := Arg_Num + 1;
+				end;
+				
+			elsif Startswith(Arg, "-p") then
+				if Arg_Num > Argument_Count then
+					raise V_Error with "Need a PATCHES dir after -p";
+				end if;
+				declare
+					Arg2 : String := Argument(Arg_Num);
+				begin
+					Set(Dirs(Patches), Arg2);
+					Arg_Num := Arg_Num + 1;
+				end;
+				
+			elsif Startswith(Arg, "-s") then
+				if Arg_Num > Argument_Count then
+					raise V_Error with "Need a SEALS dir after -s";
+				end if;
+				declare
+					Arg2 : String := Argument(Arg_Num);
+				begin
+					Set(Dirs(Seals), Arg2);
+					Arg_Num := Arg_Num + 1;
+				end;
+				
+			elsif Startswith(Arg, "+v") then
+				Verbose := True;
+				
+			elsif Startswith(Arg, "-v") then
+				Verbose := False;
+				
+			else
+				Set(Dirs(Target), Arg);
+				
+			end if;
+		end;
+	end loop;
+	
+	-- check directories to see if they exist
+	Spew("--- Checking directories ..");
+	for Dir in In_Dirs'Range loop
+		Spew(Dir'Image & ": " & Get(Dirs(Dir)));
+		if   not Exists(Get(Dirs(Dir))) 
+		     or else Kind(Get(Dirs(Dir))) /= Directory then
+			
+			raise V_Error with "Missing directory: " & Get(Dirs(Dir));
+		end if;
+	end loop;
+	
+	-- create target directory
+	Spew("TARGET: " & Get(Dirs(Target)));
+	if Exists(Get(Dirs(Target))) then
+		Spew("WARNING: Target directory already exists"); 
+		if Kind(Get(Dirs(Target))) /= Directory then
+			raise V_Error with "Target not a directory: " & Get(Dirs(Target));
+		end if;
+	else
+		Create_Directory(Get(Dirs(Target)));
+	end if;
+	
+	-- get file lists for WoT, patches, and seals
+	Spew("--- Loading files ..");
+	declare
+		Wot_Files   : Dir_Listing := 
+		  Get_List(Dir => Get(Dirs(Wot)),     Pattern => "*.asc");
+		Seal_Files  : Dir_Listing := 
+		  Get_List(Dir => Get(Dirs(Seals)),   Pattern => "*.sig");
+		Patch_Files : Dir_Listing := 
+		  Get_List(Dir => Get(Dirs(Patches)), Pattern => "*.vpatch");
+		
+		Chunks   : array(Patch_Files'Range) of Chunk_Set;
+		Chunk    : Chunk_Set;
+		Patch    : Str_L;
+		F_H      : File_State;
+		State    : State_List.LL_Ptr := null;
+		In_State : Boolean;
+		Cur      : State_List.LL_Ptr;
+	begin
+		
+		-- import sigs
+		Spew("--- Importing keys ..");
+		for Key of Wot_Files loop
+			Run_Command(Command => "gpg --import " & 
+			                       Get(Dirs(Wot)) & "/" & Get(Key), 
+			            Result => Result);
+			if Result /= Success then
+				raise V_Error with "Failed to load key: " & Get(Key);
+			end if;
+		end loop;
+		
+		-- verify signatures
+		Spew("--- Verifying seals ..");
+		for Patch of Patch_Files loop
+			Spew("file " & Get(Patch) & " ..");
+			Found := False;
+			
+			for Seal of Seal_Files loop
+				if Startswith(Seal, Patch) then
+					Found := True;
+					Run_Command(Command => "gpg --verify " & 
+					                      Path_Join(Get(Dirs(Seals)), Get(Seal)) & 
+										       " " & 
+									          Path_Join(Get(Dirs(Patches)), Get(Patch)), 
+									Result => Result);
+					if Result /= Success then
+						raise V_Error with "Verification failed: " 
+						                    & Get(Seal) & " " & Get(Patch);
+					end if;
+				end if;
+			end loop;
+			
+			if not Found then
+				raise V_Error with "No seal found for patch " & Get(Patch);
+			end if;
+			
+		end loop;
+		
+		-- read patch files to get chunks
+		Spew("--- Reading patches .. ");
+		for I in Patch_Files'Range loop
+			Patch := Patch_Files(I);
+			Chunks(I) := (Patch => Patch, Parents => null, Children => null);
+			
+			Open(F, In_File, Path_Join(Get(Dirs(Patches)), Get(Patch)));
+			while not End_Of_File(F) loop
+				Get_Line(F, FLine, Len);
+				if Startswith(FLine(1 .. Len), "diff ") then
+					if End_Of_File(F) then
+						raise V_Error with "Incomplete diff header, file " 
+						                    & Get(Patch);
+					end if;
+					Get_Line(F, FLine, Len);
+					if not Startswith(FLine(1 .. Len), "--- ") then
+						raise V_Error with "Bad diff header, file " 
+						                    & Get(Patch) & " Line " & Line(F)'Image;
+					end if;
+					-- save (file_name, hash) as parent of patch
+					F_H := Split(FLine(1 .. Len));
+					if Get(F_H.Hash) /= "false" then
+						State_List.Append(Chunks(I).Parents, F_H);
+					end if;
+					
+					if End_Of_File(F) then
+						raise V_Error with "Incomplete diff header, file " 
+						                    & Get(Patch);
+					end if;
+					Get_Line(F, FLine, Len);
+					if not Startswith(FLine(1 .. Len), "+++ ") then
+						raise V_Error with "Bad diff header, file " 
+						                    & Get(Patch) & " Line " & Line(F)'Image;
+					end if;
+					-- save (file_name, hash) as child of patch
+					F_H := Split(FLine(1 .. Len));
+					State_List.Append(Chunks(I).Children, F_H);
+				end if;
+			end loop;
+			Close(F);
+		end loop;
+		
+		-- sort into flow
+		Spew("--- Sorting patches into order ..");
+		for P of Patch_Files loop
+			Str_List.Append(Unsorted, P);
+		end loop;
+		
+		while Unsorted /= null loop
+			Cursor := Unsorted;
+			Found  := False;
+			
+			Sort : while Cursor /= null loop
+				-- find entry in chunks
+				for H of Chunks loop
+					if H.Patch = Cursor.Item then
+						Chunk := H;
+						exit;
+					end if;
+				end loop;
+				
+				-- see if all parents are in State
+				In_State := True;
+				Cur := Chunk.Parents;
+				while Cur /= null loop
+					In_State := In_State and Has(State, Cur.Item);
+					exit when not In_State;
+					Cur := Cur.Next;
+				end loop;
+				
+				if In_State then
+					Found := True;
+					
+					Str_List.Append(Flow, Cursor.Item);
+					Str_List.Remove(Unsorted, Cursor.Item);
+					
+					Cur := Chunk.Parents;
+					while Cur /= null loop
+						State_List.Remove(State, Cur.Item);
+						Cur := Cur.Next;
+					end loop;
+					
+					Cur := Chunk.Children;
+					while Cur /= null loop
+						State_List.Append(State, Cur.Item);
+						Cur := Cur.Next;
+					end loop;
+					
+					exit Sort;  -- start sort loop over at the first patch
+				end if;
+				
+				Cursor := Cursor.Next;
+			end loop Sort;
+			
+			if not Found then
+				raise V_Error with "Could not find flow to all patches, e.g. " &
+						Get(Unsorted.Item);
+			end if;
+		end loop;
+	end;
+	Spew("--- Flow is:");
+	Cursor := Flow;
+	while Cursor /= null loop
+		Spew(get(Cursor.Item));
+		Cursor := Cursor.Next;
+	end loop;
+	
+	-- press patches
+	Spew("--- Pressing patches ..");
+	Cursor := Flow;
+	while Cursor /= null loop
+		Spew("  Pressing file " & Get(Cursor.Item));
+		Run_Command(Command => "patch -E --dir " & Get(Dirs(Target)) & " -p1 < " 
+		                       & Path_Join(Get(Dirs(Patches)), Get(Cursor.Item)), 
+		            Result => Result);
+		if Result /= Success then
+			raise V_Error with "Failed to press patch: " & Get(Cursor.Item);
+		end if;
+		Cursor := Cursor.Next;
+	end loop;
+	
+	Spew("--- Done");
+	Set_Exit_Status(Success);
+end V;
diff -uNr a/v-ada/v_ada.gpr b/v-ada/v_ada.gpr
--- a/v-ada/v_ada.gpr false
+++ b/v-ada/v_ada.gpr eba433e2f63ea65c3e8a61fb1a947cc0a5c8e260a92fc3439ce1426fcacb140f4f404177243835374ff41fd3d21b34fc9b08732f5b54ab1b025d9675c54d657b
@@ -0,0 +1,64 @@
+-------------------------------------------------------------------------------
+-- This file is part of V-Ada.                                               --
+--                                                                           --
+-- (C) $2025 Peter Lambert                                                   --
+--                                                                           --
