+  char const       *desc;
+  unsigned          type;
+  union{
+    bool            b;
+    int64_t         i;
+    char const     *s;
+  }def;
+  int64_t           min;
+  int64_t           max;
+}knob_t;
+
+typedef void      (*strval_f)   (char *,size_t,void const *);
