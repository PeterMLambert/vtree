@@ -0,0 +1,13 @@
+from .broadcast_text import BroadcastText
+
+
+class BroadcastTextM(BroadcastText):
+    def __init__(self):
+        super().__init__()
+
+    def deliver(self, command):
+        # send to the client
+        self.api_service.enqueue_outbound(command.stringify())
+
+        # store
+        self.filter.intern(command)
diff -uNr - - akris/akris/pest_command_executors/direct_text.py akris-genesis/akris/pest_command_executors/direct_text.py
