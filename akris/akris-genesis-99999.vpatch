+
+
+class Unpeer:
+    def __init__(self):
+        self.db = Database.get_instance()
+
+    def execute(self, args):
+        if len(args) != 1:
+            response = {
+                "command": "console_response",
+                "type": "error",
+                "body": COMMANDS["unpeer"]["help"],
