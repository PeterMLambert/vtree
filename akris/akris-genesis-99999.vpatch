+
+def configure_pizarro(client):
+    client.send_command({"command": "handle", "args": ["pizarro"]})
+    client.send_command({"command": "peer", "args": ["cortes"]})
+    client.send_command({"command": "key", "args": ["cortes", P_C_KEY]})
