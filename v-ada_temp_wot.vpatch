 		Cur      : State_List.LL_Ptr;
 	begin
 		
-		-- import sigs
+		-- import keys
 		Spew("--- Importing keys ..");
 		for Key of Wot_Files loop
-			Run_Command(Command => "gpg --import " & 
-			                       Get(Dirs(Wot)) & "/" & Get(Key), 
+			Run_Command(Command => "gpg --homedir " & GPG_Temp_Dir & " --import " 
+			                       & Path_Join(Get(Dirs(Wot)), Get(Key)), 
 			            Result => Result);
 			if Result /= Success then
 				raise V_Error with "Failed to load key: " & Get(Key);
@@ -277,7 +279,8 @@
 			for Seal of Seal_Files loop
 				if Startswith(Seal, Patch) then
 					Found := True;
-					Run_Command(Command => "gpg --verify " & 
+					Run_Command(Command => "gpg --always-trust --homedir " & 
+					                      GPG_Temp_Dir & " --verify " & 
 					                      Path_Join(Get(Dirs(Seals)), Get(Seal)) & 
 										       " " & 
 									          Path_Join(Get(Dirs(Patches)), Get(Patch)), 
@@ -416,6 +419,17 @@
 		Cursor := Cursor.Next;
 	end loop;
 	
+	-- clean up temp dir
+	Delete_Tree(GPG_Temp_Dir);
+	
 	Spew("--- Done");
 	Set_Exit_Status(Success);
+	
+exception
+	when others =>
+		if Exists(GPG_Temp_Dir) then
+			Delete_Tree(GPG_Temp_Dir);
+		end if;
+		
+		raise;	
 end V;
