@@ -37,4 +37,15 @@
 	end Path_Join;
 	
 	
-end Sys;
\ No newline at end of file
+	function Get_Temp_Dir return String is
+		TD : String  := "temp";
+		N  : Integer := -1;
+	begin
+		while Ada.Directories.Exists(TD & N'Image) loop
+			N := N - 1;
+		end loop;
+		Ada.Directories.Create_Directory(TD & N'Image);
+		return TD & N'Image;
+	end Get_Temp_Dir;
+	
+end Sys;
